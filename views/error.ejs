<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Access Denied' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .error-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f8f9fa;
        }
        .error-card {
            max-width: 550px;
            width: 100%;
            padding: 40px;
            background: white;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
            text-align: center;
        }
        .error-icon {
            font-size: 64px;
            color: #dc3545;
            margin-bottom: 20px;
        }
        .error-details {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
            margin: 20px 0;
            text-align: left;
        }
        .error-details p {
            margin: 5px 0;
        }
        .btn-redirect {
            margin-top: 20px;
        }
        .badge-role {
            font-size: 14px;
            padding: 5px 12px;
        }
    </style>
</head>
<body>
    <div class="error-container">
        <div class="error-card">
            <div class="error-icon">🚫</div>
            <h1 class="h3 mb-3"><%= title || 'Access Denied' %></h1>
            <p class="text-muted"><%= message || 'You do not have permission to access this page.' %></p>
            
            <% if (typeof user !== 'undefined' && user) { %>
                <div class="error-details">
                    <p><strong>Logged in as:</strong> <%= user.fullname %></p>
                    <p><strong>User ID:</strong> <%= user.userId || user._id %></p>
                    <p>
                        <strong>Role:</strong> 
                        <span class="badge <%= user.role === 'admin' ? 'bg-danger' : user.role === 'student' ? 'bg-primary' : 'bg-warning' %> badge-role">
                            <%= user.role %>
                        </span>
                    </p>
                    <p><strong>Email:</strong> <%= user.email %></p>
                    <% if (typeof requiredRoles !== 'undefined' && requiredRoles) { %>
                        <p class="mt-2">
                            <strong>Required role(s):</strong> 
                            <%= requiredRoles.join(' or ') %>
                        </p>
                    <% } %>
                </div>
                
                <div class="alert alert-warning mt-3">
                    <i class="bi bi-info-circle"></i>
                    <small>You are trying to access a page that requires <strong><%= requiredRoles ? requiredRoles.join(' or ') : 'different' %></strong> privileges.</small>
                </div>
            <% } %>
            
            <div class="btn-redirect">
                <a href="<%= redirectUrl || '/login' %>" class="btn btn-primary">
                    Go to <%= user && user.role ? user.role.charAt(0).toUpperCase() + user.role.slice(1) : 'Home' %> Dashboard
                </a>
                <a href="/logout" class="btn btn-outline-secondary ms-2">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </a>
            </div>
        </div>
    </div>
    
    <!-- Bootstrap Icons (optional) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</body>
</html>