<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Registration – STAY EMBRACE</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="icon"  href="/images/logo-brow.png">
    <link rel="stylesheet" href="/css/preloader.css">
    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/portal.css">
</head>
<body>


<div class="top-slogan">
    <p>Embrace the Community <span class="slogan-dot"></span> Embrace the Growth <span class="slogan-dot"></span> Embrace the Future</p>
</div>

<nav class="navbar transparent-always">
    <a href="/" style="text-decoration:none;">
        <div class="navbar-left">
            <img src="/images/logo-head.png" alt="EMBRACE" class="logo-img">
            <div>
                <span class="logo-text">STAY EMBRACE</span>
                <div class="navbar-accent"></div>
            </div>
        </div>
    </a>
    <div class="nav-links">
        <a href="/">Home</a>
        <a href="/login" class="btn-login">Login</a>
    </div>
</nav>

<div class="portal-container" style="background: linear-gradient(rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0.15)), url('/images/reception.jpg') center/cover no-repeat;">
    <div class="portal-card">
        <img src="/images/logo-head.png" alt="EMBRACE" class="portal-logo-img">
        <div class="portal-logo-text">STAY EMBRACE</div>
        <div class="portal-divider"></div>
        <h2 class="portal-title">Registration</h2>
        <p class="portal-subtitle">Create your account to get started</p>
        <div class="portal-options">
            <a href="/register/student" class="portal-option student">
                <div class="portal-icon-circle"><i class="fas fa-user-graduate"></i></div>
                <span class="portal-option-label">Student</span>
                <span class="portal-option-desc">Join the hostel community</span>
            </a>
            <a href="/register/driver" class="portal-option driver">
                <div class="portal-icon-circle"><i class="fas fa-taxi"></i></div>
                <span class="portal-option-label">Driver / Transport</span>
                <span class="portal-option-desc">Cab &amp; transport providers</span>
            </a>
        </div>
    </div>
</div>

<script src="/js/preloader.js"></script>
</body>
</html>