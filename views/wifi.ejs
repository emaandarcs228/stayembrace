<script src="/js/preloader.js"></script>
<script>
    const n = document.getElementById("navbar");
    window.addEventListener("scroll", () => {
        window.scrollY > 50 ? n.classList.add("scrolled") : n.classList.remove("scrolled");
    });
    function reveal() {
        document.querySelectorAll('.fade-in').forEach(e => {
            const t = e.getBoundingClientRect().top, w = window.innerHeight;
            if (t < w - 80) e.classList.add('visible');
            if (t > w || t < -100) e.classList.remove('visible');
        });
    }
    window.addEventListener('scroll', reveal);
    reveal();
</script>
