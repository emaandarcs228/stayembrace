<section class="page-hero" style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.5)), url('https://images.pexels.com/photos/430205/pexels-photo-430205.jpeg?auto=compress&cs=tinysrgb&w=1600') center/cover no-repeat;">
    <h1>Contact Us</h1>
    <p>Get in touch with the hostel administration</p>
