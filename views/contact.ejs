        <p>General: hostel@embrace.pk<br>Warden: warden@embrace.pk<br>Admin: admin@embrace.pk</p>
    </div>
    <div class="contact-card">
        <div class="contact-card-icon"><i class="fas fa-clock"></i></div>
        <h4>Office Hours</h4>
        <p>Monday - Friday: 9 AM - 5 PM<br>Saturday: 9 AM - 1 PM<br>Sunday: Closed</p>
