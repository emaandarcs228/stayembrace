// ── LICENSE EXPIRY MONTH PICKER ──
const leTrigger   = document.getElementById('licenseExpiryTrigger');
const lePanel     = document.getElementById('licenseExpiryPanel');
const leLabel     = document.getElementById('licenseExpiryLabel');
const leInput     = document.getElementById('licenseExpiryInput');
const leMonthSel  = document.getElementById('leMonthSelect');
const leYearSel   = document.getElementById('leYearSelect');
const leMonths    = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
let leYear        = new Date().getFullYear();
let leMonth       = -1;

leMonths.forEach((m, i) => { const o = document.createElement('option'); o.value = i; o.textContent = m; leMonthSel.appendChild(o); });
for (let y = new Date().getFullYear(); y <= new Date().getFullYear() + 15; y++) { const o = document.createElement('option'); o.value = y; o.textContent = y; leYearSel.appendChild(o); }

function leRenderCells() {
  document.querySelectorAll('.le-month-cell').forEach(cell => {
    const m = parseInt(cell.dataset.month);
    cell.classList.toggle('selected', m === leMonth);
    const isPast = leYear < new Date().getFullYear() || (leYear === new Date().getFullYear() && m < new Date().getMonth());
    cell.classList.toggle('disabled', isPast);
  });
  leMonthSel.value = leMonth >= 0 ? leMonth : '';
  leYearSel.value  = leYear;
}

leTrigger.addEventListener('click', () => {
  const isOpen = lePanel.classList.toggle('open');
  leTrigger.classList.toggle('open', isOpen);
  if (isOpen) leRenderCells();
});

document.querySelectorAll('.le-month-cell').forEach(cell => {
  cell.addEventListener('click', () => {
    if (cell.classList.contains('disabled')) return;
    leMonth = parseInt(cell.dataset.month);
    const mm = String(leMonth + 1).padStart(2, '0');
    leLabel.textContent = `${leMonths[leMonth]} ${leYear}`;
    leInput.value = `${leYear}-${mm}`;
    leTrigger.classList.add('selected');
    lePanel.classList.remove('open');
    leTrigger.classList.remove('open');
    leRenderCells();
  });
});

document.getElementById('lePrevMonth').addEventListener('click', () => { leYear--; leRenderCells(); });
document.getElementById('leNextMonth').addEventListener('click', () => { leYear++; leRenderCells(); });
leMonthSel.addEventListener('change', () => { leMonth = parseInt(leMonthSel.value); leRenderCells(); });
leYearSel.addEventListener('change',  () => { leYear  = parseInt(leYearSel.value);  leRenderCells(); });
document.addEventListener('click', e => {
  const wrapper = document.getElementById('licenseExpiryTrigger').closest('.custom-date-wrapper');
  if (!wrapper || !wrapper.contains(e.target)) {
    lePanel.classList.remove('open');
    leTrigger.classList.remove('open');
  }
});

// ── DATE PICKER ──
const dobTrigger  = document.getElementById('dobTrigger');
const dobPanel    = document.getElementById('dobPanel');
const dobLabel    = document.getElementById('dobLabel');
const dobInput    = document.getElementById('dobInput');
const dateGrid    = document.getElementById('dateGrid');
const monthSelect = document.getElementById('monthSelect');
const yearSelect  = document.getElementById('yearSelect');
const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const today      = new Date();
let viewYear     = 1990;
let viewMonth    = 0;
let selectedDate = null;

months.forEach((m, i) => { const o = document.createElement('option'); o.value = i; o.textContent = m; monthSelect.appendChild(o); });
for (let y = today.getFullYear(); y >= 1950; y--) { const o = document.createElement('option'); o.value = y; o.textContent = y; yearSelect.appendChild(o); }

function syncSelects() { monthSelect.value = viewMonth; yearSelect.value = viewYear; }

function renderCalendar() {
    syncSelects();
    dateGrid.innerHTML = '';
    const firstDay    = new Date(viewYear, viewMonth, 1).getDay();
    const daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate();
    for (let i = 0; i < firstDay; i++) { const el = document.createElement('div'); el.className = 'date-cell empty'; dateGrid.appendChild(el); }
    for (let d = 1; d <= daysInMonth; d++) {
        const el = document.createElement('div');
        el.className = 'date-cell';
        el.textContent = d;
        const thisDate = new Date(viewYear, viewMonth, d);
        if (thisDate > today) el.classList.add('disabled');
        if (d === today.getDate() && viewMonth === today.getMonth() && viewYear === today.getFullYear()) el.classList.add('today');
        if (selectedDate && d === selectedDate.getDate() && viewMonth === selectedDate.getMonth() && viewYear === selectedDate.getFullYear()) el.classList.add('selected');
        el.addEventListener('click', () => {
            selectedDate = new Date(viewYear, viewMonth, d);
            dobLabel.textContent = `${d} ${months[viewMonth]} ${viewYear}`;
            dobTrigger.classList.add('selected');
            const mm = String(viewMonth + 1).padStart(2, '0');
            const dd = String(d).padStart(2, '0');
            dobInput.value = `${viewYear}-${mm}-${dd}`;
            dobPanel.classList.remove('open');
            dobTrigger.classList.remove('open');
            renderCalendar();
        });
        dateGrid.appendChild(el);
    }
}

dobTrigger.addEventListener('click', () => {
    const isOpen = dobPanel.classList.toggle('open');
    dobTrigger.classList.toggle('open', isOpen);
    if (isOpen) renderCalendar();
});
document.getElementById('prevMonth').addEventListener('click', () => { viewMonth--; if (viewMonth < 0) { viewMonth = 11; viewYear--; } renderCalendar(); });
document.getElementById('nextMonth').addEventListener('click', () => { viewMonth++; if (viewMonth > 11) { viewMonth = 0; viewYear++; } renderCalendar(); });
monthSelect.addEventListener('change', () => { viewMonth = parseInt(monthSelect.value); renderCalendar(); });
yearSelect.addEventListener('change',  () => { viewYear  = parseInt(yearSelect.value);  renderCalendar(); });
document.addEventListener('click', e => { const wrapper = document.querySelector('.custom-date-wrapper'); if (!wrapper || !wrapper.contains(e.target)) { dobPanel.classList.remove('open'); dobTrigger.classList.remove('open'); } });
renderCalendar();

// ── PAKISTANI FORMAT VALIDATION ──
function validatePakField(input, errorId) {
    const errorEl = document.getElementById(errorId);
    if (!input.value) {
        errorEl.style.display = 'none';
        input.style.borderColor = 'rgba(255,255,255,.2)';
        return true;
    }
    const valid = input.checkValidity();
    errorEl.style.display = valid ? 'none' : 'block';
    input.style.borderColor = valid ? 'rgba(74,124,89,.6)' : 'rgba(255,100,100,.6)';
    return valid;
}

// ── SUBMIT VALIDATION + SPINNER ──
document.getElementById('driverForm').addEventListener('submit', function(e) {
    const fields = [
        { id: 'cnicInput',        errorId: 'cnic-error',      name: 'CNIC' },
        { id: 'licenseInput',     errorId: 'license-error',   name: 'License Number' },
        { id: 'vehicleRegInput',  errorId: 'vreg-error',      name: 'Vehicle Registration' }
    ];
    let valid = true;
    fields.forEach(f => {
        const input = document.getElementById(f.id);
        if (input && input.value && !validatePakField(input, f.errorId)) {
            valid = false;
        }
    });
    if (!valid) {
        e.preventDefault();
        return;
    }
    const btn = document.getElementById('submitBtn');
    btn.disabled  = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Submitting…';
});
</script>

