<section class="page-hero" style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.5)), url('https://images.pexels.com/photos/256490/pexels-photo-256490.jpeg?auto=compress&cs=tinysrgb&w=1600') center/cover no-repeat;">
    <h1>Hostel Rules</h1>
    <p>Maintaining discipline and a conducive living environment</p>
</section>

<section class="page-content">
    <div class="container">
    <div class="rules-grid">
    <div class="rule-card">
        <div class="rule-icon-circle"><i class="fas fa-clock"></i></div>
        <h4>Curfew Timings</h4>
        <p>Strict adherence to hostel curfew. Late entry requires prior warden approval.</p>
    </div>
    <div class="rule-card">
        <div class="rule-icon-circle"><i class="fas fa-user-check"></i></div>
        <h4>Visitor Policy</h4>
        <p>Visitors allowed only in designated common areas during specified hours.</p>
    </div>
    <div class="rule-card">
        <div class="rule-icon-circle"><i class="fas fa-volume-mute"></i></div>
        <h4>Quiet Hours</h4>
        <p>Study silence from 7 PM to 7 AM. No loud music or disturbances.</p>
    </div>
    <div class="rule-card">
        <div class="rule-icon-circle"><i class="fas fa-broom"></i></div>
        <h4>Cleanliness</h4>
        <p>Weekly room inspections every Friday. Keep your space tidy.</p>
    </div>
    <div class="rule-card">
        <div class="rule-icon-circle"><i class="fas fa-calendar-check"></i></div>
        <h4>Daily Attendance</h4>
        <p>Attendance taken every night at 9 PM in your rooms.</p>
    </div>
    <div class="rule-card">
        <div class="rule-icon-circle"><i class="fas fa-ban"></i></div>
        <h4>Prohibited Items</h4>
        <p>No alcohol, drugs, or smoking allowed on hostel premises.</p>
    </div>
    <div class="rule-card">
        <div class="rule-icon-circle"><i class="fas fa-utensils"></i></div>
        <h4>Mess Rules</h4>
        <p>Food only in mess hall. No food allowed in dormitory rooms.</p>
    </div>
    <div class="rule-card">
        <div class="rule-icon-circle"><i class="fas fa-plug"></i></div>
        <h4>Electrical Appliances</h4>
        <p>No heaters or cooking equipment allowed in rooms.</p>
    </div>
</div>
</section>

