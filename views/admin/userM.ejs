<!-- ══════════════════════════════════════
     PENDING APPROVALS PAGE
══════════════════════════════════════ -->
<div class="page" id="page-pending">
  <div class="card">
    <div class="card-head">
      <h3><i class="ti ti-clock"></i> Pending Approvals</h3>
      <span style="font-size:.75rem;color:#C62828;font-weight:600"><%= pendingStudents.length %> awaiting review</span>
    </div>
    <% if(pendingStudents.length > 0){ %>
    <div class="tbl-wrap">
      <table>
        <thead><tr><th>Student</th><th>User ID</th><th>Email</th><th>ID Document</th><th>Registered</th><th class="actions-th">Actions</th></tr></thead>
        <tbody>
          <% pendingStudents.forEach(student => {
               const pendingIdUrl = student.idImage ? '/' + student.idImage : null;
          %>
          <tr class="pending-row">
            <td>
              <div class="user-cell">
                <div class="u-av s"><%= student.fullname.charAt(0).toUpperCase() %></div>
                <div><div class="u-name"><%= student.fullname %></div></div>
              </div>
            </td>
            <td><code class="uid-code"><%= student.userId %></code></td>
            <td><%= student.email %></td>
            <td>
              <% if (pendingIdUrl) { %>
                <button class="act-btn btn-view-id" onclick="openImageLightbox('<%= pendingIdUrl %>', '<%= student.fullname %>')">
                  <i class="fas fa-id-card"></i> View ID
                </button>
              <% } else { %>
                <span class="no-id-badge"><i class="fas fa-exclamation-circle"></i> Not uploaded</span>
              <% } %>
            </td>
            <td><%= new Date(student.createdAt).toLocaleDateString() %></td>
            <td class="actions-cell">
              <div class="action-cell">
                <form action="/admin/approve/<%= student._id %>" method="POST" style="display:inline">
                  <button type="submit" class="act-btn btn-approve">Approve</button>
                </form>
                <form action="/admin/reject/<%= student._id %>" method="POST" style="display:inline">
                  <button type="submit" class="act-btn btn-reject">Reject</button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="empty-state"><i class="fas fa-check-circle"></i><p>No pending approvals.</p></div>
    <% } %>
  </div>
</div>

<!-- ══════════════════════════════════════
     ADD USER PAGE
══════════════════════════════════════ -->
<div class="page" id="page-add-user">
  <div class="card">
    <div class="card-head">
      <h3><i class="ti ti-user-plus"></i> Add New User</h3>
    </div>
    <form action="/admin/users/add" method="POST" id="add-user-form" novalidate>
      <div class="form-section">
        <h4 class="form-section-title">Account Details</h4>
        <div class="form-grid">
          <div class="form-group">
            <label>Full Name <span class="req">*</span></label>
            <input type="text" name="fullname" id="au-fullname" placeholder="Enter full name" required>
          </div>
          <div class="form-group">
            <label>Email Address <span class="req">*</span></label>
            <input type="email" name="email" id="au-email" placeholder="Enter email" required>
          </div>
          <div class="form-group">
            <label>Phone Number <span class="req">*</span></label>
            <input type="tel" name="phoneNumber" id="au-phone" placeholder="Enter phone number" required>
          </div>
          <div class="form-group">
            <label>Gender <span class="req">*</span></label>
            <select name="gender" id="au-gender" required>
              <option value="male">Male</option>
              <option value="female">Female</option>
            </select>
          </div>
        </div>
      </div>
      <div class="form-section">
        <h4 class="form-section-title">Role &amp; Access</h4>
        <div class="form-grid">
          <div class="form-group">
            <label>Role <span class="req">*</span></label>
            <select name="role" id="au-role" required onchange="updateUserIdPreview()">
              <option value="student">Student</option>
              <option value="admin">Admin</option>
              <option value="warden">Warden</option>
            </select>
          </div>
          <div class="form-group" id="uid-preview" style="display:none">
            <label>Generated User ID</label>
            <div class="uid-preview-box">
              <i class="ti ti-id"></i>
              <span id="uid-preview-val">—</span>
            </div>
          </div>
        </div>
      </div>
      <div class="form-section">
        <h4 class="form-section-title">Security</h4>
        <div class="form-grid">
          <div class="form-group full">
            <label>Password <span class="req">*</span></label>
            <div class="pw-wrap">
              <input type="password" name="password" id="au-password"
                placeholder="Min 8 chars, mixed case + symbol" required
