                  data-phone="<%= admin.phoneNumber || '' %>" data-gender="<%= admin.gender || '' %>"
                  data-dob="<%= admin.dateOfBirth ? new Date(admin.dateOfBirth).toISOString().split('T')[0] : '' %>"
