<!-- ══════════════════════════════════════
     DRIVERS PAGE
══════════════════════════════════════ -->
<div class="page" id="page-drivers">
  <div class="card">
    <div class="card-head"><h3><i class="fas fa-taxi"></i> Drivers</h3><span class="count-pill"><%= (drivers || []).length %> total</span></div>
    <div class="tbl-wrap">
      <table>
        <thead><tr><th>#</th><th>Driver</th><th>User ID</th><th>Status</th><th>Phone</th><th>Joined</th><th class="actions-th">Actions</th></tr></thead>
        <tbody id="drivers-body">
          <% (drivers || []).forEach((driver, index) => { %>
          <tr>
            <td><%= index+1 %></td>
            <td>
              <div class="user-cell">
                <div class="u-av d"><%= driver.fullname.charAt(0).toUpperCase() %></div>
                <div>
                  <div class="u-name"><%= driver.fullname %></div>
                  <div class="u-email"><%= driver.email %></div>
                </div>
              </div>
            </td>
            <td><code class="uid-code"><%= driver.userId %></code></td>
            <td><span class="status-badge <%= driver.status %>"><%= driver.status %></span></td>
            <td><%= driver.phoneNumber || '—' %></td>
            <td><%= new Date(driver.createdAt).toLocaleDateString() %></td>
            <td class="actions-cell">
              <div class="action-cell">
                <button class="act-btn btn-view" data-action="view"
                  data-id="<%= driver._id %>" data-fullname="<%= driver.fullname %>" data-email="<%= driver.email %>"
                  data-role="<%= driver.role %>" data-status="<%= driver.status %>" data-userid="<%= driver.userId %>"
                  data-phone="<%= driver.phoneNumber || '' %>" data-gender="<%= driver.gender || '' %>"
                  data-dob="<%= driver.dateOfBirth ? new Date(driver.dateOfBirth).toISOString().split('T')[0] : '' %>"
                  data-joined="<%= new Date(driver.createdAt).toLocaleDateString() %>">
                  View
                </button>
                <% if (driver.status === 'pending') { %>
                  <form action="/admin/approve-driver/<%= driver._id %>" method="POST" style="display:inline">
                    <button type="submit" class="act-btn btn-approve">Approve</button>
                  </form>
                  <form action="/admin/reject-driver/<%= driver._id %>" method="POST" style="display:inline">
                    <button type="submit" class="act-btn btn-reject">Reject</button>
                  </form>
                <% } else if (driver.status === 'approved') { %>
                  <form action="/admin/suspend-driver/<%= driver._id %>" method="POST" style="display:inline"
                    onsubmit="return confirm('Suspend this driver? They will not be able to login.')">
                    <button type="submit" class="act-btn" style="background:#FFF8E1;color:#E65100">Suspend</button>
                  </form>
                <% } else if (driver.status === 'suspended') { %>
                  <form action="/admin/unsuspend-driver/<%= driver._id %>" method="POST" style="display:inline">
                    <button type="submit" class="act-btn" style="background:#E8F5E9;color:#2E7D32">Reactivate</button>
                  </form>
                <% } %>
                <button class="act-btn btn-del" data-action="delete" data-id="<%= driver._id %>" data-name="<%= driver.fullname %>">
                  Delete
                </button>
                <button class="act-btn" style="background:#FFF3E0;color:#F57C00"
                  onclick="openDriverInfoModal('<%= driver._id %>', '<%= driver.fullname.replace(/'/g, "\\'") %>', '<%= driver.userId %>')">
                  <i class="fas fa-truck"></i> Driver Info
                </button>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     PENDING APPROVALS PAGE
══════════════════════════════════════ -->
<div class="page" id="page-pending">
  <div class="card">
    <div class="card-head">
      <h3><i class="ti ti-clock"></i> Pending Approvals</h3>
      <span style="font-size:.75rem;color:#C62828;font-weight:600"><%= stats.pending %> awaiting review</span>
    </div>
    <% if(pendingStudents.length > 0 || pendingDrivers.length > 0){ %>
    <div class="tbl-wrap">
      <table>
        <thead><tr><th>User</th><th>User ID</th><th>Role</th><th>Email</th><th>Registered</th><th class="actions-th">Actions</th></tr></thead>
        <tbody>
          <% pendingStudents.forEach(student => {
               const pendingIdUrl = student.idImage ? '/' + student.idImage : null;
          %>
          <tr class="pending-row">
            <td>
              <div class="user-cell">
                <div class="u-av s"><%= student.fullname.charAt(0).toUpperCase() %></div>
                <div><div class="u-name"><%= student.fullname %></div></div>
              </div>
            </td>
            <td><code class="uid-code"><%= student.userId %></code></td>
            <td><span class="role-badge student">student</span></td>
            <td><%= student.email %></td>
            <td><%= new Date(student.createdAt).toLocaleDateString() %></td>
            <td class="actions-cell">
              <div class="action-cell">
                <form action="/admin/approve/<%= student._id %>" method="POST" style="display:inline">
                  <button type="submit" class="act-btn btn-approve">Approve</button>
                </form>
                <form action="/admin/reject/<%= student._id %>" method="POST" style="display:inline">
                  <button type="submit" class="act-btn btn-reject">Reject</button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
          <% pendingDrivers.forEach(driver => { %>
          <tr class="pending-row">
            <td>
              <div class="user-cell">
                <div class="u-av d"><%= driver.fullname.charAt(0).toUpperCase() %></div>
                <div><div class="u-name"><%= driver.fullname %></div></div>
              </div>
            </td>
            <td><code class="uid-code"><%= driver.userId %></code></td>
            <td><span class="role-badge driver">driver</span></td>
            <td><%= driver.email %></td>
            <td><%= new Date(driver.createdAt).toLocaleDateString() %></td>
            <td class="actions-cell">
              <div class="action-cell">
                <form action="/admin/approve-driver/<%= driver._id %>" method="POST" style="display:inline">
                  <button type="submit" class="act-btn btn-approve">Approve</button>
                </form>
                <form action="/admin/reject-driver/<%= driver._id %>" method="POST" style="display:inline">
                  <button type="submit" class="act-btn btn-reject">Reject</button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="empty-state"><i class="fas fa-check-circle"></i><p>No pending approvals.</p></div>
    <% } %>
  </div>
</div>

<!-- ══════════════════════════════════════
     ADD USER PAGE
══════════════════════════════════════ -->
<div class="page" id="page-add-user">
  <div class="card">
    <div class="card-head">
      <h3><i class="ti ti-user-plus"></i> Add New User</h3>
    </div>
    <form action="/admin/users/add" method="POST" id="add-user-form" enctype="multipart/form-data" novalidate>
      <div class="form-section">
        <h4 class="form-section-title">Account Details</h4>
        <div class="form-grid">
          <div class="form-group">
            <label>Full Name <span class="req">*</span></label>
            <input type="text" name="fullname" id="au-fullname" placeholder="Enter full name" required>
          </div>
          <div class="form-group">
            <label>Email Address <span class="req">*</span></label>
            <input type="email" name="email" id="au-email" placeholder="Enter email" required>
          </div>
          <div class="form-group">
            <label>Phone Number <span class="req">*</span></label>
            <input type="tel" name="phoneNumber" id="au-phone" placeholder="Enter phone number" required>
          </div>
          <div class="form-group">
            <label>Gender <span class="req">*</span></label>
            <select name="gender" id="au-gender" required>
              <option value="male">Male</option>
              <option value="female">Female</option>
            </select>
          </div>
        </div>
      </div>
      <div class="form-section">
        <h4 class="form-section-title">Role &amp; Access</h4>
        <div class="form-grid">
          <div class="form-group">
            <label>Role <span class="req">*</span></label>
            <select name="role" id="au-role" required onchange="updateUserIdPreview()">
              <option value="student">Student</option>
              <option value="admin">Admin</option>
              <option value="warden">Warden</option>
              <option value="driver">Driver</option>
            </select>
          </div>
          <div class="form-group" id="uid-preview" style="display:none">
            <label>Generated User ID</label>
            <div class="uid-preview-box">
              <i class="ti ti-id"></i>
              <span id="uid-preview-val">—</span>
            </div>
          </div>
        </div>
      </div>
      <div class="form-section" id="idCardSection" style="display:none">
        <h4 class="form-section-title">ID Card <span style="font-weight:400;font-size:.75rem;color:#C62828">(required for students)</span></h4>
        <div class="form-grid">
          <div class="form-group full">
            <label>Upload ID Card <span class="req">*</span></label>
            <div class="file-upload-wrap">
              <label class="file-upload-label" for="au-idImage" id="au-idImage-label">
                <i class="fas fa-cloud-upload-alt"></i>
                <span>Click to upload CNIC or Student ID card</span>
                <span class="file-upload-hint">JPG, PNG, WebP or PDF — Max 5 MB</span>
              </label>
              <input type="file" name="idImage" id="au-idImage" accept=".jpg,.jpeg,.png,.webp,.pdf"
                onchange="handleIdImagePreview(event)" onpaste="return false">
            </div>
            <div class="file-preview" id="au-idImage-preview" style="display:none">
              <div class="file-preview-info">
                <i class="fas fa-id-card"></i>
                <span id="au-idImage-name"></span>
              </div>
              <button type="button" class="file-preview-remove" onclick="clearIdImage()" title="Remove file">
                <i class="fas fa-times"></i>
              </button>
            </div>
            <span class="field-hint" id="au-idImage-hint">Upload a clear scan or photo of your CNIC or Student ID card.</span>
          </div>
        </div>
      </div>

      <div class="form-section">
        <h4 class="form-section-title">Security</h4>
        <div class="form-grid">
          <div class="form-group full">
            <label>Password <span class="req">*</span></label>
            <div class="pw-wrap">
              <input type="password" name="password" id="au-password"
                placeholder="Min 8 chars, mixed case + symbol" required
                minlength="8"
                oninput="validatePasswordField()">
              <button type="button" class="pw-toggle" onclick="togglePw('au-password', this)">
                <i class="fas fa-eye"></i>
              </button>
            </div>
            <span class="field-hint" id="au-password-hint">Min 8 chars with at least 3 of: uppercase, lowercase, number, special character.</span>
          </div>
        </div>
      </div>
      <div class="form-footer">
        <button type="submit" class="btn-primary"><i class="ti ti-user-plus"></i> Create User</button>
        <button type="button" class="btn-sec" onclick="clearAddForm()">Clear</button>
      </div>
    </form>
  </div>
</div>


