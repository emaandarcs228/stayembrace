<%
  const activePage   = 'users';
  const pageTitle    = 'User Management';
  const pageSubtitle = 'Manage students, wardens, and admins';
  const pendingApprovalsCount = stats.pending;
%>
<%- include('admin-header') %>

<!-- ── Search ── -->
<div style="display:flex;justify-content:flex-end;margin-bottom:1.2rem">
  <div class="search-bar" style="max-width:320px;width:100%">
    <i class="ti ti-search"></i>
    <input type="text" placeholder="Search users..." id="globalSearch" oninput="globalSearchHandler()">
  </div>
</div>

<!-- ── Sub-nav tabs ── -->
<div class="page-tabs">
  <button class="act-btn active" style="background:#E8EAF6;color:#3949AB" onclick="showPage('overview',this)"><i class="ti ti-layout-dashboard"></i> Overview</button>
  <button class="act-btn" style="background:#E3F2FD;color:#1565C0" onclick="showPage('all-users',this)"><i class="ti ti-users"></i> All Users</button>
  <button class="act-btn" style="background:#EEF5F0;color:#2D5A3D" onclick="showPage('students',this)"><i class="ti ti-school"></i> Students</button>
  <button class="act-btn" style="background:#F3E5F5;color:#7B1FA2" onclick="showPage('admins',this)"><i class="ti ti-shield"></i> Admins</button>
  <button class="act-btn" style="background:#FFF8E1;color:#E65100" onclick="showPage('wardens',this)"><i class="ti ti-user-check"></i> Wardens</button>
  <button class="act-btn" id="nav-pending" style="background:#FFEBEE;color:#C62828" onclick="showPage('pending',this)">
    <i class="ti ti-clock"></i> Pending Approvals
    <% if (pendingStudents.length > 0) { %><span style="background:#C62828;color:white;font-size:.55rem;padding:.1rem .35rem;border-radius:10px;font-weight:700;margin-left:.2rem"><%= pendingStudents.length %></span><% } %>
  </button>
  <button class="act-btn" id="nav-add-user" style="background:#E8F5E9;color:#2E7D32" onclick="showPage('add-user',this)"><i class="ti ti-user-plus"></i> Add User</button>
</div>

<!-- ══════════════════════════════════════
     OVERVIEW PAGE
══════════════════════════════════════ -->
<div class="page active" id="page-overview">
  <div class="stats-row">
    <div class="stat-card clickable" onclick="showPage('all-users',null)">
      <div class="s-icon all"><i class="ti ti-users"></i></div>
      <div class="s-info"><h4>Total Users</h4><h3><%= stats.totalUsers %></h3></div>
    </div>
    <div class="stat-card clickable" onclick="showPage('students',null)">
      <div class="s-icon student"><i class="ti ti-school"></i></div>
      <div class="s-info"><h4>Students</h4><h3><%= stats.students %></h3></div>
    </div>
    <div class="stat-card clickable" onclick="showPage('admins',null)">
      <div class="s-icon admin"><i class="ti ti-shield"></i></div>
      <div class="s-info"><h4>Admins</h4><h3><%= stats.admins %></h3></div>
    </div>
    <div class="stat-card clickable" onclick="showPage('wardens',null)">
      <div class="s-icon warden"><i class="ti ti-user-check"></i></div>
      <div class="s-info"><h4>Wardens</h4><h3><%= stats.wardens %></h3></div>
    </div>
    <div class="stat-card clickable" onclick="showPage('pending',null)">
      <div class="s-icon pending"><i class="ti ti-clock"></i></div>
      <div class="s-info"><h4>Pending</h4><h3><%= stats.pending %></h3></div>
    </div>
  </div>

  <div class="card">
    <div class="card-head">
      <h3><i class="ti ti-clock"></i> Pending Approvals</h3>
      <button class="add-btn" onclick="showPage('pending',null)">View All</button>
    </div>
    <% if(pendingStudents.length > 0){ %>
    <div class="tbl-wrap">
      <table>
        <thead><tr><th>Student</th><th>User ID</th><th>Email</th><th>ID Document</th><th>Registered</th><th class="actions-th">Actions</th></tr></thead>
        <tbody>
          <% pendingStudents.forEach(student => { %>
          <tr class="pending-row">
            <td>
              <div class="user-cell">
                <div class="u-av s"><%= student.fullname.charAt(0).toUpperCase() %></div>
                <div><div class="u-name"><%= student.fullname %></div></div>
              </div>
            </td>
            <td><code class="uid-code"><%= student.userId %></code></td>
            <td><%= student.email %></td>
            <td>
              <%
                const overviewIdUrl = student.idImage ? '/' + student.idImage : null;
              %>
              <% if (overviewIdUrl) { %>
                <button class="act-btn btn-view-id" onclick="openImageLightbox('<%= overviewIdUrl %>', '<%= student.fullname %>')">
                  <i class="fas fa-id-card"></i> View ID
                </button>
              <% } else { %>
                <span class="no-id-badge"><i class="fas fa-exclamation-circle"></i> Not uploaded</span>
              <% } %>
            </td>
            <td><%= new Date(student.createdAt).toLocaleDateString() %></td>
            <td class="actions-cell">
              <div class="action-cell">
                <form action="/admin/approve/<%= student._id %>" method="POST" style="display:inline">
                  <button type="submit" class="act-btn btn-approve">Approve</button>
                </form>
                <form action="/admin/reject/<%= student._id %>" method="POST" style="display:inline">
                  <button type="submit" class="act-btn btn-reject">Reject</button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="empty-state"><i class="fas fa-check-circle"></i><p>No pending approvals.</p></div>
    <% } %>
  </div>

  <div class="card">
    <div class="card-head"><h3><i class="ti ti-users"></i> Recent Users</h3></div>
    <div class="tbl-wrap">
      <table>
        <thead><tr><th>User</th><th>User ID</th><th>Role</th><th>Status</th><th>Joined</th><th class="actions-th">Actions</th></tr></thead>
        <tbody>
          <% users.slice(0,5).forEach(u => { %>
          <tr>
            <td>
              <div class="user-cell">
                <div class="u-av"><%= u.fullname.charAt(0).toUpperCase() %></div>
                <div>
                  <div class="u-name"><%= u.fullname %></div>
                  <div class="u-email"><%= u.email %></div>
                </div>
              </div>
            </td>
            <td><code class="uid-code"><%= u.userId %></code></td>
            <td><span class="role-badge <%= u.role %>"><%= u.role %></span></td>
            <td><span class="status-badge <%= u.status %>"><%= u.status %></span></td>
            <td><%= new Date(u.createdAt).toLocaleDateString() %></td>
            <td class="actions-cell">
              <div class="action-cell">
                <button class="act-btn btn-view" data-action="view"
                  data-id="<%= u._id %>" data-fullname="<%= u.fullname %>" data-email="<%= u.email %>"
                  data-role="<%= u.role %>" data-status="<%= u.status %>" data-userid="<%= u.userId %>"
                  data-phone="<%= u.phoneNumber || '' %>" data-gender="<%= u.gender || '' %>"
                  data-dob="<%= u.dateOfBirth ? new Date(u.dateOfBirth).toISOString().split('T')[0] : '' %>"
                  data-joined="<%= new Date(u.createdAt).toLocaleDateString() %>">
                  View
                </button>
                <button class="act-btn btn-del" data-action="delete" data-id="<%= u._id %>" data-name="<%= u.fullname %>">
                  Delete
                </button>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     ALL USERS PAGE
══════════════════════════════════════ -->
<div class="page" id="page-all-users">
  <div class="card">
    <div class="card-head">
      <h3><i class="ti ti-users"></i> All Users</h3>
      <div class="card-actions">
        <select class="filter-sel" id="filter-role" onchange="applyFilters()">
          <option value="all">All Roles</option>
          <option value="student">Students</option>
          <option value="admin">Admins</option>
          <option value="warden">Wardens</option>
        </select>
        <select class="filter-sel" id="filter-status" onchange="applyFilters()">
          <option value="all">All Status</option>
          <option value="approved">Approved</option>
          <option value="pending">Pending</option>
          <option value="rejected">Rejected</option>
        </select>
      </div>
    </div>
    <div class="tbl-wrap">
      <table id="all-table">
        <thead><tr><th>#</th><th>User</th><th>User ID</th><th>Role</th><th>Status</th><th>Joined</th><th class="actions-th">Actions</th></tr></thead>
        <tbody id="all-body">
          <% users.forEach((u, index) => { %>
          <tr data-role="<%= u.role %>" data-status="<%= u.status %>">
            <td><%= index+1 %></td>
            <td>
              <div class="user-cell">
                <div class="u-av"><%= u.fullname.charAt(0).toUpperCase() %></div>
                <div>
                  <div class="u-name"><%= u.fullname %></div>
                  <div class="u-email"><%= u.email %></div>
                </div>
              </div>
            </td>
            <td><code class="uid-code"><%= u.userId %></code></td>
            <td><span class="role-badge <%= u.role %>"><%= u.role %></span></td>
            <td><span class="status-badge <%= u.status %>"><%= u.status %></span></td>
            <td><%= new Date(u.createdAt).toLocaleDateString() %></td>
            <td class="actions-cell">
              <div class="action-cell">
                <button class="act-btn btn-view" data-action="view"
                  data-id="<%= u._id %>" data-fullname="<%= u.fullname %>" data-email="<%= u.email %>"
                  data-role="<%= u.role %>" data-status="<%= u.status %>" data-userid="<%= u.userId %>"
                  data-phone="<%= u.phoneNumber || '' %>" data-gender="<%= u.gender || '' %>"
                  data-dob="<%= u.dateOfBirth ? new Date(u.dateOfBirth).toISOString().split('T')[0] : '' %>"
                  data-joined="<%= new Date(u.createdAt).toLocaleDateString() %>">
                  View
                </button>
                <button class="act-btn btn-del" data-action="delete" data-id="<%= u._id %>" data-name="<%= u.fullname %>">
                  Delete
                </button>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div class="pagination" id="all-users-pagination">
      <span id="all-users-page-info">Showing 1–13 of <%= users.length %> users</span>
      <div class="page-btns" id="all-users-page-btns"></div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     STUDENTS PAGE
══════════════════════════════════════ -->
<div class="page" id="page-students">
  <div class="card">
    <div class="card-head">
      <h3><i class="ti ti-school"></i> Students</h3>
      <span class="count-pill"><%= students.length %> total</span>
    </div>
    <div class="tbl-wrap">
      <table>
        <thead>
          <tr>
            <th>#</th><th>Student</th><th>Status</th>
            <th>ID Document</th><th>Profile Info</th><th>Joined</th><th class="actions-th">Actions</th>
          </tr>
        </thead>
        <tbody id="students-body">
          <% students.forEach((student, index) => {
               const hasInfo = studentInfoMap && studentInfoMap[student._id.toString()];
               const studentIdUrl = student.idImage ? '/' + student.idImage : null;
          %>
          <tr>
            <td><%= index+1 %></td>
            <td>
              <div class="user-cell">
                <div class="u-av s"><%= student.fullname.charAt(0).toUpperCase() %></div>
                <div>
                  <div class="u-name"><%= student.fullname %></div>
                  <div class="u-sub"><code class="uid-code"><%= student.userId %></code> · <%= student.phoneNumber || 'No phone' %></div>
                </div>
              </div>
            </td>
            <td><span class="status-badge <%= student.status %>"><%= student.status %></span></td>
            <td>
              <% if (studentIdUrl) { %>
                <button class="act-btn btn-view-id" onclick="openImageLightbox('<%= studentIdUrl %>', '<%= student.fullname %>')">
                  <i class="fas fa-id-card"></i> View ID
                </button>
              <% } else { %>
                <span class="no-id-badge"><i class="fas fa-exclamation-circle"></i> Not uploaded</span>
              <% } %>
            </td>
            <td>
              <% if (hasInfo) { %>
                <span class="info-pill info-filled"><i class="fas fa-check-circle"></i> Filled</span>
              <% } else { %>
                <span class="info-pill info-empty"><i class="fas fa-exclamation-circle"></i> Missing</span>
              <% } %>
            </td>
            <td><%= new Date(student.createdAt).toLocaleDateString() %></td>
            <td class="actions-cell">
              <div class="action-cell">
                <button class="act-btn btn-view" data-action="view"
                  data-id="<%= student._id %>" data-fullname="<%= student.fullname %>" data-email="<%= student.email %>"
                  data-role="<%= student.role %>" data-status="<%= student.status %>" data-userid="<%= student.userId %>"
                  data-phone="<%= student.phoneNumber || '' %>" data-gender="<%= student.gender || '' %>"
                  data-dob="<%= student.dateOfBirth ? new Date(student.dateOfBirth).toISOString().split('T')[0] : '' %>"
                  data-joined="<%= new Date(student.createdAt).toLocaleDateString() %>">
                  View
                </button>
                <button class="act-btn btn-del" data-action="delete" data-id="<%= student._id %>" data-name="<%= student.fullname %>">
                  Delete
                </button>
                <% if (student.status === 'approved') { %>
                  <button class="act-btn btn-student-info" data-action="student-info"
                    data-userid="<%= student._id %>" data-fullname="<%= student.fullname %>">
                    <i class="fas fa-id-card"></i> Student Info
                  </button>
                <% } else { %>
                  <button class="act-btn btn-student-info-locked" disabled
                    title="Student info is only available after the account is approved">
                    <i class="fas fa-lock"></i> Student Info
                  </button>
                <% } %>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
    ADMINS PAGE
══════════════════════════════════════ -->
<div class="page" id="page-admins">
  <div class="card">
    <div class="card-head"><h3><i class="ti ti-shield"></i> Admins</h3><span class="count-pill"><%= admins.length %> total</span></div>
    <div class="tbl-wrap">
      <table>
        <thead><tr><th>#</th><th>Admin</th><th>User ID</th><th>Status</th><th>Phone</th><th>Joined</th><th class="actions-th">Actions</th></tr></thead>
        <tbody id="admins-body">
          <% admins.forEach((admin, index) => { %>
          <tr>
            <td><%= index+1 %></td>
            <td>
              <div class="user-cell">
                <div class="u-av a"><%= admin.fullname.charAt(0).toUpperCase() %></div>
                <div>
                  <div class="u-name"><%= admin.fullname %></div>
                  <div class="u-email"><%= admin.email %></div>
                </div>
              </div>
            </td>
            <td><code class="uid-code"><%= admin.userId %></code></td>
            <td><span class="status-badge approved"><%= admin.status %></span></td>
            <td><%= admin.phoneNumber || '—' %></td>
            <td><%= new Date(admin.createdAt).toLocaleDateString() %></td>
            <td class="actions-cell">
              <div class="action-cell">
                <button class="act-btn btn-view" data-action="view"
                  data-id="<%= admin._id %>" data-fullname="<%= admin.fullname %>" data-email="<%= admin.email %>"
                  data-role="<%= admin.role %>" data-status="<%= admin.status %>" data-userid="<%= admin.userId %>"
                  data-phone="<%= admin.phoneNumber || '' %>" data-gender="<%= admin.gender || '' %>"
                  data-dob="<%= admin.dateOfBirth ? new Date(admin.dateOfBirth).toISOString().split('T')[0] : '' %>"
                  data-joined="<%= new Date(admin.createdAt).toLocaleDateString() %>">
                  View
                </button>
                <button class="act-btn btn-del" data-action="delete" data-id="<%= admin._id %>" data-name="<%= admin.fullname %>">
                  Delete
                </button>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     WARDENS PAGE
══════════════════════════════════════ -->
<div class="page" id="page-wardens">
  <div class="card">
    <div class="card-head"><h3><i class="ti ti-user-check"></i> Wardens</h3><span class="count-pill"><%= wardens.length %> total</span></div>
    <div class="tbl-wrap">
      <table>
        <thead><tr><th>#</th><th>Warden</th><th>User ID</th><th>Status</th><th>Phone</th><th>Joined</th><th class="actions-th">Actions</th></tr></thead>
        <tbody id="wardens-body">
          <% wardens.forEach((warden, index) => { %>
          <tr>
            <td><%= index+1 %></td>
            <td>
              <div class="user-cell">
                <div class="u-av w"><%= warden.fullname.charAt(0).toUpperCase() %></div>
                <div>
                  <div class="u-name"><%= warden.fullname %></div>
                  <div class="u-email"><%= warden.email %></div>
                </div>
              </div>
            </td>
            <td><code class="uid-code"><%= warden.userId %></code></td>
            <td><span class="status-badge approved"><%= warden.status %></span></td>
            <td><%= warden.phoneNumber || '—' %></td>
            <td><%= new Date(warden.createdAt).toLocaleDateString() %></td>
            <td class="actions-cell">
              <div class="action-cell">
                <button class="act-btn btn-view" data-action="view"
                  data-id="<%= warden._id %>" data-fullname="<%= warden.fullname %>" data-email="<%= warden.email %>"
                  data-role="<%= warden.role %>" data-status="<%= warden.status %>" data-userid="<%= warden.userId %>"
                  data-phone="<%= warden.phoneNumber || '' %>" data-gender="<%= warden.gender || '' %>"
                  data-dob="<%= warden.dateOfBirth ? new Date(warden.dateOfBirth).toISOString().split('T')[0] : '' %>"
                  data-joined="<%= new Date(warden.createdAt).toLocaleDateString() %>">
                  View
                </button>
                <button class="act-btn btn-del" data-action="delete" data-id="<%= warden._id %>" data-name="<%= warden.fullname %>">
                  Delete
