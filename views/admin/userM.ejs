}

function diSwitchToView() {
  document.getElementById('di-view-section').style.display = 'block';
  document.getElementById('di-edit-section').style.display  = 'none';
  document.getElementById('di-btn-edit').style.display      = 'flex';
  document.getElementById('di-btn-save').style.display      = 'none';
  document.getElementById('di-btn-cancel').style.display    = 'none';
  document.getElementById('di-modal-title').innerHTML       = '<i class="fas fa-truck"></i> Driver Information';
}

async function diSubmit() {
  const mongoId = document.getElementById('driverInfoModal').dataset.currentId;
  if (!mongoId) {
    alert('Session error: missing driver reference. Please close and reopen the modal.');
    return;
  }

  const payload = {
    cnic                : document.getElementById('de-cnic').value.trim(),
    licenseNumber       : document.getElementById('de-licenseNumber').value.trim(),
    licenseExpiry       : document.getElementById('de-licenseExpiry').value || null,
    vehicleType         : document.getElementById('de-vehicleType').value,
    vehicleRegistration : document.getElementById('de-vehicleRegistration').value.trim(),
    vehicleModel        : document.getElementById('de-vehicleModel').value.trim(),
    serviceArea         : document.getElementById('de-serviceArea').value.trim(),
    experienceYears     : document.getElementById('de-experienceYears').value
  };

  try {
    const res  = await fetch(`/admin/drivers/${mongoId}/info`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (!res.ok || data.error) {
      alert(data.error || 'Failed to save driver information.');
      return;
    }
    diSwitchToView();
    document.getElementById('di-user-name').textContent = data.driver.fullname || document.getElementById('di-user-name').textContent;
    // Re-populate view fields from response
    const d = data.driverInfo || {};
    document.getElementById('dv-cnic').textContent               = d.cnic || '—';
    document.getElementById('dv-verified').textContent           = d.isVerified ? 'Yes' : 'No';
    document.getElementById('dv-licenseNumber').textContent      = d.licenseNumber || '—';
    document.getElementById('dv-licenseExpiry').textContent      = d.licenseExpiry ? new Date(d.licenseExpiry).toLocaleDateString() : '—';
    document.getElementById('dv-vehicleType').textContent        = d.vehicleType ? d.vehicleType.charAt(0).toUpperCase() + d.vehicleType.slice(1) : '—';
    document.getElementById('dv-vehicleRegistration').textContent = d.vehicleRegistration || '—';
    document.getElementById('dv-vehicleModel').textContent       = d.vehicleModel || '—';
    document.getElementById('dv-serviceArea').textContent        = d.serviceArea || '—';
    document.getElementById('dv-experienceYears').textContent    = d.experienceYears ? d.experienceYears + ' yrs' : '—';
    alert('Driver information saved successfully!');
  } catch (err) {
    alert('Failed to save driver information.');
  }
}

// Also allow the driver info modal to be closed from the input if needed
document.addEventListener('keydown', function (e) {
  if (e.key === 'Escape') {
    if (document.getElementById('driverInfoModal').classList.contains('open')) {
      closeDriverInfoModal();
    }
  }
});

// ── Driver document lightbox ──
function openDocLightbox(path) {
  closeDocLightbox();
  var lb = document.getElementById('diDocLightbox');
  var img = document.getElementById('diDocLightboxImg');
  var iframe = document.getElementById('diDocLightboxIframe');

  if (path.toLowerCase().endsWith('.pdf')) {
    iframe.src = '/' + path;
    iframe.style.display = 'block';
  } else {
    img.src = '/' + path;
    img.style.display = 'block';
  }
  lb.classList.add('open');
}

function closeDocLightbox() {
  var lb = document.getElementById('diDocLightbox');
  if (lb) lb.classList.remove('open');
  var img = document.getElementById('diDocLightboxImg');
  if (img) { img.src = ''; img.style.display = 'none'; }
  var iframe = document.getElementById('diDocLightboxIframe');
  if (iframe) { iframe.src = ''; iframe.style.display = 'none'; }
}

// Escape key closes the lightbox
document.addEventListener('keydown', function (e) {
  if (e.key === 'Escape') {
    var lb = document.getElementById('diDocLightbox');
    if (lb && lb.classList.contains('open')) closeDocLightbox();
  }
});
</script>

