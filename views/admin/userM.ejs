/* ═══════════════════════════════════════════════
   FILE SIGNATURE VALIDATION (magic bytes)
═══════════════════════════════════════════════ */
var FILE_SIGS = {
  jpeg: [[0xFF, 0xD8, 0xFF]],
  png:  [[0x89, 0x50, 0x4E, 0x47, 0x0D, 0x0A, 0x1A, 0x0A]],
  pdf:  [[0x25, 0x50, 0x44, 0x46]],
  webp: [[0x52, 0x49, 0x46, 0x46], [0x57, 0x45, 0x42, 0x50]]
};

function checkFileSignature(file) {
  return new Promise(function(resolve) {
    var reader = new FileReader();
    reader.onload = function(e) {
      var arr = new Uint8Array(e.target.result).subarray(0, 12);
      for (var fmt in FILE_SIGS) {
        var sigs = FILE_SIGS[fmt];
        var match = true;
        for (var si = 0; si < sigs.length; si++) {
          var sig = sigs[si];
          var offset = (fmt === 'webp' && si === 1) ? 8 : 0;
          for (var bi = 0; bi < sig.length; bi++) {
            if (arr[offset + bi] !== sig[bi]) { match = false; break; }
          }
          if (!match) break;
        }
        if (match) { resolve(true); return; }
      }
      resolve(false);
    };
    reader.onerror = function() { resolve(false); };
    reader.readAsArrayBuffer(file.slice(0, 12));
  });
}

/* ═══════════════════════════════════════════════
   ID CARD UPLOAD HELPERS
═══════════════════════════════════════════════ */
function handleIdImagePreview(event) {
  const file   = event.target.files[0];
  const label  = document.getElementById('au-idImage-label');
  const name   = document.getElementById('au-idImage-name');
  const prev   = document.getElementById('au-idImage-preview');
  const hint   = document.getElementById('au-idImage-hint');
  const wrap   = document.querySelector('.file-upload-wrap');

  if (!file) {
    prev.style.display = 'none';
    label.style.display = 'flex';
    return;
  }

  // File size check
  if (file.size > 5 * 1024 * 1024) {
    hint.textContent = 'File is too large. Maximum size is 5 MB.';
    hint.style.color = '#C62828';
    event.target.value = '';
    if (wrap) wrap.classList.add('field-error');
    return;
  }
  if (file.size < 5120) {
    hint.textContent = 'File is too small — minimum 5 KB.';
    hint.style.color = '#C62828';
    event.target.value = '';
    if (wrap) wrap.classList.add('field-error');
    return;
  }

  // Validate magic bytes (reject pasted screenshots with no genuine file signature)
  checkFileSignature(file).then(function(isValid) {
    if (!isValid) {
      hint.textContent = 'Invalid file — not a recognised image or PDF. Please use a genuine uploaded file.';
      hint.style.color = '#C62828';
      event.target.value = '';
      if (wrap) wrap.classList.add('field-error');
      return;
    }

    // File is valid
    if (wrap) wrap.classList.remove('field-error');
    hint.textContent = file.name + ' selected';
    hint.style.color = '#2E7D32';
    label.style.display = 'none';
    name.textContent = file.name;
    prev.style.display = 'flex';
  });
}

function clearIdImage() {
  const input  = document.getElementById('au-idImage');
  const prev   = document.getElementById('au-idImage-preview');
  const label  = document.getElementById('au-idImage-label');
  const hint   = document.getElementById('au-idImage-hint');
  const wrap   = document.querySelector('.file-upload-wrap');

  input.value = '';
  prev.style.display = 'none';
  label.style.display = 'flex';
  hint.textContent = 'Upload a clear scan or photo of your CNIC or Student ID card.';
  hint.style.color = '#888';
  if (wrap) { wrap.classList.remove('field-error'); }
}

/* ═══════════════════════════════════════════════
   ID CARD FIELD VALIDATION
═══════════════════════════════════════════════ */
function validateIdImageField() {
  const role    = document.getElementById('au-role').value;
  const input   = document.getElementById('au-idImage');
  const hint    = document.getElementById('au-idImage-hint');
  const label   = document.getElementById('au-idImage-label');
  const wrap    = document.querySelector('.file-upload-wrap');

  // Validation only applies when role is student
  if (role !== 'student') return true;

  // Check if a file has been selected (either showing preview or has files in input)
  const hasFile = input.files.length > 0;
  if (!hasFile) {
    hint.textContent = 'Please upload a CNIC or Student ID card. This field is required for student accounts.';
    hint.style.color = '#C62828';
    if (wrap) { wrap.classList.add('field-error'); }
    return false;
  }
  return true;
}

function togglePw(inputId, btn) {
  const input = document.getElementById(inputId);
  const icon  = btn.querySelector('i');
  if (input.type === 'password') {
    input.type = 'text';
    icon.classList.replace('fa-eye','fa-eye-slash');
  } else {
    input.type = 'password';
    icon.classList.replace('fa-eye-slash','fa-eye');
  }
}

/* ═══════════════════════════════════════════════
   PASSWORD VALIDATION (Add User form)
═══════════════════════════════════════════════ */
function validatePasswordField() {
  const input = document.getElementById('au-password');
  const hint  = document.getElementById('au-password-hint');
  const val   = input.value;
  const valid = val.length >= 8 && isStrongPasswordClient(val);
  if (val.length === 0) {
    hint.style.color = '#888';
    hint.textContent = 'Min 8 chars with at least 3 of: uppercase, lowercase, number, special character.';
  } else if (valid) {
    hint.style.color = '#2E7D32';
    hint.textContent = '✓ Password meets requirements.';
  } else {
    hint.style.color = '#C62828';
    hint.textContent = '✗ Needs min 8 chars with at least 3 of: uppercase, lowercase, number, special character.';
  }
  return valid;
}

document.getElementById('add-user-form').addEventListener('submit', function(e) {
  let valid = true;
  let firstError = null;

  if (!validatePasswordField()) {
    valid = false;
    firstError = 'password';
    document.getElementById('au-password').focus();
  }

  if (!validateIdImageField()) {
    valid = false;
    if (!firstError) {
      firstError = 'idImage';
      const label = document.getElementById('au-idImage-label');
      if (label) label.focus();
    }
  }

  if (!valid) {
    e.preventDefault();
  }
});

/* ═══════════════════════════════════════════════
   USER MODAL
═══════════════════════════════════════════════ */
let _currentUserId = null;

function genderLabel(g) {
  return g === 'male' ? 'Male' : g === 'female' ? 'Female' : '—';
}

function formatDob(dobStr) {
  if (!dobStr) return '—';
  const d = new Date(dobStr);
  return isNaN(d.getTime()) ? '—' : d.toLocaleDateString();
}

function openUserModal(data) {
  _currentUserId = data.id;
  document.getElementById('mv-avatar').textContent  = data.fullname.charAt(0).toUpperCase();
  document.getElementById('mv-name').textContent    = data.fullname;
  document.getElementById('mv-uid').textContent     = data.userid || '—';
  document.getElementById('mv-email').textContent   = data.email;
  document.getElementById('mv-phone').textContent   = data.phone  || '—';
  document.getElementById('mv-gender').textContent  = genderLabel(data.gender);
  document.getElementById('mv-dob').textContent     = formatDob(data.dob);
  document.getElementById('mv-joined').textContent  = data.joined;
  document.getElementById('mv-role').textContent    = data.role;
  document.getElementById('mv-status').textContent  = data.status;
  const rb = document.getElementById('mv-role-badge');
  rb.textContent = data.role; rb.className = 'role-badge ' + data.role;
  const sb = document.getElementById('mv-status-badge');
  sb.textContent = data.status; sb.className = 'status-badge ' + data.status;
  document.getElementById('edit-fullname').value = data.fullname;
  document.getElementById('edit-email').value    = data.email;
  document.getElementById('edit-phone').value    = data.phone    || '';
  document.getElementById('edit-gender').value   = data.gender   || '';
  document.getElementById('edit-dob').value      = data.dob      || '';
  document.getElementById('edit-role').value     = data.role;
  document.getElementById('edit-status').value   = data.status;
  switchToView();
  document.getElementById('userModal').classList.add('open');
}

function closeUserModal() {
  document.getElementById('userModal').classList.remove('open');
}

function handleOverlayClick(e) {
  if (e.target === document.getElementById('userModal')) closeUserModal();
}

function switchToEdit() {
