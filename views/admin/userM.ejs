/* ═══════════════════════════════════════════════
   STUDENT INFO MODAL
═══════════════════════════════════════════════ */
let _siUserId   = null;
let _siUserName = null;
let _siUserUid  = null;

async function openStudentInfoModal(userId, userName, userUid) {
  _siUserId   = userId;
  _siUserName = userName;
  _siUserUid  = userUid || '—';

  document.getElementById('si-loading').style.display = 'flex';
  document.getElementById('si-content').style.display = 'none';
  siSwitchToView();
  document.getElementById('studentInfoModal').classList.add('open');

  try {
    const res  = await fetch(`/admin/students/${userId}/info`);
    const data = await res.json();

    document.getElementById('si-avatar').textContent    = userName.charAt(0).toUpperCase();
    document.getElementById('si-user-name').textContent = userName;
    document.getElementById('si-user-id').textContent   = userUid || '—';

    const si = data.studentInfo;
    setValue('sv-department',       si?.department       || '—');
    setValue('sv-institution',      si?.institution      || '—');
    setValue('sv-admissionDate',    si?.admissionDate    ? new Date(si.admissionDate).toLocaleDateString() : '—');
    setValue('sv-cnic',             si?.cnic             || '—');
    setValue('sv-bloodGroup',       si?.bloodGroup       || '—');
    setValue('sv-homeAddress',      si?.homeAddress      || '—');
    setValue('sv-emergencyContact', si?.emergencyContact || '—');
    setValue('sv-guardianName',     si?.guardianName     || '—');
    setValue('sv-guardianEmail',    si?.guardianEmail    || '—');
    setValue('sv-guardianContact',  si?.guardianContact  || '—');
    setValue('sv-guardianRelation', si?.guardianRelation || '—');

    /* Room / Hostel — show real assigned details, not just a boolean */
    const room = si?.room;
    if (room && typeof room === 'object') {
      const roomLabel = room.roomNumber
        ? `Room ${room.roomNumber}${room.block ? ' (' + room.block + ')' : ''}`
        : 'Assigned';
      setValue('sv-room', roomLabel);
      setValue('sv-hostel', room.hostelName || '—');
    } else {
      setValue('sv-room', 'Not assigned');
      setValue('sv-hostel', '—');
    }
    setValue('sv-hostelStatus', si?.hostelStatus || '—');

    setInput('se-department',       si?.department       || '');
    setInput('se-institution',      si?.institution      || '');
    setInput('se-cnic',             si?.cnic             || '');
    setInput('se-bloodGroup',       si?.bloodGroup       || '');
    setInput('se-homeAddress',      si?.homeAddress      || '');
    setInput('se-emergencyContact', si?.emergencyContact || '');
    setInput('se-guardianName',     si?.guardianName     || '');
    setInput('se-guardianEmail',    si?.guardianEmail    || '');
    setInput('se-guardianContact',  si?.guardianContact  || '');
    setInput('se-guardianRelation', si?.guardianRelation || '');
    setInput('se-admissionDate',
      si?.admissionDate ? new Date(si.admissionDate).toISOString().split('T')[0] : ''
    );

    const wrap  = document.getElementById('si-id-doc-wrap');
    const idSrc = data.idImage ? '/' + data.idImage : null;

    if (idSrc) {
      const isPdf = idSrc.toLowerCase().endsWith('.pdf');
      if (isPdf) {
        wrap.innerHTML = `
          <div class="si-id-pdf">
            <i class="fas fa-file-pdf"></i>
            <span>PDF document uploaded</span>
            <button class="act-btn btn-view-id" onclick="openImageLightbox('${idSrc}', '${userName.replace(/'/g,"\\'")}')">
              <i class="fas fa-external-link-alt"></i> View PDF
            </button>
          </div>`;
      } else {
        wrap.innerHTML = `
          <div class="si-id-img-wrap">
            <img src="${idSrc}" alt="ID Document" class="si-id-thumbnail"
                 onclick="openImageLightbox('${idSrc}', '${userName.replace(/'/g,"\\'")}' )"
                 title="Click to enlarge">
            <div class="si-id-hint"><i class="fas fa-search-plus"></i> Click image to enlarge</div>
          </div>`;
      }
    } else {
      wrap.innerHTML = `
        <div class="si-id-missing">
          <i class="fas fa-exclamation-circle"></i>
          <span>No ID document uploaded by this student.</span>
        </div>`;
    }

    document.getElementById('si-loading').style.display = 'none';
    document.getElementById('si-content').style.display = 'block';

  } catch (err) {
    console.error('Failed to load student info:', err);
    document.getElementById('si-loading').innerHTML =
      '<i class="fas fa-exclamation-circle" style="color:#C62828"></i> Failed to load. Please try again.';
  }
}

