document.addEventListener('click', function (e) {
  const viewBtn = e.target.closest('[data-action="view"]');
  if (viewBtn) {
    openUserModal({
      id       : viewBtn.dataset.id,
      fullname : viewBtn.dataset.fullname,
      email    : viewBtn.dataset.email,
      role     : viewBtn.dataset.role,
      status   : viewBtn.dataset.status,
      userid   : viewBtn.dataset.userid,
      phone    : viewBtn.dataset.phone,
      gender   : viewBtn.dataset.gender,
      dob      : viewBtn.dataset.dob,
      joined   : viewBtn.dataset.joined
    });
    return;
  }
  const siBtn = e.target.closest('[data-action="student-info"]');
  if (siBtn) {
    const row        = siBtn.closest('tr');
    const uidCode    = row ? row.querySelector('.uid-code') : null;
    const readableId = uidCode ? uidCode.textContent.trim() : '';
    openStudentInfoModal(siBtn.dataset.userid, siBtn.dataset.fullname, readableId);
    return;
  }
  const delBtn = e.target.closest('[data-action="delete"]');
  if (delBtn) {
    openDeleteModal(delBtn.dataset.id, delBtn.dataset.name);
    return;
  }
});

/* ═══════════════════════════════════════════════
   DRIVER INFO MODAL
═══════════════════════════════════════════════ */
function handleDIOverlayClick(e) {
  if (e.target === document.getElementById('driverInfoModal')) closeDriverInfoModal();
}

function closeDriverInfoModal() {
  document.getElementById('driverInfoModal').classList.remove('open');
  diSwitchToView();
}

async function openDriverInfoModal(userId, userName, userUid) {
  diSwitchToView();
  // Store the MongoDB _id on the modal for later use in diSubmit()
  document.getElementById('driverInfoModal').dataset.currentId = userId;
  document.getElementById('driverInfoModal').classList.add('open');
  document.getElementById('di-loading').style.display = 'flex';
  document.getElementById('di-content').style.display  = 'none';
  document.getElementById('di-user-name').textContent   = userName;
  document.getElementById('di-user-id').textContent     = userUid;
  document.getElementById('di-avatar').textContent      = userName.charAt(0).toUpperCase();

  try {
    console.log('[DriverInfo] Fetching:', `/admin/drivers/${userId}/info`);
    const res  = await fetch(`/admin/drivers/${userId}/info`);
    console.log('[DriverInfo] Response status:', res.status, res.statusText);
    const contentType = res.headers.get('content-type');
    if (!contentType || !contentType.includes('application/json')) {
      const text = await res.text();
      console.log('[DriverInfo] Non-JSON response:', text.substring(0, 500));
      alert('Server returned: ' + (contentType || 'no content-type') + ' — ' + text.substring(0, 200));
      closeDriverInfoModal();
      return;
    }
    const data = await res.json();
    console.log('[DriverInfo] Data:', data);
    if (!res.ok || data.error) {
      alert(data.error || 'Failed to load driver information.');
      closeDriverInfoModal();
      return;
    }
    const dInfo = data.driverInfo || {};
    // View fields
    document.getElementById('dv-cnic').textContent               = dInfo.cnic || '—';
    document.getElementById('dv-verified').textContent           = dInfo.isVerified ? 'Yes' : 'No';
    document.getElementById('dv-licenseNumber').textContent      = dInfo.licenseNumber || '—';
    document.getElementById('dv-licenseExpiry').textContent      = dInfo.licenseExpiry ? new Date(dInfo.licenseExpiry).toLocaleDateString() : '—';
    document.getElementById('dv-vehicleType').textContent        = dInfo.vehicleType ? dInfo.vehicleType.charAt(0).toUpperCase() + dInfo.vehicleType.slice(1) : '—';
    document.getElementById('dv-vehicleRegistration').textContent = dInfo.vehicleRegistration || '—';
    document.getElementById('dv-vehicleModel').textContent       = dInfo.vehicleModel || '—';
    document.getElementById('dv-serviceArea').textContent        = dInfo.serviceArea || '—';
    document.getElementById('dv-experienceYears').textContent    = dInfo.experienceYears ? dInfo.experienceYears + ' yrs' : '—';

    // ── Documents ──
    const docFields = [
      { id: 'cnicFront',    label: 'CNIC Front',  path: dInfo.cnicFrontImage },
      { id: 'cnicBack',     label: 'CNIC Back',   path: dInfo.cnicBackImage },
      { id: 'licenseImage', label: 'License',     path: dInfo.licenseImage },
      { id: 'vehicleDocImage', label: 'Vehicle Reg', path: dInfo.vehicleDocImage },
      { id: 'profilePhoto', label: 'Photo',       path: dInfo.profilePhoto },
      { id: 'additionalDoc',label: 'Additional',  path: dInfo.additionalDoc }
    ];
    docFields.forEach(function(df) {
      var placeholder = document.querySelector('#dv-documents .di-doc-placeholder[data-doc-id="' + df.id + '"]');
      if (!placeholder) return;
      if (df.path) {
        var isPdf = df.path.toLowerCase().endsWith('.pdf');
        placeholder.innerHTML = '<div class="di-doc-thumb" onclick="openDocLightbox(\'' + df.path + '\')">'
          + (isPdf
              ? '<div class="di-doc-pdf-icon"><i class="fas fa-file-pdf"></i></div>'
              : '<img src="/' + df.path + '" alt="' + df.label + '">')
          + '<div class="di-doc-label-overlay">' + df.label + '</div>'
          + '</div>';
      } else {
        placeholder.innerHTML = '<div class="di-doc-empty"><i class="ti ti-circle-minus"></i><span>' + df.label + '</span></div>';
      }
    });

    // Edit fields
    document.getElementById('de-cnic').value                = dInfo.cnic || '';
    document.getElementById('de-licenseNumber').value       = dInfo.licenseNumber || '';
    document.getElementById('de-licenseExpiry').value        = dInfo.licenseExpiry ? new Date(dInfo.licenseExpiry).toISOString().split('T')[0] : '';
    document.getElementById('de-vehicleType').value          = dInfo.vehicleType || '';
    document.getElementById('de-vehicleRegistration').value = dInfo.vehicleRegistration || '';
    document.getElementById('de-vehicleModel').value         = dInfo.vehicleModel || '';
    document.getElementById('de-serviceArea').value          = dInfo.serviceArea || '';
    document.getElementById('de-experienceYears').value      = dInfo.experienceYears || '';

    document.getElementById('di-loading').style.display = 'none';
    document.getElementById('di-content').style.display  = 'block';
  } catch (err) {
    console.error('[DriverInfo] Error:', err);
    alert('Failed to load driver information. Check console (F12) for details.');
    closeDriverInfoModal();
  }
}

function diSwitchToEdit() {
  document.getElementById('di-view-section').style.display = 'none';
  document.getElementById('di-edit-section').style.display  = 'block';
  document.getElementById('di-btn-edit').style.display      = 'none';
  document.getElementById('di-btn-save').style.display      = 'flex';
  document.getElementById('di-btn-cancel').style.display    = 'flex';
