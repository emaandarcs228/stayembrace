<script>
window.PAGE_TITLES = {
  'overview'  : 'Overview',
  'all-users' : 'All Users',
  'students'  : 'Students',
  'admins'    : 'Admins',
  'wardens'   : 'Wardens',
  'pending'   : 'Pending Approvals',
  'add-user'  : 'Add User'
};

function showPage(id, el) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.page-tabs .act-btn').forEach(n => n.classList.remove('active'));
  const pg = document.getElementById('page-' + id);
  if (pg) pg.classList.add('active');
  if (el) el.classList.add('active');
  if (id === 'all-users') {
    document.getElementById('filter-role').value   = 'all';
    document.getElementById('filter-status').value = 'all';
    applyFilters();
    renderAllUsersPagination();
  }
}

window.addEventListener('DOMContentLoaded', () => {
  const params = new URLSearchParams(window.location.search);
  const page   = params.get('page');
  const validPages = ['overview','all-users','students','admins','wardens','pending','add-user'];
  if (page && validPages.includes(page)) {
    const navMap = {
      'pending': document.getElementById('nav-pending'),
      'add-user': document.getElementById('nav-add-user')
    };
    showPage(page, navMap[page] || null);
  } else {
    renderAllUsersPagination();
  }
});

/* ═══════════════════════════════════════════════
   FILTERS
═══════════════════════════════════════════════ */
function applyFilters() {
  const role   = document.getElementById('filter-role').value;
  const status = document.getElementById('filter-status').value;
  document.querySelectorAll('#all-body tr').forEach(row => {
    const roleMatch   = role   === 'all' || row.dataset.role   === role;
    const statusMatch = status === 'all' || row.dataset.status === status;
    row.dataset.filterHidden = (roleMatch && statusMatch) ? '0' : '1';
  });
  ALL_USERS_PAGE = 1;
  renderAllUsersPagination();
}

/* ═══════════════════════════════════════════════
   PAGINATION
═══════════════════════════════════════════════ */
const ROWS_PER_PAGE = 13;
let ALL_USERS_PAGE  = 1;

function getVisibleAllUsersRows() {
  return Array.from(document.querySelectorAll('#all-body tr')).filter(row =>
    row.dataset.filterHidden !== '1' && row.dataset.searchHidden !== '1'
  );
}

function renderAllUsersPagination() {
  const allRows     = Array.from(document.querySelectorAll('#all-body tr'));
  const visibleRows = getVisibleAllUsersRows();
  const total       = visibleRows.length;
  const totalPages  = Math.max(1, Math.ceil(total / ROWS_PER_PAGE));
  if (ALL_USERS_PAGE > totalPages) ALL_USERS_PAGE = totalPages;
  if (ALL_USERS_PAGE < 1)          ALL_USERS_PAGE = 1;
  allRows.forEach(row => row.style.display = 'none');
  const start = (ALL_USERS_PAGE - 1) * ROWS_PER_PAGE;
  const end   = start + ROWS_PER_PAGE;
  visibleRows.slice(start, end).forEach(row => row.style.display = '');
  const info = document.getElementById('all-users-page-info');
  if (total === 0) {
    info.textContent = 'Showing 0 of 0 users';
  } else {
    info.textContent = `Showing ${start + 1}–${Math.min(end, total)} of ${total} users`;
  }
  const btnWrap = document.getElementById('all-users-page-btns');
  btnWrap.innerHTML = '';
  const prev = document.createElement('button');
  prev.className = 'pg-btn'; prev.textContent = '‹'; prev.disabled = ALL_USERS_PAGE === 1;
  prev.onclick = () => { ALL_USERS_PAGE--; renderAllUsersPagination(); };
  btnWrap.appendChild(prev);
  for (let i = 1; i <= totalPages; i++) {
    const b = document.createElement('button');
    b.className = 'pg-btn' + (i === ALL_USERS_PAGE ? ' active' : '');
    b.textContent = i;
    b.onclick = () => { ALL_USERS_PAGE = i; renderAllUsersPagination(); };
    btnWrap.appendChild(b);
  }
  const next = document.createElement('button');
  next.className = 'pg-btn'; next.textContent = '›'; next.disabled = ALL_USERS_PAGE === totalPages;
  next.onclick = () => { ALL_USERS_PAGE++; renderAllUsersPagination(); };
  btnWrap.appendChild(next);
}

/* ═══════════════════════════════════════════════
   GLOBAL SEARCH
═══════════════════════════════════════════════ */
const SEARCH_TABLE_BODIES = ['all-body','students-body','admins-body','wardens-body'];
const SEARCH_PAGE_MAP = {
  'all-body'      : { page: 'all-users' },
  'students-body' : { page: 'students'  },
  'admins-body'   : { page: 'admins'    },
  'wardens-body'  : { page: 'wardens'   }
};

function globalSearchHandler() {
  const q = document.getElementById('globalSearch').value.trim().toLowerCase();
  let firstMatchTable = null;
  SEARCH_TABLE_BODIES.forEach(bodyId => {
    const tbody = document.getElementById(bodyId);
    if (!tbody) return;
    let matchInThisTable = false;
    tbody.querySelectorAll('tr').forEach(row => {
      const matches = q === '' || row.textContent.toLowerCase().includes(q);
      row.dataset.searchHidden = matches ? '0' : '1';
      if (matches && q !== '') matchInThisTable = true;
    });
    if (matchInThisTable && !firstMatchTable) firstMatchTable = bodyId;
  });
  ALL_USERS_PAGE = 1;
  renderAllUsersPagination();
  ['students-body','admins-body','wardens-body'].forEach(bodyId => {
    const tbody = document.getElementById(bodyId);
    if (!tbody) return;
    tbody.querySelectorAll('tr').forEach(row => {
      row.style.display = row.dataset.searchHidden === '1' ? 'none' : '';
    });
  });
  if (q !== '' && firstMatchTable) {
    const activePage = document.querySelector('.page.active');
    const activeId   = activePage ? activePage.id : '';
    const targetId   = 'page-' + SEARCH_PAGE_MAP[firstMatchTable].page;
    if (activeId !== targetId) showPage(SEARCH_PAGE_MAP[firstMatchTable].page, null);
  }
}

/* ═══════════════════════════════════════════════
   ADD USER HELPERS
═══════════════════════════════════════════════ */
async function updateUserIdPreview() {
  const role    = document.getElementById('au-role').value;
  const preview = document.getElementById('uid-preview');
  const val     = document.getElementById('uid-preview-val');
  if (!role) { preview.style.display = 'none'; return; }
  preview.style.display = 'flex';
  val.textContent = 'Loading…';
  try {
    const res  = await fetch(`/admin/users/preview-id?role=${encodeURIComponent(role)}`);
    if (!res.ok) throw new Error('Request failed');
    const data = await res.json();
    val.textContent = data.preview || '—';
  } catch (err) {
    val.textContent = '—';
  }
}

function clearAddForm() {
  document.getElementById('add-user-form').reset();
  document.getElementById('uid-preview').style.display = 'none';
  const hint = document.getElementById('au-password-hint');
  hint.style.color = '#888';
  hint.textContent = 'Must include uppercase, lowercase, number and special character.';
}

function togglePw(inputId, btn) {
  const input = document.getElementById(inputId);
  const icon  = btn.querySelector('i');
  if (input.type === 'password') {
    input.type = 'text';
    icon.classList.replace('fa-eye','fa-eye-slash');
  } else {
    input.type = 'password';
    icon.classList.replace('fa-eye-slash','fa-eye');
  }
}

/* ═══════════════════════════════════════════════
   PASSWORD VALIDATION (Add User form)
═══════════════════════════════════════════════ */
function validatePasswordField() {
  const input = document.getElementById('au-password');
  const hint  = document.getElementById('au-password-hint');
  const valid = input.checkValidity();
  if (input.value.length === 0) {
    hint.style.color = '#888';
    hint.textContent = 'Must include uppercase, lowercase, number and special character.';
  } else if (valid) {
    hint.style.color = '#2E7D32';
    hint.textContent = '✓ Password meets requirements.';
  } else {
    hint.style.color = '#C62828';
    hint.textContent = '✗ Needs uppercase, lowercase, number, and special character (min 8 chars).';
  }
  return valid;
}

document.getElementById('add-user-form').addEventListener('submit', function(e) {
  if (!validatePasswordField()) {
    e.preventDefault();
    document.getElementById('au-password').focus();
  }
});

/* ═══════════════════════════════════════════════
   USER MODAL
═══════════════════════════════════════════════ */
let _currentUserId = null;

function genderLabel(g) {
  return g === 'male' ? 'Male' : g === 'female' ? 'Female' : '—';
}

function formatDob(dobStr) {
  if (!dobStr) return '—';
  const d = new Date(dobStr);
  return isNaN(d.getTime()) ? '—' : d.toLocaleDateString();
}

function openUserModal(data) {
  _currentUserId = data.id;
  document.getElementById('mv-avatar').textContent  = data.fullname.charAt(0).toUpperCase();
  document.getElementById('mv-name').textContent    = data.fullname;
  document.getElementById('mv-uid').textContent     = data.userid || '—';
  document.getElementById('mv-email').textContent   = data.email;
  document.getElementById('mv-phone').textContent   = data.phone  || '—';
  document.getElementById('mv-gender').textContent  = genderLabel(data.gender);
  document.getElementById('mv-dob').textContent     = formatDob(data.dob);
  document.getElementById('mv-joined').textContent  = data.joined;
  document.getElementById('mv-role').textContent    = data.role;
  document.getElementById('mv-status').textContent  = data.status;
  const rb = document.getElementById('mv-role-badge');
  rb.textContent = data.role; rb.className = 'role-badge ' + data.role;
  const sb = document.getElementById('mv-status-badge');
  sb.textContent = data.status; sb.className = 'status-badge ' + data.status;
  document.getElementById('edit-fullname').value = data.fullname;
  document.getElementById('edit-email').value    = data.email;
  document.getElementById('edit-phone').value    = data.phone    || '';
  document.getElementById('edit-gender').value   = data.gender   || '';
  document.getElementById('edit-dob').value      = data.dob      || '';
  document.getElementById('edit-role').value     = data.role;
  document.getElementById('edit-status').value   = data.status;
  switchToView();
  document.getElementById('userModal').classList.add('open');
}

function closeUserModal() {
  document.getElementById('userModal').classList.remove('open');
}

function handleOverlayClick(e) {
  if (e.target === document.getElementById('userModal')) closeUserModal();
}

function switchToEdit() {
  document.getElementById('modal-title').innerHTML             = '<i class="fas fa-pen"></i> Edit User';
  document.getElementById('modal-view-section').style.display = 'none';
  document.getElementById('modal-edit-section').style.display = 'block';
  document.getElementById('btn-switch-edit').style.display    = 'none';
  document.getElementById('btn-save-edit').style.display      = 'flex';
  document.getElementById('btn-cancel-edit').style.display    = 'flex';
}

function switchToView() {
  document.getElementById('modal-title').innerHTML             = '<i class="fas fa-user"></i> User Details';
  document.getElementById('modal-view-section').style.display = 'block';
  document.getElementById('modal-edit-section').style.display = 'none';
  document.getElementById('btn-switch-edit').style.display    = 'flex';
  document.getElementById('btn-save-edit').style.display      = 'none';
  document.getElementById('btn-cancel-edit').style.display    = 'none';
}

function submitEdit() {
  if (!_currentUserId) return;
  const form = document.getElementById('modal-edit-section');
  form.action = '/admin/users/edit/' + _currentUserId;
  form.submit();
}

/* ═══════════════════════════════════════════════
   IMAGE LIGHTBOX
═══════════════════════════════════════════════ */
function openImageLightbox(src, studentName) {
  const isPdf = src.toLowerCase().endsWith('.pdf');
  const img   = document.getElementById('lightbox-img');
  const pdf   = document.getElementById('lightbox-pdf-msg');
  const title = document.getElementById('lightbox-title');
  const dl    = document.getElementById('lightbox-download');

  title.textContent = `ID Document — ${studentName}`;
  dl.href = src;

  if (isPdf) {
    img.style.display = 'none';
    pdf.style.display = 'flex';
    document.getElementById('lightbox-pdf-link').href = src;
  } else {
    pdf.style.display = 'none';
    img.style.display = 'block';
    img.src = src;
  }
  document.getElementById('imageLightbox').classList.add('open');
}

function closeImageLightbox() {
  document.getElementById('imageLightbox').classList.remove('open');
  document.getElementById('lightbox-img').src = '';
}

/* ═══════════════════════════════════════════════
   STUDENT INFO MODAL
═══════════════════════════════════════════════ */
let _siUserId   = null;
let _siUserName = null;
let _siUserUid  = null;

async function openStudentInfoModal(userId, userName, userUid) {
  _siUserId   = userId;
  _siUserName = userName;
  _siUserUid  = userUid || '—';

  document.getElementById('si-loading').style.display = 'flex';
  document.getElementById('si-content').style.display = 'none';
  siSwitchToView();
  document.getElementById('studentInfoModal').classList.add('open');

  try {
    const res  = await fetch(`/admin/students/${userId}/info`);
    const data = await res.json();

    document.getElementById('si-avatar').textContent    = userName.charAt(0).toUpperCase();
    document.getElementById('si-user-name').textContent = userName;
    document.getElementById('si-user-id').textContent   = userUid || '—';

    const si = data.studentInfo;
    setValue('sv-department',       si?.department       || '—');
    setValue('sv-institution',      si?.institution      || '—');
    setValue('sv-admissionDate',    si?.admissionDate    ? new Date(si.admissionDate).toLocaleDateString() : '—');
    setValue('sv-cnic',             si?.cnic             || '—');
    setValue('sv-bloodGroup',       si?.bloodGroup       || '—');
    setValue('sv-homeAddress',      si?.homeAddress      || '—');
    setValue('sv-emergencyContact', si?.emergencyContact || '—');
    setValue('sv-guardianName',     si?.guardianName     || '—');
    setValue('sv-guardianContact',  si?.guardianContact  || '—');
    setValue('sv-guardianRelation', si?.guardianRelation || '—');

    /* Room / Hostel — show real assigned details, not just a boolean */
    const room = si?.room;
    if (room && typeof room === 'object') {
      const roomLabel = room.roomNumber
        ? `Room ${room.roomNumber}${room.block ? ' (' + room.block + ')' : ''}`
        : 'Assigned';
      setValue('sv-room', roomLabel);
      setValue('sv-hostel', room.hostelName || '—');
    } else {
      setValue('sv-room', 'Not assigned');
      setValue('sv-hostel', '—');
    }
    setValue('sv-hostelStatus', si?.hostelStatus || '—');

    setInput('se-department',       si?.department       || '');
    setInput('se-institution',      si?.institution      || '');
    setInput('se-cnic',             si?.cnic             || '');
    setInput('se-bloodGroup',       si?.bloodGroup       || '');
    setInput('se-homeAddress',      si?.homeAddress      || '');
    setInput('se-emergencyContact', si?.emergencyContact || '');
    setInput('se-guardianName',     si?.guardianName     || '');
    setInput('se-guardianContact',  si?.guardianContact  || '');
    setInput('se-guardianRelation', si?.guardianRelation || '');
    setInput('se-admissionDate',
      si?.admissionDate ? new Date(si.admissionDate).toISOString().split('T')[0] : ''
    );

    const wrap  = document.getElementById('si-id-doc-wrap');
    const idSrc = data.idImage ? '/' + data.idImage : null;

    if (idSrc) {
      const isPdf = idSrc.toLowerCase().endsWith('.pdf');
      if (isPdf) {
        wrap.innerHTML = `
          <div class="si-id-pdf">
            <i class="fas fa-file-pdf"></i>
            <span>PDF document uploaded</span>
            <button class="act-btn btn-view-id" onclick="openImageLightbox('${idSrc}', '${userName.replace(/'/g,"\\'")}')">
              <i class="fas fa-external-link-alt"></i> View PDF
            </button>
          </div>`;
      } else {
        wrap.innerHTML = `
          <div class="si-id-img-wrap">
            <img src="${idSrc}" alt="ID Document" class="si-id-thumbnail"
                 onclick="openImageLightbox('${idSrc}', '${userName.replace(/'/g,"\\'")}' )"
                 title="Click to enlarge">
            <div class="si-id-hint"><i class="fas fa-search-plus"></i> Click image to enlarge</div>
          </div>`;
      }
    } else {
      wrap.innerHTML = `
        <div class="si-id-missing">
          <i class="fas fa-exclamation-circle"></i>
          <span>No ID document uploaded by this student.</span>
        </div>`;
    }

    document.getElementById('si-loading').style.display = 'none';
    document.getElementById('si-content').style.display = 'block';

  } catch (err) {
    console.error('Failed to load student info:', err);
    document.getElementById('si-loading').innerHTML =
      '<i class="fas fa-exclamation-circle" style="color:#C62828"></i> Failed to load. Please try again.';
  }
}

function setValue(id, val) {
  const el = document.getElementById(id);
  if (el) el.textContent = val;
}

function setInput(id, val) {
  const el = document.getElementById(id);
  if (el) el.value = val;
}

function closeStudentInfoModal() {
  document.getElementById('studentInfoModal').classList.remove('open');
}

function handleSIOverlayClick(e) {
  if (e.target === document.getElementById('studentInfoModal')) closeStudentInfoModal();
}

function siSwitchToEdit() {
  document.getElementById('si-view-section').style.display = 'none';
  document.getElementById('si-edit-section').style.display = 'block';
  document.getElementById('si-btn-edit').style.display     = 'none';
  document.getElementById('si-btn-save').style.display     = 'flex';
  document.getElementById('si-btn-cancel').style.display   = 'flex';
  document.getElementById('si-modal-title').innerHTML =
    '<i class="fas fa-id-card"></i> Edit Student Information';
}

function siSwitchToView() {
  document.getElementById('si-view-section').style.display = 'block';
  document.getElementById('si-edit-section').style.display = 'none';
  document.getElementById('si-btn-edit').style.display     = 'flex';
  document.getElementById('si-btn-save').style.display     = 'none';
  document.getElementById('si-btn-cancel').style.display   = 'none';
  document.getElementById('si-modal-title').innerHTML =
    '<i class="fas fa-id-card"></i> Student Information';
}

function siSubmit() {
  if (!_siUserId) return;
  const form = document.getElementById('si-edit-section');
  form.action = '/admin/students/' + _siUserId + '/info';
  form.submit();
}

/* ═══════════════════════════════════════════════
   DELETE MODAL
═══════════════════════════════════════════════ */
function openDeleteModal(id, name) {
  document.getElementById('del-msg').textContent = 'You are about to delete "' + name + '". This cannot be undone.';
  document.getElementById('delete-form').action  = '/admin/users/delete/' + id;
  document.getElementById('deleteModal').classList.add('open');
}

function closeDeleteModal() {
  document.getElementById('deleteModal').classList.remove('open');
}

function handleDelOverlayClick(e) {
  if (e.target === document.getElementById('deleteModal')) closeDeleteModal();
}

function triggerDeleteFromModal() {
  const name = document.getElementById('mv-name').textContent;
  closeUserModal();
  openDeleteModal(_currentUserId, name);
}

/* ═══════════════════════════════════════════════
   EVENT DELEGATION
═══════════════════════════════════════════════ */
document.addEventListener('click', function (e) {
  const viewBtn = e.target.closest('[data-action="view"]');
  if (viewBtn) {
    openUserModal({
      id       : viewBtn.dataset.id,
      fullname : viewBtn.dataset.fullname,
      email    : viewBtn.dataset.email,
      role     : viewBtn.dataset.role,
      status   : viewBtn.dataset.status,
      userid   : viewBtn.dataset.userid,
      phone    : viewBtn.dataset.phone,
      gender   : viewBtn.dataset.gender,
      dob      : viewBtn.dataset.dob,
      joined   : viewBtn.dataset.joined
    });
    return;
  }
  const siBtn = e.target.closest('[data-action="student-info"]');
  if (siBtn) {
    const row        = siBtn.closest('tr');
    const uidCode    = row ? row.querySelector('.uid-code') : null;
    const readableId = uidCode ? uidCode.textContent.trim() : '';
    openStudentInfoModal(siBtn.dataset.userid, siBtn.dataset.fullname, readableId);
    return;
  }
  const delBtn = e.target.closest('[data-action="delete"]');
  if (delBtn) {
    openDeleteModal(delBtn.dataset.id, delBtn.dataset.name);
    return;
  }
});
</script>

