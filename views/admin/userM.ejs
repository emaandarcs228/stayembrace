<script>
window.PAGE_TITLES = {
  'overview'  : 'Overview',
  'all-users' : 'All Users',
  'students'  : 'Students',
  'admins'    : 'Admins',
  'wardens'   : 'Wardens',
  'drivers'   : 'Drivers',
  'pending'   : 'Pending Approvals',
  'add-user'  : 'Add User'
};

function showPage(id, el) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.page-tabs .act-btn').forEach(n => n.classList.remove('active'));
  const pg = document.getElementById('page-' + id);
  if (pg) pg.classList.add('active');
  if (el) el.classList.add('active');
  if (id === 'all-users') {
    document.getElementById('filter-role').value   = 'all';
    document.getElementById('filter-status').value = 'all';
    applyFilters();
    renderAllUsersPagination();
  }
}

window.addEventListener('DOMContentLoaded', () => {
  const params = new URLSearchParams(window.location.search);
  const page   = params.get('page');
  const validPages = ['overview','all-users','students','admins','wardens','drivers','pending','add-user'];
  if (page && validPages.includes(page)) {
    const navMap = {
      'pending': document.getElementById('nav-pending'),
      'add-user': document.getElementById('nav-add-user')
    };
    showPage(page, navMap[page] || null);
  } else {
    renderAllUsersPagination();
  }
  // Show ID Card section for default "student" role
  updateUserIdPreview();
});

/* ═══════════════════════════════════════════════
   FILTERS
═══════════════════════════════════════════════ */
function applyFilters() {
  const role   = document.getElementById('filter-role').value;
  const status = document.getElementById('filter-status').value;
  document.querySelectorAll('#all-body tr').forEach(row => {
    const roleMatch   = role   === 'all' || row.dataset.role   === role;
    const statusMatch = status === 'all' || row.dataset.status === status;
    row.dataset.filterHidden = (roleMatch && statusMatch) ? '0' : '1';
  });
  ALL_USERS_PAGE = 1;
  renderAllUsersPagination();
}

/* ═══════════════════════════════════════════════
   PAGINATION
═══════════════════════════════════════════════ */
const ROWS_PER_PAGE = 13;
let ALL_USERS_PAGE  = 1;

function getVisibleAllUsersRows() {
  return Array.from(document.querySelectorAll('#all-body tr')).filter(row =>
    row.dataset.filterHidden !== '1' && row.dataset.searchHidden !== '1'
  );
}

function renderAllUsersPagination() {
  const allRows     = Array.from(document.querySelectorAll('#all-body tr'));
  const visibleRows = getVisibleAllUsersRows();
  const total       = visibleRows.length;
  const totalPages  = Math.max(1, Math.ceil(total / ROWS_PER_PAGE));
  if (ALL_USERS_PAGE > totalPages) ALL_USERS_PAGE = totalPages;
  if (ALL_USERS_PAGE < 1)          ALL_USERS_PAGE = 1;
  allRows.forEach(row => row.style.display = 'none');
  const start = (ALL_USERS_PAGE - 1) * ROWS_PER_PAGE;
  const end   = start + ROWS_PER_PAGE;
  visibleRows.slice(start, end).forEach(row => row.style.display = '');
  const info = document.getElementById('all-users-page-info');
  if (total === 0) {
    info.textContent = 'Showing 0 of 0 users';
  } else {
    info.textContent = `Showing ${start + 1}–${Math.min(end, total)} of ${total} users`;
  }
  const btnWrap = document.getElementById('all-users-page-btns');
  btnWrap.innerHTML = '';
  const prev = document.createElement('button');
  prev.className = 'pg-btn'; prev.textContent = '‹'; prev.disabled = ALL_USERS_PAGE === 1;
  prev.onclick = () => { ALL_USERS_PAGE--; renderAllUsersPagination(); };
  btnWrap.appendChild(prev);
  for (let i = 1; i <= totalPages; i++) {
    const b = document.createElement('button');
    b.className = 'pg-btn' + (i === ALL_USERS_PAGE ? ' active' : '');
    b.textContent = i;
    b.onclick = () => { ALL_USERS_PAGE = i; renderAllUsersPagination(); };
    btnWrap.appendChild(b);
  }
  const next = document.createElement('button');
  next.className = 'pg-btn'; next.textContent = '›'; next.disabled = ALL_USERS_PAGE === totalPages;
  next.onclick = () => { ALL_USERS_PAGE++; renderAllUsersPagination(); };
  btnWrap.appendChild(next);
}

/* ═══════════════════════════════════════════════
   GLOBAL SEARCH
═══════════════════════════════════════════════ */
const SEARCH_TABLE_BODIES = ['all-body','students-body','admins-body','wardens-body','drivers-body'];
const SEARCH_PAGE_MAP = {
  'all-body'      : { page: 'all-users' },
  'students-body' : { page: 'students'  },
  'admins-body'   : { page: 'admins'    },
  'wardens-body'  : { page: 'wardens'   },
  'drivers-body'  : { page: 'drivers'   }
};

function globalSearchHandler() {
  const q = document.getElementById('globalSearch').value.trim().toLowerCase();
  let firstMatchTable = null;
  SEARCH_TABLE_BODIES.forEach(bodyId => {
    const tbody = document.getElementById(bodyId);
    if (!tbody) return;
    let matchInThisTable = false;
    tbody.querySelectorAll('tr').forEach(row => {
      const matches = q === '' || row.textContent.toLowerCase().includes(q);
      row.dataset.searchHidden = matches ? '0' : '1';
      if (matches && q !== '') matchInThisTable = true;
    });
    if (matchInThisTable && !firstMatchTable) firstMatchTable = bodyId;
  });
  ALL_USERS_PAGE = 1;
  renderAllUsersPagination();
  ['students-body','admins-body','wardens-body','drivers-body'].forEach(bodyId => {
    const tbody = document.getElementById(bodyId);
    if (!tbody) return;
    tbody.querySelectorAll('tr').forEach(row => {
      row.style.display = row.dataset.searchHidden === '1' ? 'none' : '';
    });
  });
  if (q !== '' && firstMatchTable) {
    const activePage = document.querySelector('.page.active');
    const activeId   = activePage ? activePage.id : '';
    const targetId   = 'page-' + SEARCH_PAGE_MAP[firstMatchTable].page;
    if (activeId !== targetId) showPage(SEARCH_PAGE_MAP[firstMatchTable].page, null);
  }
}

