<!-- ══════════════════════════════════════
     REJECT PAYMENT MODAL
══════════════════════════════════════ -->
<div class="modal-overlay" id="rejectModal" onclick="if(event.target===this) closeRejectModal()">
  <div class="modal-box modal-box-sm">
    <div class="modal-head">
      <h3><i class="ti ti-x"></i> Reject Payment</h3>
