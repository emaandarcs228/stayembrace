<!-- ══════════════════════════════════════
     DELETE DUE CONFIRM MODAL
══════════════════════════════════════ -->
<div class="modal-overlay" id="deleteDueModal" onclick="if(event.target===this) closeDeleteDueModal()">
  <div class="del-modal-box">
    <div class="del-icon"><i class="fas fa-exclamation-triangle"></i></div>
    <h3>Delete Due?</h3>
    <p id="dd-msg">This action cannot be undone.</p>
    <div class="del-btns">
      <button class="btn-cancel-del" onclick="closeDeleteDueModal()">Cancel</button>
      <form id="delete-due-form" method="POST" style="display:inline">
        <button type="submit" class="btn-confirm-del">Yes, Delete</button>
      </form>
    </div>
  </div>
</div>

<script>
/* window.showPage / window.openModal / window.closeModal are defined
   globally in admin-footer.ejs — reused here rather than redefined. */

window.PAGE_TITLES = {
  'overview' : 'Fee & Payment Management',
  'payments' : 'Payments',
  'pending'  : 'Pending Verification',
  'dues'     : 'Dues',
  'fines'    : 'Fines'
};

window.addEventListener('DOMContentLoaded', () => {
  const params = new URLSearchParams(window.location.search);
  const page   = params.get('page');
  const validPages = ['overview', 'payments', 'pending', 'dues', 'fines'];
  if (page && validPages.includes(page)) {
    const navMap = { 'pending': document.getElementById('nav-pending') };
    showPage(page, navMap[page] || null);
  }
});

/* ═══════════════════════════════════════════════
   GLOBAL SEARCH (Payments tab)
═══════════════════════════════════════════════ */
function globalSearchHandler() {
  const term = document.getElementById('globalSearch').value.trim().toLowerCase();
  document.querySelectorAll('.searchable-row').forEach(row => {
    const hay = (row.dataset.search || '').toLowerCase();
    row.style.display = !term || hay.includes(term) ? '' : 'none';
  });
}

/* ═══════════════════════════════════════════════
   ADD PAYMENT MODAL
═══════════════════════════════════════════════ */
function openAddPaymentModal() {
  document.getElementById('add-payment-form').reset();
  document.getElementById('ap-due-wrap').style.display = 'none';
  openModal('addPaymentModal');
}
function closeAddPaymentModal() { closeModal('addPaymentModal'); }

async function loadOutstandingDues() {
  const studentId = document.getElementById('ap-student').value;
  const type      = document.getElementById('ap-type').value;
  const wrap      = document.getElementById('ap-due-wrap');
  const select    = document.getElementById('ap-due-select');

  if (!studentId) { wrap.style.display = 'none'; return; }

  try {
    const res  = await fetch('/admin/fees/student/' + studentId + '/dues');
    const data = await res.json();
    const dues = (data.dues || []).filter(d => d.dueType === type);

    select.innerHTML = '<option value="">— None —</option>';
    if (dues.length === 0) { wrap.style.display = 'none'; return; }

    dues.forEach(d => {
      const opt = document.createElement('option');
      opt.value = d._id;
      const dateStr = new Date(d.dueDate).toLocaleDateString();
      opt.textContent = 'Rs ' + Number(d.amount).toLocaleString() + ' — due ' + dateStr + ' (' + d.status + ')';
      select.appendChild(opt);
    });
    wrap.style.display = '';
  } catch (err) {
    console.error('loadOutstandingDues failed:', err);
    wrap.style.display = 'none';
  }
}

/* ═══════════════════════════════════════════════
   GENERATE DUE MODAL
═══════════════════════════════════════════════ */
function openGenerateDueModal() { openModal('generateDueModal'); }
function closeGenerateDueModal() { closeModal('generateDueModal'); }

/* ═══════════════════════════════════════════════
   APPLY FINE MODAL
═══════════════════════════════════════════════ */
function openApplyFineModal() { openModal('applyFineModal'); }
function closeApplyFineModal() { closeModal('applyFineModal'); }

/* ═══════════════════════════════════════════════
   MARK PAID MODAL (shared: Due / Fine)
═══════════════════════════════════════════════ */
function openMarkPaidModal(type, id, studentName, amount) {
  const form = document.getElementById('mark-paid-form');
  form.action = type === 'due'
    ? '/admin/fees/dues/mark-paid/' + id
    : '/admin/fees/fines/mark-paid/' + id;

  document.getElementById('mp-student').textContent = studentName;
  document.getElementById('mp-amount').textContent = 'Rs ' + Number(amount).toLocaleString() + ' ' + (type === 'due' ? 'due' : 'fine');
  document.getElementById('mp-remarks-wrap').style.display = type === 'due' ? '' : 'none';

  openModal('markPaidModal');
}
function closeMarkPaidModal() { closeModal('markPaidModal'); }

/* ═══════════════════════════════════════════════
   REJECT PAYMENT MODAL
═══════════════════════════════════════════════ */
function openRejectModal(id, studentName) {
  document.getElementById('reject-form').action = '/admin/fees/payments/reject/' + id;
  document.getElementById('rj-student').textContent = studentName;
  openModal('rejectModal');
}
function closeRejectModal() { closeModal('rejectModal'); }

/* ═══════════════════════════════════════════════
   DELETE DUE MODAL
═══════════════════════════════════════════════ */
function openDeleteDueModal(id, studentName) {
  document.getElementById('delete-due-form').action = '/admin/fees/dues/delete/' + id;
  document.getElementById('dd-msg').textContent = 'This will permanently delete this due for ' + studentName + '. This action cannot be undone.';
  openModal('deleteDueModal');
}
function closeDeleteDueModal() { closeModal('deleteDueModal'); }
</script>

