              <% students.forEach(s => { %>
                <option value="<%= s._id %>"><%= s.user.fullname %> (<%= s.user.userId %>)</option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Due Type <span class="req">*</span></label>
            <select name="dueType" required>
              <option value="Hostel Fee">Hostel Fee</option>
              <option value="Mess Order">Mess Order</option>
              <option value="Laundry">Laundry</option>
              <option value="Mobile Load">Mobile Load</option>
