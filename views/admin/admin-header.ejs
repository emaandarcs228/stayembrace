<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' – STAY EMBRACE' : 'STAY EMBRACE Admin Portal' %></title>
  <link rel="icon" href="/images/logo-brow.png">
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">
  <link rel="stylesheet" href="/css/admin.css">
  <% if (typeof extraCss !== 'undefined') { %>
    <link rel="stylesheet" href="/css/<%= extraCss %>">
  <% } %>
</head>
<body>
<div class="dash">

  <!-- ══════════════════════════════════════
       SIDEBAR
  ══════════════════════════════════════ -->
  <aside class="sidebar">

    <a href="/admin/dashboard" class="s-logo">
  <img src="/images/logo-sidebar.png" alt="Stay Embrace Logo" class="s-logo-img">
  <span class="s-logo-text"><span class="s-logo-accent">S</span>TAY EMBRACE</span>
</a>

    <div class="s-user">
      <div class="s-avatar"><%= user.fullname.charAt(0).toUpperCase() %></div>
      <div class="s-user-info">
        <h4><%= user.fullname %></h4>
        <span><%= user.userId %></span>
      </div>
    </div>

    <nav class="s-nav" tabindex="0">

      <a href="/admin/dashboard"
         class="nav-item <%= activePage === 'dashboard' ? 'active' : '' %>">
        <i class="ti ti-layout-dashboard"></i>
        <span>Dashboard</span>
      </a>

      <!-- ── Core Management ── -->
      <div class="s-section">Management</div>

      <a href="/admin/users"
         class="nav-item <%= activePage === 'users' ? 'active' : '' %>">
        <i class="ti ti-users"></i>
        <span>User Management</span>
        <% if (typeof pendingApprovalsCount !== 'undefined' && pendingApprovalsCount > 0) { %>
          <span class="nav-badge"><%= pendingApprovalsCount %></span>
        <% } %>
      </a>

      <a href="/admin/pending-drivers"
         class="nav-item <%= activePage === 'pending-drivers' ? 'active' : '' %>">
        <i class="fas fa-taxi"></i>
        <span>Driver Approvals</span>
        <% if (typeof totalPending !== 'undefined' && totalPending > 0) { %>
          <span class="nav-badge"><%= totalPending %></span>
        <% } %>
      </a>

      <a href="/admin/rooms"
   class="nav-item <%= activePage === 'rooms' ? 'active' : '' %>">
  <i class="ti ti-bed"></i>
  <span>Room Management</span>
  <% if (typeof unassignedStudentsCount !== 'undefined' && unassignedStudentsCount > 0) { %>
    <span class="nav-badge"><%= unassignedStudentsCount %></span>
  <% } %>
</a>

      <a href="/admin/fees"
         class="nav-item <%= activePage === 'fees' ? 'active' : '' %>">
        <i class="ti ti-cash"></i>
        <span>Fee &amp; Payment</span>
        <% if (typeof pendingPaymentsCount !== 'undefined' && pendingPaymentsCount > 0) { %>
          <span class="nav-badge"><%= pendingPaymentsCount %></span>
        <% } %>
      </a>

      <!-- ── Operations (Warden Oversight) ── -->
      <div class="s-section">Operations Oversight</div>

      <a href="/admin/operations/attendance"
         class="nav-item <%= activePage === 'ops-attendance' ? 'active' : '' %>">
        <i class="ti ti-calendar-check"></i>
        <span>Attendance Overview</span>
        <% if (typeof opsPendingDisputes !== 'undefined' && opsPendingDisputes > 0) { %>
          <span class="nav-badge"><%= opsPendingDisputes %></span>
        <% } %>
      </a>

      <a href="/admin/operations/leave"
         class="nav-item <%= activePage === 'ops-leave' ? 'active' : '' %>">
        <i class="ti ti-calendar-off"></i>
        <span>Leave Management</span>
        <% if (typeof opsEscalatedLeaves !== 'undefined' && opsEscalatedLeaves > 0) { %>
          <span class="nav-badge"><%= opsEscalatedLeaves %></span>
        <% } %>
      </a>

      <a href="/admin/operations/complaints"
         class="nav-item <%= activePage === 'ops-complaints' ? 'active' : '' %>">
        <i class="ti ti-message-report"></i>
        <span>Complaints Oversight</span>
        <% if (typeof opsStaleComplaints !== 'undefined' && opsStaleComplaints > 0) { %>
          <span class="nav-badge"><%= opsStaleComplaints %></span>
        <% } %>
      </a>

      <a href="/admin/operations/room-requests"
         class="nav-item <%= activePage === 'ops-room-requests' ? 'active' : '' %>">
        <i class="ti ti-door"></i>
        <span>Room Requests</span>
        <% if (typeof opsPendingRoomRequests !== 'undefined' && opsPendingRoomRequests > 0) { %>
          <span class="nav-badge"><%= opsPendingRoomRequests %></span>
        <% } %>
      </a>
      
      <a href="/admin/operations/guest-bookings"
        class="nav-item <%= activePage === 'ops-guest-bookings' ? 'active' : '' %>">
        <i class="ti ti-home-2"></i>
        <span>Visitors &amp; Guest Room Bookings</span>
        <% if (typeof opsPendingGuestBookings !== 'undefined' && opsPendingGuestBookings > 0) { %>
        <span class="nav-badge"><%= opsPendingGuestBookings %></span>
        <% } %>
      </a>
      
      <a href="/admin/operations/mess"
        class="nav-item <%= activePage === 'ops-mess' ? 'active' : '' %>">
        <i class="ti ti-tools-kitchen-2"></i>
        <span>Mess Orders &amp; Menu</span>
      </a>

      <a href="/admin/operations/laundry"
        class="nav-item <%= activePage === 'ops-laundry' ? 'active' : '' %>">
        <i class="ti ti-wash"></i>
        <span>Laundry Oversight</span>
      </a>
      
      <a href="/admin/operations/mobile-load"
        class="nav-item <%= activePage === 'ops-mobile-load' ? 'active' : '' %>">
        <i class="ti ti-device-mobile"></i>
        <span>Mobile Load Oversight</span>
        <% if (typeof opsPendingMobileLoad !== 'undefined' && opsPendingMobileLoad > 0) { %>
        <span class="nav-badge"><%= opsPendingMobileLoad %></span>
        <% } %>
      </a>
      
      <a href="/admin/operations/cab-bookings"
        class="nav-item <%= activePage === 'ops-cab-bookings' ? 'active' : '' %>">
        <i class="ti ti-car"></i>
        <span>Transport Management</span>
      </a>
      
      <a href="/admin/operations/activity"
        class="nav-item <%= activePage === 'ops-activity' ? 'active' : '' %>">
        <i class="ti ti-history"></i>
        <span>Warden Activity Log</span>
      </a>

      <!-- ── Communications ── -->
      <div class="s-section">Communications</div>

      <a href="/admin/notifications"
         class="nav-item <%= activePage === 'notifications' ? 'active' : '' %>">
        <i class="ti ti-bell"></i>
        <span>Notifications</span>
        <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %>
          <span class="nav-badge"><%= unreadCount %></span>
        <% } %>
      </a>

    </nav>

    <div class="s-footer">
      <a href="/logout" class="nav-item logout-item">
        <i class="fas fa-sign-out-alt"></i>
        <span>Logout</span>
      </a>
    </div>

  </aside>

  <!-- Sidebar overlay for mobile -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <!-- ══════════════════════════════════════
       MAIN CONTENT
  ══════════════════════════════════════ -->
  <main class="main">

    <div class="topbar">
      <div class="topbar-left">
        <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
          <i class="fas fa-bars"></i>
        </button>
        <%
          /*
            topbarGreeting takes priority over pageTitle so that pages like the
            dashboard (which want "Welcome back, Name" instead of a generic
            page label) aren't overridden by a pageTitle coming from the
            controller's res.render() call.
          */
        %>
        <h2>
          <%= typeof topbarGreeting !== 'undefined'
                ? topbarGreeting
                : (typeof pageTitle !== 'undefined' ? pageTitle : 'Admin Portal') %>
        </h2>
        <% if (typeof pageSubtitle !== 'undefined') { %>
          <p><i class="ti ti-calendar-event" style="font-size:.7rem;"></i> <%= pageSubtitle %></p>
        <% } %>
      </div>

      <div class="topbar-right">

        <!-- ── Notification Bell ── -->
        <div class="notif-wrap">
          <button class="notif-btn" id="notifBtn" aria-label="Notifications">
            <i class="ti ti-bell"></i>
            <span class="notif-badge" id="notifBadge"
                  data-count="<%= typeof unreadCount !== 'undefined' ? unreadCount : 0 %>">
              <%= typeof unreadCount !== 'undefined' && unreadCount > 0 ? (unreadCount > 99 ? '99+' : unreadCount) : '' %>
            </span>
          </button>

          <div class="notif-dropdown" id="notifDropdown">
            <div class="notif-drop-head">
              <h4>Notifications</h4>
              <button class="notif-mark-all" id="markAllRead">Mark all read</button>
            </div>

            <div class="notif-list" id="notifList">
              <% if (typeof recentNotifs !== 'undefined' && recentNotifs.length > 0) { %>
                <% recentNotifs.forEach(function(n) {
                     const iconMap = {
                       'Payments':      { cls: 'payments',      icon: 'fas fa-wallet'             },
                       'Requests':      { cls: 'requests',      icon: 'fas fa-paper-plane'        },
                       'Announcements': { cls: 'announcements', icon: 'fas fa-bullhorn'            },
                       'General':       { cls: 'announcements', icon: 'fas fa-bell'               }
                     };
                     const ic = iconMap[n.category] || { cls: 'announcements', icon: 'fas fa-bell' };
                     const isUnread = !n.readBy || !n.readBy.map(String).includes(String(user._id));
                     const timeAgoStr = n._timeAgo || new Date(n.createdAt).toLocaleDateString();
                %>
                <a href="/admin/notifications" class="notif-item <%= isUnread ? 'unread' : '' %>">
                  <div class="notif-icon <%= ic.cls %>">
                    <i class="<%= ic.icon %>"></i>
                  </div>
                  <div class="notif-body">
                    <div class="notif-title"><%= n.title %></div>
                    <div class="notif-msg"><%= n.message %></div>
                    <div class="notif-time"><%= timeAgoStr %></div>
                  </div>
                  <div class="notif-dot"></div>
                </a>
                <% }); %>
              <% } else { %>
                <div class="notif-empty">
                  <i class="ti ti-bell-off"></i>
                  You're all caught up!
                </div>
              <% } %>
            </div>

            <div class="notif-drop-foot">
              <a href="/admin/notifications" class="notif-view-all">
                View all notifications <i class="fas fa-arrow-right" style="font-size:.6rem"></i>
              </a>
            </div>
          </div>
        </div>

        <!-- ── Profile Dropdown ── -->
        <% if (activePage === 'dashboard') { %>
        <div class="profile-wrap">
          <button class="profile-btn" id="profileBtn">
            <div class="profile-btn-avatar"><%= user.fullname.charAt(0).toUpperCase() %></div>
            <span class="profile-btn-name"><%= user.fullname.split(' ')[0] %></span>
            <i class="fas fa-chevron-down profile-btn-chevron"></i>
          </button>

          <div class="profile-dropdown" id="profileDropdown">
            <div class="pd-header">
              <div class="pd-avatar"><%= user.fullname.charAt(0).toUpperCase() %></div>
              <div class="pd-info">
                <div class="pd-name"><%= user.fullname %></div>
                <div class="pd-role">Administrator</div>
                <div class="pd-uid"><%= user.userId %></div>
              </div>
            </div>
            <div class="pd-menu">
              <a href="/admin/profile" class="pd-item">
                <i class="fas fa-id-card"></i>
                View Profile
              </a>
              <a href="/admin/notifications" class="pd-item">
                <i class="ti ti-bell"></i>
                Notifications
                <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %>
                  <span style="margin-left:auto;background:#e53e3e;color:white;font-size:.55rem;padding:.1rem .38rem;border-radius:10px;font-weight:700;">
                    <%= unreadCount %>
                  </span>
                <% } %>
              </a>
              <div class="pd-divider"></div>
              <a href="/logout" class="pd-item pd-logout">
                <i class="fas fa-sign-out-alt"></i>
                Logout
              </a>
            </div>
          </div>
        </div>
      <% } %>
      </div><!-- /topbar-right -->
    </div><!-- /topbar -->

    <!-- Flash messages -->
    <% if (typeof successMessage !== 'undefined' && successMessage) { %>
    <div class="modal-overlay open" id="flashModal">
      <div class="flash-modal-box flash-success">
        <div class="flash-icon"><i class="fas fa-check-circle"></i></div>
        <h3>Success</h3>
        <p><%= successMessage %></p>
        <button class="flash-ok-btn btn-primary" onclick="document.getElementById('flashModal').remove()">OK</button>
      </div>
    </div>
    <% } %>
    <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
    <div class="modal-overlay open" id="flashModal">
      <div class="flash-modal-box flash-error">
        <div class="flash-icon"><i class="fas fa-exclamation-circle"></i></div>
        <h3>Error</h3>
        <p><%= errorMessage %></p>
        <button class="flash-ok-btn" style="background:#C62828;color:white;" onclick="document.getElementById('flashModal').remove()">OK</button>
      </div>
    </div>
    <% } %>

    <!-- Page body starts here — closed in admin-footer.ejs -->
    <div class="page-body">

      <script>
  const sNav = document.querySelector('.s-nav');
  
  // Mouse wheel anywhere on sidebar scrolls the nav
  document.querySelector('.sidebar').addEventListener('wheel', function(e) {
    e.preventDefault();
    sNav.scrollTop += e.deltaY;
  }, { passive: false });

  // Auto-focus nav when mouse enters sidebar
  document.querySelector('.sidebar').addEventListener('mouseenter', function() {
    sNav.focus({ preventScroll: true });
  });

  // ── Sidebar toggle for mobile ──
  var sidebarToggle = document.getElementById('sidebarToggle');
  var sidebar = document.querySelector('.sidebar');
  var sidebarOverlay = document.getElementById('sidebarOverlay');
  
  function toggleSidebar() {
    sidebar.classList.toggle('open');
    sidebarOverlay.classList.toggle('open');
  }
  
  if (sidebarToggle) {
    sidebarToggle.addEventListener('click', function(e) {
      e.stopPropagation();
      toggleSidebar();
    });
  }
  
  if (sidebarOverlay) {
    sidebarOverlay.addEventListener('click', function() {
      toggleSidebar();
    });
  }
</script>
