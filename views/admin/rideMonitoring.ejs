<%
  const badgeCls = (s) => (typeof statusClass !== 'undefined' && statusClass[s]) || 'badge-neutral';
  const fmtDt = d => d ? new Date(d).toLocaleDateString('en-PK', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) : '—';
  const fmtTime = d => d ? new Date(d).toLocaleTimeString('en-PK', { hour:'2-digit', minute:'2-digit' }) : '—';
  const statusIcon = (s) => ({
    'Ride Confirmed'  : 'ti ti-circle-check',
    'Driver On the Way': 'ti ti-steering-wheel',
    'Driver Arrived'  : 'ti ti-map-pin-check',
    'Student Coming'  : 'ti ti-user-check',
    'Ride Started'    : 'ti ti-car',
    'Ride Completed'  : 'ti ti-circle-check-filled',
    'Pending'         : 'ti ti-clock'
  }[s] || 'ti ti-circle');

  const statusSortOrder = [
    'Ride Started', 'Driver Arrived', 'Student Coming',
    'Ride Confirmed', 'Driver On the Way', 'Pending'
  ];
  const sortedRides = [...(rides || [])].sort((a, b) => {
    const ai = statusSortOrder.indexOf(a.status);
    const bi = statusSortOrder.indexOf(b.status);
    return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
  });
%>
<%- include('admin-header') %>

<!-- ── Styles ── -->
<style>
  .rm-stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: .85rem;
    margin-bottom: 1.2rem;
  }
  .rm-stat-card {
    background: white;
    padding: .9rem 1rem;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: .75rem;
    transition: transform .25s, box-shadow .25s;
  }
  .rm-stat-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .rm-stat-icon {
    width: 38px; height: 38px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .95rem;
    flex-shrink: 0;
  }
  .rm-stat-icon.blue   { background: #E3F2FD; color: #1565C0; }
  .rm-stat-icon.green  { background: #E8F5E9; color: #2E7D32; }
  .rm-stat-icon.orange { background: #FFF3E0; color: #E65100; }
  .rm-stat-icon.purple { background: #F3E5F5; color: #7B1FA2; }
  .rm-stat-icon.teal   { background: #E0F7FA; color: #00838F; }

  .rm-stat-info h4 {
    font-size: .62rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: .4px;
    font-weight: 500;
    margin-bottom: .1rem;
  }
  .rm-stat-info h3 {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1;
  }
  .rm-stat-info p {
    font-size: .6rem;
    color: var(--text-muted);
    margin-top: .12rem;
  }

  /* ── Ride Cards ── */
  .rm-card-grid {
    display: flex;
    flex-direction: column;
    gap: .7rem;
  }
  .rm-ride-card {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: white;
    overflow: hidden;
    transition: box-shadow .25s, transform .2s;
    position: relative;
  }
  .rm-ride-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
  }
  .rm-ride-card-body {
    padding: 1rem 1.2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
    align-items: center;
  }
  .rm-ride-left {
    display: flex;
    align-items: center;
    gap: .9rem;
    flex: 1;
    min-width: 240px;
  }
  .rm-status-indicator {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: .15rem;
    align-self: flex-start;
  }
  .rm-status-indicator.status-pending    { background: #F9A825; box-shadow: 0 0 6px #F9A82566; animation: rm-pulse 2s infinite; }
  .rm-status-indicator.status-confirmed  { background: #42A5F5; box-shadow: 0 0 6px #42A5F566; }
  .rm-status-indicator.status-enroute    { background: #FF9800; box-shadow: 0 0 6px #FF980066; animation: rm-pulse 2s infinite; }
  .rm-status-indicator.status-arrived    { background: #AB47BC; box-shadow: 0 0 6px #AB47BC66; animation: rm-pulse 1.5s infinite; }
  .rm-status-indicator.status-started    { background: #66BB6A; box-shadow: 0 0 6px #66BB6A66; }
  .rm-status-indicator.status-coming     { background: #26C6DA; box-shadow: 0 0 6px #26C6DA66; }

  @keyframes rm-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: .6; transform: scale(1.4); }
  }

  .rm-ride-students {
    min-width: 0;
  }
  .rm-student-name {
    font-size: .85rem;
    font-weight: 600;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: .4rem;
  }
  .rm-student-id {
    font-size: .65rem;
    color: var(--text-muted);
    font-family: monospace;
  }
  .rm-driver-info {
    display: flex;
    align-items: center;
    gap: .5rem;
    font-size: .78rem;
    color: var(--text-primary);
  }
  .rm-driver-avatar {
    width: 26px; height: 26px;
    border-radius: 50%;
    background: #FFF3E0;
    color: #E65100;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .65rem;
    font-weight: 700;
    flex-shrink: 0;
    position: relative;
  }
  .rm-driver-online-dot {
    position: absolute;
    bottom: -1px; right: -1px;
    width: 8px; height: 8px;
    border-radius: 50%;
    border: 2px solid white;
    background: #4CAF50;
  }
  .rm-driver-online-dot.offline { background: #BDBDBD; }
  .rm-route {
    display: flex;
    flex-direction: column;
    gap: .2rem;
    min-width: 160px;
    font-size: .75rem;
    position: relative;
    padding-left: 1rem;
  }
  .rm-route::before {
    content: '';
    position: absolute;
    left: 0; top: .25rem; bottom: .25rem;
    width: 2px;
    background: linear-gradient(to bottom, var(--green), #E65100);
    border-radius: 1px;
  }
  .rm-route-stop {
    display: flex;
    align-items: center;
    gap: .4rem;
  }
  .rm-route-stop i {
    font-size: .6rem;
    color: var(--text-muted);
    width: 10px;
    text-align: center;
  }
  .rm-route-stop .rm-dot-green { color: var(--green); }
  .rm-route-stop .rm-dot-red { color: #E65100; }

  .rm-meta {
    display: flex;
    flex-direction: column;
    gap: .2rem;
    min-width: 100px;
    font-size: .72rem;
    color: var(--text-muted);
  }
  .rm-meta-item {
    display: flex;
    align-items: center;
    gap: .3rem;
  }
  .rm-meta-item i { font-size: .65rem; width: 14px; color: var(--text-muted); }

  .rm-actions {
    display: flex;
    gap: .35rem;
    flex-wrap: wrap;
    margin-left: auto;
  }

  .rm-status-badge {
    display: inline-flex;
    align-items: center;
    gap: .3rem;
    padding: .2rem .65rem;
    border-radius: var(--radius-pill);
    font-size: .68rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .rm-status-badge i { font-size: .65rem; }

  .rm-fare-tag {
    display: inline-flex;
    align-items: center;
    gap: .25rem;
    font-size: .78rem;
    font-weight: 700;
    color: var(--green-dark);
    background: var(--green-light);
    padding: .15rem .55rem;
    border-radius: var(--radius-pill);
  }

  .rm-ride-card-footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: .5rem .8rem;
    padding: .5rem 1.2rem;
    background: #fafafa;
    border-top: 1px solid #f0f0f0;
    font-size: .68rem;
    color: var(--text-muted);
  }
  .rm-footer-item {
    display: flex;
    align-items: center;
    gap: .3rem;
  }
  .rm-footer-item i { font-size: .6rem; }

  /* ── Status pills row ── */
  .rm-status-pills {
    display: flex;
    gap: .35rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .rm-status-pill {
    display: inline-flex;
    align-items: center;
    gap: .25rem;
    padding: .25rem .65rem;
    border-radius: var(--radius-pill);
    font-size: .65rem;
    font-weight: 600;
    white-space: nowrap;
    background: #f5f5f5;
    color: #666;
    border: 1px solid transparent;
    transition: all .15s;
  }
  .rm-status-pill i { font-size: .6rem; }
  .rm-status-pill.active {
    border-color: var(--green);
    background: var(--green-light);
    color: var(--green-dark);
  }
  .rm-status-pill .rm-count {
    font-weight: 400;
    opacity: .7;
    margin-left: .15rem;
  }

  .rm-card-head-actions {
    display: flex;
    align-items: center;
    gap: .6rem;
  }
  .rm-refresh-btn {
    width: 32px; height: 32px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-mid);
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--text-secondary);
    font-size: .82rem;
    transition: all .2s;
  }
  .rm-refresh-btn:hover {
    background: var(--green-light);
    color: var(--green);
    border-color: #b8d9c0;
  }
  .rm-refresh-btn.spinning i {
    animation: rm-spin .6s linear;
  }
  @keyframes rm-spin {
