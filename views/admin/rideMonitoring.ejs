  /* ── Empty state ── */
  .rm-empty {
    text-align: center;
    padding: 3rem 1rem;
  }
  .rm-empty i {
    font-size: 2.5rem;
    opacity: .2;
    display: block;
    margin-bottom: .6rem;
    color: var(--text-primary);
  }
  .rm-empty h4 {
    font-size: .9rem;
    color: var(--text-secondary);
