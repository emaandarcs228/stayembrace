<%- include('admin-header') %>
<%
  const badgeCls = (s) => (typeof statusClass !== 'undefined' && statusClass[s]) || 'badge-neutral';
  const sortIcon = (col) => {
    if (sortBy !== col) return 'ti ti-arrows-sort';
    return sortOrder === 1 ? 'ti ti-sort-ascending' : 'ti ti-sort-descending';
  };
%>

<style>
  .drh-stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: .7rem;
    margin-bottom: 1rem;
  }
  .drh-stat-card {
    background: white;
    padding: .8rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: .65rem;
    transition: box-shadow .2s;
  }
  .drh-stat-card:hover { box-shadow: var(--shadow-sm); }
  .drh-stat-icon {
    width: 34px; height: 34px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .85rem;
    flex-shrink: 0;
  }
  .drh-stat-icon.green   { background: #E8F5E9; color: #2E7D32; }
  .drh-stat-icon.red     { background: #FFEBEE; color: #C62828; }
  .drh-stat-icon.blue    { background: #E3F2FD; color: #1565C0; }
  .drh-stat-icon.orange  { background: #FFF3E0; color: #E65100; }
  .drh-stat-icon.purple  { background: #F3E5F5; color: #7B1FA2; }
  .drh-stat-icon.teal    { background: #E0F7FA; color: #00838F; }

  .drh-stat-info h4 {
    font-size: .58rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: .4px;
    font-weight: 500;
    margin-bottom: .05rem;
  }
  .drh-stat-info h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
  }
  .drh-stat-info p { font-size: .58rem; color: var(--text-muted); margin-top: .05rem; }

  .sort-th {
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
  }
  .sort-th:hover { color: var(--text-primary); }
  .sort-th i {
    font-size: .6rem;
    margin-left: .2rem;
    opacity: .5;
    vertical-align: middle;
  }
  .sort-th.active i { opacity: 1; color: var(--green); }
  .sort-th.active { color: var(--text-primary); }

  .drh-rating { display: inline-flex; gap: .08rem; color: #F9A825; font-size: .6rem; }
  .drh-rating .empty { color: #ddd; }
</style>

<!-- ── Driver Selector ── -->
<div style="display:flex;gap:.8rem;margin-bottom:1rem;flex-wrap:wrap;align-items:center">
  <form method="GET" action="/admin/operations/driver-ride-history" id="driverSelectForm" style="display:flex;gap:.8rem;flex-wrap:wrap;align-items:center;width:100%">
    <div style="display:flex;align-items:center;gap:.5rem;flex:1;min-width:240px">
      <i class="ti ti-steering-wheel" style="color:var(--text-muted);font-size:.9rem"></i>
      <select name="driver" class="filter-sel" style="flex:1;min-width:200px" onchange="this.form.submit()">
        <option value="">— Select a Driver —</option>
        <% (driverList || []).forEach(function(d) { %>
          <option value="<%= d._id %>" <%= selectedDriverId === d._id.toString() ? 'selected' : '' %>>
            <%= d.fullname %> (<%= d.userId %>) <%= d.vehicleType ? '- ' + d.vehicleType : '' %>
          </option>
        <% }); %>
      </select>
    </div>

    <% if (selectedDriverId) { %>
    <div class="search-bar" style="max-width:240px;width:100%;flex:1">
      <i class="ti ti-search"></i>
      <input type="text" name="search" placeholder="Search by student or location..."
        value="<%= search %>" onchange="this.form.submit()"
        style="border:none;background:transparent;flex:1;font-family:inherit;font-size:.8rem;padding:.55rem 0;outline:none">
      <input type="hidden" name="driver" value="<%= selectedDriverId %>">
      <input type="hidden" name="status" value="<%= statusF %>">
      <input type="hidden" name="sortBy" value="<%= sortBy %>">
      <input type="hidden" name="sortOrder" value="<%= sortOrder %>">
      <input type="hidden" name="page" value="1">
    </div>

    <select class="filter-sel" name="status" form="driverSelectForm" onchange="this.form.submit()" style="min-width:120px">
      <option value="all" <%= statusF === 'all' ? 'selected' : '' %>>All Rides</option>
      <option value="completed" <%= statusF === 'completed' ? 'selected' : '' %>>Completed</option>
      <option value="cancelled" <%= statusF === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
    </select>
    <% } %>
  </form>
</div>

<% if (!selectedDriverId) { %>
  <!-- ── No driver selected ── -->
  <div class="card">
    <div class="empty-state" style="padding:3rem 1rem">
      <i class="ti ti-steering-wheel" style="font-size:2.5rem;opacity:.15"></i>
      <h4 style="font-size:.9rem;color:var(--text-secondary);font-weight:500;margin-top:.5rem">Select a Driver</h4>
      <p style="font-size:.75rem;color:var(--text-muted)">Choose a driver from the dropdown above to view their ride history and statistics.</p>
    </div>
  </div>
<% } else { %>

  <!-- ══════════════════════════════════════
       DRIVER STATS CARDS
  ══════════════════════════════════════ -->
  <div class="drh-stats-row">
    <div class="drh-stat-card">
      <div class="drh-stat-icon blue"><i class="ti ti-car"></i></div>
      <div class="drh-stat-info">
        <h4>Total Rides</h4>
        <h3><%= driverStats?.totalRides || 0 %></h3>
        <p>All terminal rides</p>
      </div>
    </div>
    <div class="drh-stat-card">
      <div class="drh-stat-icon green"><i class="ti ti-circle-check"></i></div>
      <div class="drh-stat-info">
        <h4>Completed</h4>
        <h3><%= driverStats?.completedCount || 0 %></h3>
        <p><%= driverStats?.totalFares || 0 %> with fare</p>
      </div>
    </div>
    <div class="drh-stat-card">
      <div class="drh-stat-icon red"><i class="ti ti-alert-triangle"></i></div>
      <div class="drh-stat-info">
        <h4>Cancelled</h4>
        <h3><%= driverStats?.cancelledCount || 0 %></h3>
        <p>
          <% if (driverStats) { %>
            S:<%= driverStats.cancelledByStudent %> D:<%= driverStats.cancelledByDriver %> A:<%= driverStats.cancelledByAdmin %>
          <% } %>
        </p>
      </div>
    </div>
    <div class="drh-stat-card">
      <div class="drh-stat-icon orange"><i class="ti ti-currency-rupee"></i></div>
      <div class="drh-stat-info">
        <h4>Total Earnings</h4>
        <h3 style="color:#E65100">Rs <%= (driverStats?.totalEarnings || 0).toLocaleString() %></h3>
        <p>
          <% if (driverStats) { %>
            <%= driverStats.paidCount %> paid · <%= driverStats.unpaidCount %> unpaid
          <% } %>
        </p>
      </div>
    </div>
    <div class="drh-stat-card">
      <div class="drh-stat-icon purple"><i class="ti ti-star"></i></div>
      <div class="drh-stat-info">
        <h4>Avg Rating</h4>
        <h3><%= driverStats?.avgRating || '—' %></h3>
        <p><%= driverStats?.totalRatings || 0 %> ratings</p>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════
       RIDE HISTORY TABLE
  ══════════════════════════════════════ -->
  <div class="card">
    <div class="card-head">
      <h3><i class="ti ti-clock-history"></i> Ride History — <%= selectedDriverName %></h3>
      <span class="count-pill"><%= total %> trips</span>
    </div>

    <% if (rides.length > 0) { %>
    <div class="tbl-wrap">
      <table>
        <thead>
          <tr>
            <th>Student</th>
            <th>Pickup</th>
            <th>Destination</th>
            <th class="sort-th <%= sortBy === 'pickupDate' ? 'active' : '' %>"
                onclick="sortByField('pickupDate')">
              Date <i class="<%= sortIcon('pickupDate') %>"></i>
            </th>
            <th>Status</th>
            <th class="sort-th <%= sortBy === 'fare' ? 'active' : '' %>"
                onclick="sortByField('fare')">
              Fare <i class="<%= sortIcon('fare') %>"></i>
            </th>
            <th>Payment</th>
            <th>Rating</th>
            <th class="actions-th">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% rides.forEach(function(b) {
            const studentUser = b.student?.user;
            const studentName = studentUser ? studentUser.fullname : 'Unknown';
            const studentId   = studentUser ? studentUser.userId : '—';
            const initial     = studentName.charAt(0).toUpperCase();
            const pickupDate  = new Date(b.pickupDate);
            const dateStr     = pickupDate.toLocaleDateString('en-PK', { day:'2-digit', month:'short', year:'numeric' });
            const timeStr     = b.pickupTime || '—';
            const completedAt = b.completedAt ? new Date(b.completedAt).toLocaleDateString('en-PK', { day:'2-digit', month:'short' }) : '—';
            const cancelledAt = b.cancellation?.at ? new Date(b.cancellation.at).toLocaleDateString('en-PK', { day:'2-digit', month:'short' }) : null;

            let ratingHtml = '<span style="color:var(--text-muted);font-size:.6rem">—</span>';
            if (b.rating) {
              let stars = '';
              for (let i = 1; i <= 5; i++) stars += '<span class="' + (i <= b.rating ? '' : 'empty') + '">★</span>';
              ratingHtml = '<span class="drh-rating">' + stars + '</span>';
            }
          %>
          <tr>
            <td>
              <div class="user-cell">
                <div class="u-av s"><%= initial %></div>
                <div>
                  <div class="u-name"><%= studentName %></div>
                  <div class="u-email"><%= studentId %></div>
                </div>
              </div>
            </td>
            <td style="font-size:.72rem;max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="<%= b.pickupLocation %>"><%= b.pickupLocation %></td>
            <td style="font-size:.72rem;max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="<%= b.dropoffLocation %>"><%= b.dropoffLocation %></td>
            <td style="font-size:.7rem;white-space:nowrap">
              <div><%= dateStr %></div>
              <div style="color:var(--text-muted);font-size:.62rem"><%= timeStr %></div>
            </td>
            <td>
              <span class="badge <%= badgeCls(b.status) %>" style="font-size:.6rem"><%= b.status %></span>
              <% if (b.status === 'Cancelled' && b.cancellation?.reason) { %>
                <div style="font-size:.58rem;color:var(--text-muted);margin-top:.1rem;max-width:100px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="<%= b.cancellation.reason %>">
                  <%= b.cancellation.reason %>
                </div>
              <% } %>
            </td>
            <td style="font-size:.72rem;font-weight:600">
              <%= b.fare ? 'Rs ' + b.fare.toLocaleString() : '—' %>
            </td>
            <td>
              <% if (b.fare) { %>
                <span class="badge <%= b.paymentStatus === 'Paid' ? 'badge-success' : (b.paymentStatus === 'Refund Pending' ? 'badge-danger' : 'badge-warning') %>" style="font-size:.55rem">
                  <%= b.paymentStatus %>
                </span>
              <% } else { %>
                <span style="color:var(--text-muted);font-size:.6rem">—</span>
              <% } %>
            </td>
            <td style="font-size:.75rem"><%- ratingHtml %></td>
            <td class="actions-cell">
              <div class="action-cell">
                <button class="act-btn btn-view" onclick="openBookingModal('<%= b._id %>')"
                  data-id="<%= b._id %>"><i class="ti ti-eye"></i></button>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <!-- ── Pagination ── -->
    <% if (totalPages > 1) { %>
    <div class="pagination">
      <span style="font-size:.7rem;color:var(--text-secondary)">
        Page <%= page %> of <%= totalPages %> (<%= total %> trips)
      </span>
      <div class="page-btns">
        <% if (page > 1) { %>
          <a href="/admin/operations/driver-ride-history?driver=<%= selectedDriverId %>&page=<%= page - 1 %>&status=<%= statusF %>&search=<%= search %>&sortBy=<%= sortBy %>&sortOrder=<%= sortOrder %>" class="pg-btn">‹</a>
        <% } %>
        <% for (let i = 1; i <= totalPages; i++) { %>
          <a href="/admin/operations/driver-ride-history?driver=<%= selectedDriverId %>&page=<%= i %>&status=<%= statusF %>&search=<%= search %>&sortBy=<%= sortBy %>&sortOrder=<%= sortOrder %>" class="pg-btn <%= i === page ? 'active' : '' %>"><%= i %></a>
        <% } %>
        <% if (page < totalPages) { %>
          <a href="/admin/operations/driver-ride-history?driver=<%= selectedDriverId %>&page=<%= page + 1 %>&status=<%= statusF %>&search=<%= search %>&sortBy=<%= sortBy %>&sortOrder=<%= sortOrder %>" class="pg-btn">›</a>
        <% } %>
      </div>
    </div>
    <% } %>

    <% } else { %>
    <div class="empty-state">
      <i class="ti ti-car-off"></i>
      <p>No rides found for this driver.</p>
      <% if (search || statusF !== 'all') { %>
        <a href="/admin/operations/driver-ride-history?driver=<%= selectedDriverId %>" class="act-btn btn-view" style="margin-top:.5rem">Clear filters</a>
      <% } %>
    </div>
    <% } %>
  </div>

<% } %>

<!-- ── Sorting script ── -->
<script>
function sortByField(field) {
  var form = document.getElementById('driverSelectForm');
  if (!form) return;
  var currentSort = '<%= sortBy %>';
  var currentOrder = <%= sortOrder %>;
  var newOrder = (currentSort === field) ? (currentOrder === 1 ? -1 : 1) : -1;
  var sortByInput = form.querySelector('input[name="sortBy"]');
  var sortOrderInput = form.querySelector('input[name="sortOrder"]');
  if (sortByInput) sortByInput.value = field;
  if (sortOrderInput) sortOrderInput.value = newOrder;
  form.submit();
}
</script>

<!-- ══════════════════════════════════════════
     BOOKING DETAIL MODAL (reused pattern)
══════════════════════════════════════════ -->
<div class="modal-overlay" id="bookingModal" onclick="if(event.target===this) closeBookingModal()">
  <div class="modal-box modal-box-wide">
    <div class="modal-head">
      <h3><i class="ti ti-car"></i> Booking Details</h3>
      <button class="modal-close" onclick="closeBookingModal()"><i class="fas fa-times"></i></button>
    </div>
    <div id="bm-loading" style="text-align:center;padding:2rem;color:var(--text-secondary)">
      <i class="fas fa-spinner fa-spin"></i> Loading…
    </div>
    <div id="bm-content" style="display:none">
      <div class="si-user-banner" id="bm-student-banner">
        <div class="si-avatar" id="bm-avatar">S</div>
        <div class="si-user-info">
          <div class="si-user-name" id="bm-student-name">—</div>
          <div class="si-user-meta">
            <code class="uid-code" id="bm-student-id">—</code>
            <span class="role-badge student">student</span>
          </div>
        </div>
      </div>

      <div class="si-section-title"><i class="ti ti-steering-wheel"></i> Driver & Vehicle</div>
      <div class="si-grid">
        <div class="si-field"><label>Driver</label><span id="bm-driver-name">—</span></div>
        <div class="si-field"><label>Phone</label><span id="bm-driver-phone">—</span></div>
        <div class="si-field"><label>Vehicle</label><span id="bm-vehicle-type">—</span></div>
        <div class="si-field"><label>Registration</label><span id="bm-vehicle-reg">—</span></div>
      </div>

      <div class="si-section-title"><i class="ti ti-credit-card"></i> Fare & Payment</div>
      <div class="si-grid">
        <div class="si-field"><label>Fare</label><span id="bm-fare">—</span></div>
        <div class="si-field"><label>Payment Status</label><span id="bm-payment-status">—</span></div>
      </div>

      <div class="si-section-title"><i class="ti ti-map-pin"></i> Trip Details</div>
      <div class="si-grid">
        <div class="si-field"><label>Pickup</label><span id="bm-pickup">—</span></div>
        <div class="si-field"><label>Destination</label><span id="bm-destination">—</span></div>
        <div class="si-field"><label>Date</label><span id="bm-date">—</span></div>
        <div class="si-field"><label>Time</label><span id="bm-time">—</span></div>
        <div class="si-field"><label>Passengers</label><span id="bm-passengers">—</span></div>
        <div class="si-field"><label>Notes</label><span id="bm-notes">—</span></div>
      </div>

      <div class="si-section-title"><i class="ti ti-flag"></i> Status Timeline</div>
      <div class="si-grid">
        <div class="si-field"><label>Status</label><span id="bm-status">—</span></div>
        <div class="si-field"><label>Booked On</label><span id="bm-booked-on">—</span></div>
        <div class="si-field"><label>Confirmed At</label><span id="bm-confirmed-at">—</span></div>
        <div class="si-field"><label>Completed At</label><span id="bm-completed-at">—</span></div>
      </div>

      <div id="bm-cancellation-section" style="display:none">
        <div class="si-section-title" style="color:#C62828"><i class="ti ti-alert-triangle"></i> Cancellation</div>
        <div class="si-grid">
          <div class="si-field"><label>Cancelled By</label><span id="bm-cancelled-by">—</span></div>
          <div class="si-field"><label>Reason</label><span id="bm-cancel-reason">—</span></div>
          <div class="si-field"><label>Cancelled At</label><span id="bm-cancelled-at">—</span></div>
          <div class="si-field"><label>Cancellation Fee</label><span id="bm-cancel-fee-amt">—</span></div>
        </div>
      </div>

      <div id="bm-rating-section" style="display:none">
        <div class="si-section-title"><i class="ti ti-star"></i> Rating & Review</div>
        <div class="si-grid">
          <div class="si-field"><label>Rating</label><span id="bm-rating">—</span></div>
          <div class="si-field si-field-full"><label>Review</label><span id="bm-review">—</span></div>
        </div>
      </div>
    </div>
    <div class="modal-foot">
      <div class="mf-left"></div>
      <button class="btn-modal-close-si" onclick="closeBookingModal()"><i class="fas fa-times"></i> Close</button>
    </div>
  </div>
</div>

<script>
var RIDE_STATUS_BADGE = <%- JSON.stringify(typeof statusClass !== 'undefined' ? statusClass : {}) %>;

const bookingData = <%- JSON.stringify(rides.map(b => ({
  _id: b._id,
  student: b.student ? {
    user: b.student.user ? { fullname: b.student.user.fullname, userId: b.student.user.userId, phoneNumber: b.student.user.phoneNumber } : null
  } : null,
  driverName: b.driverName,
  driverPhone: b.driverPhone,
  vehicleType: b.vehicleType,
  vehicleRegistration: b.vehicleRegistration,
  pickupLocation: b.pickupLocation,
  dropoffLocation: b.dropoffLocation,
  pickupDate: b.pickupDate,
  pickupTime: b.pickupTime,
  passengerCount: b.passengerCount,
  notes: b.notes,
  status: b.status,
  createdAt: b.createdAt,
  confirmedAt: b.confirmedAt,
  driverOnWayAt: b.driverOnWayAt,
  driverArrivedAt: b.driverArrivedAt,
  studentComingAt: b.studentComingAt,
  rideStartedAt: b.rideStartedAt,
  completedAt: b.completedAt,
  cancellation: b.cancellation,
  cancellationFee: b.cancellationFee,
  rating: b.rating,
  review: b.review,
  fare: b.fare,
  paymentStatus: b.paymentStatus
}))) %>;

function openBookingModal(id) {
  var b = bookingData.find(function(x) { return x._id === id; });
  if (!b) return;

  var su = b.student && b.student.user;
  document.getElementById('bm-student-name').textContent = su ? su.fullname : 'Unknown';
  document.getElementById('bm-student-id').textContent  = su ? su.userId : '—';
  document.getElementById('bm-avatar').textContent      = su ? su.fullname.charAt(0).toUpperCase() : '?';

  document.getElementById('bm-driver-name').textContent  = b.driverName || '—';
  document.getElementById('bm-driver-phone').textContent = b.driverPhone || '—';
  document.getElementById('bm-vehicle-type').textContent = b.vehicleType ? b.vehicleType.charAt(0).toUpperCase() + b.vehicleType.slice(1) : '—';
  document.getElementById('bm-vehicle-reg').textContent  = b.vehicleRegistration || '—';

  document.getElementById('bm-fare').textContent = b.fare ? 'Rs ' + Number(b.fare).toLocaleString() : 'Not set yet';
  document.getElementById('bm-payment-status').innerHTML = b.fare
    ? '<span class="badge ' + (b.paymentStatus === 'Paid' ? 'badge-success' : (b.paymentStatus === 'Refund Pending' ? 'badge-danger' : 'badge-warning')) + '">' + b.paymentStatus + '</span>'
    : '—';

  document.getElementById('bm-pickup').textContent = b.pickupLocation || '—';
  document.getElementById('bm-destination').textContent = b.dropoffLocation || '—';
  document.getElementById('bm-passengers').textContent = b.passengerCount || '1';
  document.getElementById('bm-notes').textContent = b.notes || '—';

  var d = b.pickupDate ? new Date(b.pickupDate) : null;
  document.getElementById('bm-date').textContent = d ? d.toLocaleDateString('en-PK', { day:'2-digit', month:'long', year:'numeric' }) : '—';
  document.getElementById('bm-time').textContent = b.pickupTime || '—';

  var sc = RIDE_STATUS_BADGE[b.status] || 'badge-neutral';
  document.getElementById('bm-status').innerHTML = '<span class="badge ' + sc + '"><i class="ti ti-circle"></i> ' + b.status + '</span>';

  var fmt = function(d) { return d ? new Date(d).toLocaleDateString('en-PK', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) : '—'; };
  document.getElementById('bm-booked-on').textContent = fmt(b.createdAt);
  document.getElementById('bm-confirmed-at').textContent = fmt(b.confirmedAt);
  document.getElementById('bm-completed-at').textContent = fmt(b.completedAt);

  // Cancellation
  var cs = document.getElementById('bm-cancellation-section');
  if (b.cancellation && b.cancellation.by) {
    cs.style.display = '';
    document.getElementById('bm-cancelled-by').textContent = b.cancellation.by.charAt(0).toUpperCase() + b.cancellation.by.slice(1);
    document.getElementById('bm-cancel-reason').textContent = b.cancellation.reason || '—';
    document.getElementById('bm-cancelled-at').textContent = b.cancellation.at ? new Date(b.cancellation.at).toLocaleDateString('en-PK', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) : '—';
    document.getElementById('bm-cancel-fee-amt').textContent = b.cancellationFee ? 'Rs ' + Number(b.cancellationFee).toLocaleString() : 'None';
  } else {
    cs.style.display = 'none';
  }

  // Rating
  var rs = document.getElementById('bm-rating-section');
  if (b.rating) {
    rs.style.display = '';
    document.getElementById('bm-rating').textContent = '★'.repeat(b.rating) + '☆'.repeat(5 - b.rating) + ' (' + b.rating + '/5)';
    document.getElementById('bm-review').textContent = b.review || '—';
  } else {
    rs.style.display = 'none';
  }

  document.getElementById('bm-loading').style.display = 'none';
  document.getElementById('bm-content').style.display = '';
  document.getElementById('bookingModal').classList.add('open');
}

function closeBookingModal() {
  document.getElementById('bookingModal').classList.remove('open');
  document.getElementById('bm-content').style.display = 'none';
  document.getElementById('bm-loading').style.display = '';
}
</script>

