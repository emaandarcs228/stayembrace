        <h3><%= opsStats.pendingDisputes || 0 %></h3>
        <p>Needs review</p>
      </div>
    </div>

    <div class="stat-card clickable" onclick="location.href='/admin/operations/leave'">
      <div class="s-icon <%= (opsStats.escalatedLeaves||0) > 0 ? 'orange' : 'green' %>"><i class="ti ti-calendar-off"></i></div>
      <div class="s-info">
        <h4>Escalated Leave</h4>
