    <div class="stat-card clickable" onclick="location.href='/admin/operations/complaints'">
      <div class="s-icon <%= (opsStats.staleComplaints||0) > 0 ? 'red' : 'green' %>"><i class="ti ti-message-report"></i></div>
      <div class="s-info">
        <h4>Stale Complaints</h4>
        <h3><%= opsStats.staleComplaints || 0 %></h3>
        <p>SLA breached</p>
      </div>
    </div>

