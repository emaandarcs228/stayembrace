          <small>Cab &amp; transport providers</small>
        </div>
        <div class="activity-time"><span class="badge" style="background:#F57C00;color:white"><%= stats.drivers || 0 %></span></div>
      </a>
      <a href="/admin/users?page=admins" class="activity-item" style="text-decoration:none;color:inherit">
        <div class="activity-dot purple"></div>
        <div class="activity-body">
          <p>Admins</p>
          <small>Supervisory access</small>
        </div>
        <div class="activity-time"><span class="badge badge-purple"><%= stats.admins %></span></div>
      </a>
    </div>
  </div>

  <!-- Recent Activity -->
  <div class="card">
    <div class="card-head">
      <h3><i class="fas fa-clock-rotate-left"></i> Recent Activity</h3>
    </div>
    <% if (recentActivities && recentActivities.length > 0) { %>
    <div class="activity-list">
      <% recentActivities.forEach(function(a) { %>
      <div class="activity-item">
        <div class="activity-dot green"></div>
        <div class="activity-body">
          <p><%= a.action %></p>
          <small><%= a.user %></small>
        </div>
        <div class="activity-time"><%= a.date %></div>
      </div>
      <% }); %>
    </div>
    <% } else { %>
    <div class="empty-state" style="padding:2rem">
      <i class="fas fa-bell-slash"></i>
      <h4>No recent activity</h4>
    </div>
    <% } %>
  </div>

</div>

<!-- ══════════════════════════════════════
     FINANCE SNAPSHOT
══════════════════════════════════════ -->
<div class="card">
  <div class="card-head">
    <h3><i class="ti ti-cash"></i> Finance Snapshot</h3>
    <a href="/admin/fees" class="add-btn" style="text-decoration:none">
      <i class="ti ti-arrow-right"></i> Fee Management
    </a>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:1px;background:var(--border)">

    <div style="background:white;padding:1rem 1.2rem">
      <div style="font-size:.65rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:.3rem">
        Total Income
      </div>
      <div style="font-size:1.1rem;font-weight:700;color:var(--green)">Rs <%= (stats.collectedFees || 0).toLocaleString() %></div>
      <div style="font-size:.65rem;color:var(--text-muted)">Verified</div>
    </div>

    <div style="background:white;padding:1rem 1.2rem">
      <div style="font-size:.65rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:.3rem">
        Outstanding
      </div>
      <div style="font-size:1.1rem;font-weight:700;color:<%= (stats.outstandingFees||0) > 0 ? '#E65100' : 'var(--green)' %>">Rs <%= (stats.outstandingFees || 0).toLocaleString() %></div>
      <div style="font-size:.65rem;color:var(--text-muted)">Pending + overdue</div>
    </div>

    <div style="background:white;padding:1rem 1.2rem">
      <div style="font-size:.65rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:.3rem">
        Pending Verification
      </div>
      <div style="font-size:1.1rem;font-weight:700;color:var(--text-primary)"><%= stats.pendingPaymentsCount %></div>
      <div style="font-size:.65rem;color:var(--text-muted)">Payments</div>
    </div>

  </div>
</div>

<!-- ══════════════════════════════════════
     COMPLETED RIDE FARES
══════════════════════════════════════ -->
<div class="card">
  <div class="card-head">
    <h3><i class="ti ti-currency-rupee"></i> Transport Revenue — Completed Rides</h3>
    <a href="/admin/operations/completed-rides" class="add-btn" style="text-decoration:none">
      <i class="ti ti-arrow-right"></i> View All
    </a>
  </div>

  <div class="stats-row" style="padding:.8rem 1.2rem;margin-bottom:0;grid-template-columns:repeat(auto-fit,minmax(120px,1fr))">
    <div class="stat-card" style="padding:.6rem .8rem">
      <div class="s-icon green" style="width:32px;height:32px;font-size:.8rem"><i class="ti ti-currency-rupee"></i></div>
      <div class="s-info">
        <h4 style="font-size:.6rem">Total Fare Collected</h4>
        <h3 style="font-size:1rem;color:var(--green)" id="dashTotalFare">Rs <%= (completedFareStats.totalFare || 0).toLocaleString() %></h3>
      </div>
    </div>
    <div class="stat-card" style="padding:.6rem .8rem">
      <div class="s-icon blue" style="width:32px;height:32px;font-size:.8rem"><i class="ti ti-car"></i></div>
      <div class="s-info">
        <h4 style="font-size:.6rem">Completed Rides</h4>
        <h3 style="font-size:1rem" id="dashCompletedCount"><%= completedFareStats.count || 0 %></h3>
      </div>
    </div>
    <div class="stat-card" style="padding:.6rem .8rem">
      <div class="s-icon purple" style="width:32px;height:32px;font-size:.8rem"><i class="ti ti-calendar-stats"></i></div>
      <div class="s-info">
        <h4 style="font-size:.6rem">Avg Fare / Ride</h4>
        <h3 style="font-size:1rem" id="dashAvgFare">Rs <%= Math.round(completedFareStats.avgFare || 0).toLocaleString() %></h3>
      </div>
    </div>
  </div>

  <% if (typeof recentCompletedRides !== 'undefined' && recentCompletedRides.length > 0) { %>
  <div style="padding:0 1.2rem 1rem;max-height:220px;overflow-y:auto;scrollbar-width:thin">
    <table style="width:100%;font-size:.72rem;border-collapse:collapse">
      <thead>
        <tr style="border-bottom:1px solid var(--border-mid);color:var(--text-muted);font-size:.62rem;text-transform:uppercase;letter-spacing:.4px">
          <th style="padding:.35rem .5rem;text-align:left">Student</th>
          <th style="padding:.35rem .5rem;text-align:left">Driver</th>
          <th style="padding:.35rem .5rem;text-align:left">Pickup → Destination</th>
          <th style="padding:.35rem .5rem;text-align:right">Agreed Fare</th>
          <th style="padding:.35rem .5rem;text-align:right">Completed</th>
        </tr>
      </thead>
      <tbody id="dashCompletedList">
        <% recentCompletedRides.forEach(function(b) {
          const studentName = b.student?.user?.fullname || 'Unknown';
          const initial = studentName.charAt(0).toUpperCase();
          const completedDate = b.completedAt ? new Date(b.completedAt).toLocaleDateString('en-PK', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' }) : '—';
        %>
        <tr style="border-bottom:1px solid #f5f5f5">
          <td style="padding:.35rem .5rem">
            <div style="display:flex;align-items:center;gap:.35rem">
              <div class="u-av s" style="width:24px;height:24px;font-size:.55rem;flex-shrink:0"><%= initial %></div>
              <span style="font-weight:500"><%= studentName %></span>
            </div>
          </td>
          <td style="padding:.35rem .5rem"><%= b.driverName || '—' %></td>
          <td style="padding:.35rem .5rem;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="<%= b.pickupLocation %> → <%= b.dropoffLocation %>">
            <%= b.pickupLocation %> → <%= b.dropoffLocation %>
          </td>
          <td style="padding:.35rem .5rem;text-align:right;font-weight:700;color:var(--green-dark);font-size:.78rem">
            <%= b.fare ? 'Rs ' + b.fare.toLocaleString() : '—' %>
          </td>
          <td style="padding:.35rem .5rem;text-align:right;font-size:.65rem;color:var(--text-muted);white-space:nowrap">
            <%= completedDate %>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% } else { %>
  <div style="padding:1rem 1.2rem;text-align:center;color:var(--text-muted)">
    <i class="ti ti-currency-rupee-off" style="font-size:1.2rem;opacity:.3;display:block;margin-bottom:.3rem"></i>
    <p style="font-size:.75rem">No completed rides yet. Fares will appear here once rides are completed.</p>
  </div>
  <% } %>
</div>

<!-- ── Auto-refresh script extension for completed fare widget ── -->
<script>
(function() {
  // Independent polling for the completed fare widget.
  // Can't patch into the existing IIFE above (updateRideWidget is not
  // exposed on window), so we add a separate fetch cycle.
  function updateCompletedFareWidget(data) {
    if (!data || !data.ok || !data.completedFare) return;

    var elTotal = document.getElementById('dashTotalFare');
    var elCount = document.getElementById('dashCompletedCount');
    var elAvg   = document.getElementById('dashAvgFare');
    var elList  = document.getElementById('dashCompletedList');

    if (elTotal) elTotal.textContent = 'Rs ' + Number(data.completedFare.totalFare || 0).toLocaleString();
    if (elCount) elCount.textContent = data.completedFare.count || 0;
    if (elAvg) elAvg.textContent = 'Rs ' + Number(data.completedFare.avgFare || 0).toLocaleString();

    if (!elList) return;

    var completed = data.completedFare.recentCompleted;
    if (completed && completed.length > 0) {
      var html = '';
      completed.forEach(function(b) {
        var initial = (b.studentName || '?').charAt(0).toUpperCase();
        var fare = b.fare ? 'Rs ' + Number(b.fare).toLocaleString() : '—';
        var dateStr = b.completedAt ? new Date(b.completedAt).toLocaleDateString('en-PK', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' }) : '—';
        var route = (b.pickupLocation || '') + ' \u2192 ' + (b.dropoffLocation || '');

        html += '<tr style="border-bottom:1px solid #f5f5f5">' +
          '<td style="padding:.35rem .5rem"><div style="display:flex;align-items:center;gap:.35rem">' +
            '<div class="u-av s" style="width:24px;height:24px;font-size:.55rem;flex-shrink:0">' + initial + '</div>' +
            '<span style="font-weight:500">' + escapeHtml(b.studentName) + '</span></div></td>' +
          '<td style="padding:.35rem .5rem">' + escapeHtml(b.driverName) + '</td>' +
          '<td style="padding:.35rem .5rem;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="' + escapeAttr(route) + '">' + escapeHtml(route) + '</td>' +
          '<td style="padding:.35rem .5rem;text-align:right;font-weight:700;color:var(--green-dark);font-size:.78rem">' + fare + '</td>' +
          '<td style="padding:.35rem .5rem;text-align:right;font-size:.65rem;color:var(--text-muted);white-space:nowrap">' + dateStr + '</td></tr>';
      });
      elList.innerHTML = html;
    } else {
      elList.innerHTML = '';
    }
  }

  function escapeHtml(str) {
    if (!str) return '—';
    var div = document.createElement('div');
    div.appendChild(document.createTextNode(str));
    return div.innerHTML;
  }

  function escapeAttr(str) {
    if (!str) return '';
    return str.replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  // Poll every 15 seconds (same interval as active rides widget)
  function fetchFareStatus() {
    fetch('/admin/dashboard/ride-status.json')
      .then(function(r) { return r.json(); })
      .then(updateCompletedFareWidget)
      .catch(function() {});
  }

  setInterval(fetchFareStatus, 15000);
  setTimeout(fetchFareStatus, 6000);
})();
</script>

<%- include('admin-footer') %>
