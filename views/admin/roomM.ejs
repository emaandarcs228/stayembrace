<%
  const activePage   = 'rooms';
  const pageTitle    = 'Room Management';
  const pageSubtitle = 'Manage rooms, allocations, and transfers';
%>
<%- include('admin-header') %>

<!-- ── Search + Add Room ── -->
<div style="display:flex;justify-content:flex-end;align-items:center;gap:.8rem;margin-bottom:1.2rem;flex-wrap:wrap">
  <div class="search-bar" style="max-width:320px;width:100%">
    <i class="ti ti-search"></i>
    <input type="text" placeholder="Search rooms..." id="globalSearch" oninput="globalSearchHandler()">
  </div>
  <button class="act-btn btn-approve" id="nav-add-room" onclick="showPage('add-room',this)"><i class="ti ti-plus"></i> Add Room</button>
</div>

<!-- ── Sub-nav tabs ── -->
<div class="page-tabs">
  <button class="act-btn active" style="background:#E8EAF6;color:#3949AB" onclick="showPage('overview',this)"><i class="ti ti-layout-dashboard"></i> Overview</button>
  <button class="act-btn" id="nav-student-rooms" style="background:#E3F2FD;color:#1565C0" onclick="showPage('all-rooms',this)"><i class="ti ti-door"></i> Student Rooms</button>
  <button class="act-btn" id="nav-guest-rooms" style="background:#F3E5F5;color:#8E24AA" onclick="showPage('guest-rooms',this)">
    <i class="ti ti-home-2"></i> Guest Rooms
  </button>
  <button class="act-btn" id="nav-unassigned" style="background:#FFEBEE;color:#C62828" onclick="showPage('unassigned',this)">
    <i class="ti ti-user-off"></i> Unassigned Students
    <% if (unallocatedStudents.length > 0) { %>
      <span style="background:#C62828;color:white;font-size:.55rem;padding:.1rem .35rem;border-radius:10px;font-weight:700;margin-left:.2rem"><%= unallocatedStudents.length %></span>
    <% } %>
  </button>
  <button class="act-btn" id="nav-allocations" style="background:#F3E5F5;color:#7B1FA2" onclick="showPage('allocations',this)"><i class="ti ti-transfer"></i> Allocations</button>
</div>

<!-- ══════════════════════════════════════
     OVERVIEW PAGE  (Student rooms only)
══════════════════════════════════════ -->
<div class="page active" id="page-overview">

  <div class="stats-row">
    <div class="stat-card clickable" onclick="showPage('all-rooms',document.getElementById('nav-student-rooms'))">
      <div class="s-icon all"><i class="ti ti-door"></i></div>
      <div class="s-info"><h4>Student Rooms</h4><h3><%= stats.totalRooms %></h3></div>
    </div>
    <div class="stat-card clickable" onclick="goToStudentRoomsFiltered('Available')">
      <div class="s-icon avail"><i class="ti ti-circle-check"></i></div>
      <div class="s-info"><h4>Available</h4><h3><%= stats.availableRooms %></h3></div>
    </div>
    <div class="stat-card clickable" onclick="goToStudentRoomsFiltered('Occupied')">
      <div class="s-icon occ"><i class="ti ti-users"></i></div>
      <div class="s-info"><h4>Occupied</h4><h3><%= stats.occupiedRooms %></h3></div>
    </div>
    <div class="stat-card clickable" onclick="goToStudentRoomsFiltered('Maintenance')">
      <div class="s-icon maint"><i class="ti ti-tool"></i></div>
      <div class="s-info"><h4>Maintenance</h4><h3><%= stats.maintenanceRooms %></h3></div>
    </div>
    <div class="stat-card">
      <div class="s-icon beds"><i class="ti ti-bed"></i></div>
      <div class="s-info"><h4>Total Beds</h4><h3><%= stats.totalBeds %></h3></div>
    </div>
    <div class="stat-card">
      <div class="s-icon free"><i class="ti ti-bed-off"></i></div>
      <div class="s-info"><h4>Free Beds</h4><h3><%= stats.freeBeds %></h3></div>
    </div>
    <div class="stat-card clickable" onclick="showPage('unassigned',document.getElementById('nav-unassigned'))">
      <div class="s-icon pending"><i class="ti ti-user-off"></i></div>
      <div class="s-info"><h4>Unassigned Students</h4><h3><%= unallocatedStudents.length %></h3></div>
    </div>
    <div class="stat-card clickable" onclick="showPage('guest-rooms',document.getElementById('nav-guest-rooms'))">
      <div class="s-icon" style="background:#F3E5F5;color:#8E24AA"><i class="ti ti-home-2"></i></div>
      <div class="s-info"><h4>Guest Rooms</h4><h3><%= guestStats.totalGuestRooms %></h3></div>
    </div>
  </div>

  <!-- Occupancy Bar -->
  <div class="card">
    <div class="card-head">
      <h3><i class="ti ti-chart-bar"></i> Occupancy Overview</h3>
    </div>
    <div class="occ-bar-wrap">
      <% const occPct = stats.totalBeds > 0 ? Math.round((stats.occupiedBeds / stats.totalBeds) * 100) : 0; %>
      <div class="occ-label">
        <span><%= stats.occupiedBeds %> of <%= stats.totalBeds %> beds occupied</span>
        <span class="occ-pct"><%= occPct %>%</span>
      </div>
      <div class="occ-bar-bg">
        <div class="occ-bar-fill" style="--width:<%= occPct %>%"></div>
      </div>
      <div class="occ-legend">
        <span class="leg-dot leg-occ"></span> Occupied (<%= stats.occupiedRooms %>)
        &nbsp;&nbsp;
        <span class="leg-dot leg-avail"></span> Available (<%= stats.availableRooms %>)
        &nbsp;&nbsp;
        <span class="leg-dot leg-maint"></span> Maintenance (<%= stats.maintenanceRooms %>)
      </div>
    </div>
  </div>

  <!-- Recent Allocations -->
  <div class="card">
    <div class="card-head">
      <h3><i class="ti ti-transfer"></i> Recent Allocations</h3>
      <button class="add-btn" onclick="showPage('allocations',document.getElementById('nav-allocations'))">View All</button>
    </div>
    <% if (recentAllocations && recentAllocations.length > 0) { %>
    <div class="tbl-wrap">
      <table>
        <thead><tr><th>Student</th><th>Room</th><th>Bed No</th><th>Date</th><th>Status</th></tr></thead>
        <tbody>
          <% recentAllocations.forEach(function(al) { %>
          <tr>
            <td>
              <div class="user-cell">
                <div class="u-av s"><%= al.student && al.student.user && al.student.user.fullname ? al.student.user.fullname.charAt(0).toUpperCase() : '?' %></div>
                <div>
                  <div class="u-name"><%= al.student && al.student.user ? al.student.user.fullname : '—' %></div>
                  <div class="u-sub"><%= al.student && al.student.user ? al.student.user.userId : '—' %></div>
                </div>
              </div>
            </td>
            <td>
              <strong><%= al.room ? al.room.roomNo : '—' %></strong>
              <div style="font-size:.68rem;color:var(--text-muted)">Block <%= al.room ? al.room.block : '' %>, Floor <%= al.room ? al.room.floor : '' %></div>
            </td>
            <td><%= al.bedNo || '—' %></td>
            <td style="font-size:.72rem;color:var(--text-muted)"><%= new Date(al.allocationDate).toLocaleDateString() %></td>
            <td><span class="alloc-badge alloc-<%= al.status.toLowerCase() %>"><%= al.status %></span></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="empty-state"><i class="fas fa-bed"></i><p>No allocations yet.</p></div>
    <% } %>
  </div>

  <!-- Quick Room Grid -->
  <div class="card">
    <div class="card-head">
      <h3><i class="ti ti-layout-grid"></i> Room Grid</h3>
      <button class="add-btn" onclick="showPage('all-rooms',document.getElementById('nav-student-rooms'))">View All</button>
    </div>
    <div class="room-grid">
      <% rooms.slice(0,12).forEach(function(room) {
           var safeDesc = (room.description || '').replace(/\\/g, '\\\\').replace(/'/g, '&#39;');
      %>
      <div class="room-tile room-tile-<%= room.status.toLowerCase() %>"
           data-id="<%= room._id %>"
           data-roomno="<%= room.roomNo %>"
           data-block="<%= room.block %>"
           data-floor="<%= room.floor %>"
           data-capacity="<%= room.capacity %>"
           data-occupied="<%= room.occupiedBeds %>"
           data-type="<%= room.roomType %>"
           data-category="Student"
           data-fee="<%= room.monthlyFee %>"
           data-nightlyfee="<%= room.feePerNight || 0 %>"
           data-status="<%= room.status %>"
           data-desc="<%= safeDesc %>"
           onclick="openRoomModalFromTile(this)">
        <div class="rt-no"><%= room.roomNo %></div>
        <div class="rt-type"><%= room.roomType %></div>
        <div class="rt-beds">
          <% for(var i=0;i<room.capacity;i++){ %>
            <span class="bed-dot <%= i < room.occupiedBeds ? 'bed-occ' : 'bed-free' %>"></span>
          <% } %>
        </div>
        <div class="rt-status"><%= room.status %></div>
      </div>
      <% }) %>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     STUDENT ROOMS PAGE  (formerly "All Rooms")
     Status filter dropdown below replaces the old standalone
     Available / Occupied / Maintenance tabs.
══════════════════════════════════════ -->
<div class="page" id="page-all-rooms">
  <div class="card">
    <div class="card-head">
      <h3><i class="ti ti-door"></i> Student Rooms</h3>
      <div class="card-actions">
        <select class="filter-sel" id="filter-block" onchange="applyRoomFilters()">
          <option value="all">All Blocks</option>
          <option value="A">Block A</option>
          <option value="B">Block B</option>
          <option value="C">Block C</option>
        </select>
        <select class="filter-sel" id="filter-status" onchange="applyRoomFilters()">
          <option value="all">All Status</option>
          <option value="Available">Available</option>
          <option value="Occupied">Occupied</option>
          <option value="Maintenance">Maintenance</option>
        </select>
        <select class="filter-sel" id="filter-type" onchange="applyRoomFilters()">
          <option value="all">All Types</option>
          <option value="Single">Single</option>
          <option value="Double">Double</option>
          <option value="Triple">Triple</option>
        </select>
      </div>
    </div>
    <div class="tbl-wrap">
      <table id="rooms-table">
        <thead>
          <tr>
            <th>#</th><th>Room No</th><th>Block</th><th>Floor</th><th>Type</th>
            <th>Capacity</th><th>Occupied</th><th>Monthly Fee</th><th>Status</th>
            <th class="actions-th">Actions</th>
          </tr>
        </thead>
        <tbody id="rooms-body">
          <% rooms.forEach(function(room, index) {
               var safeDesc2 = (room.description || '').replace(/\\/g, '\\\\').replace(/'/g, '&#39;');
          %>
          <tr data-block="<%= room.block %>" data-status="<%= room.status %>" data-type="<%= room.roomType %>">
            <td><%= index + 1 %></td>
            <td><strong><%= room.roomNo %></strong></td>
            <td><span class="block-badge block-<%= room.block.toLowerCase() %>">Block <%= room.block %></span></td>
            <td>Floor <%= room.floor %></td>
            <td><span class="type-badge"><%= room.roomType %></span></td>
            <td><%= room.capacity %> beds</td>
            <td>
              <div class="bed-bar">
                <div class="bed-bar-fill" style="--width:<%= room.capacity > 0 ? ((room.occupiedBeds / room.capacity) * 100) : 0 %>%"></div>
              </div>
              <span class="bed-count"><%= room.occupiedBeds %>/<%= room.capacity %></span>
            </td>
            <td>Rs <%= room.monthlyFee.toLocaleString() %></td>
            <td><span class="room-status-badge status-<%= room.status.toLowerCase() %>"><%= room.status %></span></td>
            <td class="actions-cell">
              <div class="action-cell">
                <button class="act-btn btn-view"
                  data-id="<%= room._id %>"
                  data-roomno="<%= room.roomNo %>"
                  data-block="<%= room.block %>"
                  data-floor="<%= room.floor %>"
                  data-capacity="<%= room.capacity %>"
                  data-occupied="<%= room.occupiedBeds %>"
                  data-type="<%= room.roomType %>"
                  data-category="Student"
                  data-fee="<%= room.monthlyFee %>"
                  data-nightlyfee="<%= room.feePerNight || 0 %>"
                  data-status="<%= room.status %>"
                  data-desc="<%= safeDesc2 %>"
                  onclick="openRoomModalFromTile(this)">View</button>
                <button class="act-btn btn-alloc"
                  data-roomid="<%= room._id %>"
                  data-roomno="<%= room.roomNo %>"
                  data-capacity="<%= room.capacity %>"
                  data-occupied="<%= room.occupiedBeds %>"
                  onclick="openAllocModalFromBtn(this)"
                  <%= room.status !== 'Available' || room.occupiedBeds >= room.capacity ? 'disabled title="No free beds"' : '' %>>
                  Allocate
                </button>
                <% if (room.status === 'Occupied') { %>
                <button class="act-btn btn-vacate"
                  data-roomid="<%= room._id %>" data-roomno="<%= room.roomNo %>"
                  onclick="showOccupantsModal(this.dataset.roomid, this.dataset.roomno)">Occupants</button>
                <% } %>
                <button class="act-btn btn-del"
                  data-roomid="<%= room._id %>"
                  data-roomno="<%= room.roomNo %>"
                  onclick="openDeleteRoomModal(this.dataset.roomid, this.dataset.roomno)">Delete</button>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div class="pagination" id="rooms-pagination">
      <span id="rooms-page-info">Showing 1–13 of <%= rooms.length %> rooms</span>
      <div class="page-btns" id="rooms-page-btns"></div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     UNASSIGNED STUDENTS PAGE
══════════════════════════════════════ -->
<div class="page" id="page-unassigned">
  <% if (unallocatedStudents.length === 0) { %>
  <div class="card">
    <div class="empty-state" style="padding:3rem">
      <i class="ti ti-circle-check" style="color:var(--green);opacity:.5;font-size:2.5rem;display:block;margin-bottom:.7rem"></i>
      <h4>All students have been assigned rooms.</h4>
    </div>
  </div>
  <% } else { %>
  <div class="card">
    <div class="card-head">
      <h3><i class="ti ti-user-off"></i> Students Without Room Assignment</h3>
      <span class="count-pill"><%= unallocatedStudents.length %> students</span>
    </div>
    <div class="tbl-wrap">
      <table>
        <thead>
          <tr><th>#</th><th>Student</th><th>Student ID</th><th>Phone</th><th>Status</th><th>Action</th></tr>
        </thead>
        <tbody>
          <% unallocatedStudents.forEach(function(student, index) { %>
          <tr>
            <td><%= index + 1 %></td>
            <td>
              <div class="user-cell">
                <div class="u-av s"><%= student.user && student.user.fullname ? student.user.fullname.charAt(0).toUpperCase() : '?' %></div>
                <div>
                  <div class="u-name"><%= student.user ? student.user.fullname : '—' %></div>
                  <div class="u-sub"><%= student.user ? student.user.email : '—' %></div>
                </div>
              </div>
            </td>
            <td><code class="uid-code"><%= student.user ? student.user.userId : '—' %></code></td>
            <td><%= student.user && student.user.phoneNumber ? student.user.phoneNumber : '—' %></td>
            <td><span class="alloc-badge alloc-vacated">No Room Assigned</span></td>
            <td>
              <button class="act-btn btn-alloc"
                data-studentid="<%= student._id %>"
                data-studentname="<%= student.user ? student.user.fullname : '' %>"
                onclick="openStudentAllocationModal(this.dataset.studentid, this.dataset.studentname)">
                <i class="ti ti-door"></i> Allocate Room
              </button>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>
</div>

<!-- ══════════════════════════════════════
     ALLOCATIONS PAGE
══════════════════════════════════════ -->
<div class="page" id="page-allocations">
  <div class="card">
    <div class="card-head">
      <h3><i class="ti ti-transfer"></i> All Allocations</h3>
      <div class="card-actions">
        <select class="filter-sel" id="filter-alloc-status" onchange="applyAllocFilters()">
          <option value="all">All Status</option>
          <option value="Active">Active</option>
          <option value="Vacated">Vacated</option>
          <option value="Transferred">Transferred</option>
        </select>
      </div>
    </div>
    <div class="tbl-wrap">
      <table>
        <thead><tr><th>#</th><th>Student</th><th>Room</th><th>Bed No</th><th>Allocated By</th><th>Date</th><th>Status</th><th>Remarks</th><th class="actions-th">Actions</th></tr></thead>
        <tbody id="alloc-body">
          <% allocations.forEach(function(al, i) { %>
          <tr data-alloc-status="<%= al.status %>">
            <td><%= i+1 %></td>
            <td>
              <div class="user-cell">
                <div class="u-av s"><%= al.student && al.student.user && al.student.user.fullname ? al.student.user.fullname.charAt(0).toUpperCase() : '?' %></div>
                <div>
                  <div class="u-name"><%= al.student && al.student.user ? al.student.user.fullname : '—' %></div>
                  <div class="u-sub"><%= al.student && al.student.user ? al.student.user.userId : '—' %></div>
                </div>
              </div>
            </td>
            <td>
              <strong><%= al.room ? al.room.roomNo : '—' %></strong>
              <div style="font-size:.68rem;color:var(--text-muted)">Block <%= al.room ? al.room.block : '' %></div>
            </td>
            <td><%= al.bedNo || '—' %></td>
            <td><%= al.allocatedBy ? al.allocatedBy.fullname : 'System' %></td>
            <td style="font-size:.72rem;color:var(--text-muted)"><%= new Date(al.allocationDate).toLocaleDateString() %></td>
            <td><span class="alloc-badge alloc-<%= al.status.toLowerCase() %>"><%= al.status %></span></td>
            <td><span class="remarks-text"><%= al.remarks || '—' %></span></td>
            <td class="actions-cell">
              <div class="action-cell">
                <% if (al.status === 'Active') { %>
                <button class="act-btn btn-vacate"
                  data-allocid="<%= al._id %>"
                  data-studentname="<%= al.student && al.student.user ? al.student.user.fullname : '' %>"
                  data-roomno="<%= al.room ? al.room.roomNo : '' %>"
                  onclick="openVacateModal(this.dataset.allocid, this.dataset.studentname, this.dataset.roomno)">
                  Vacate
                </button>
                <button class="act-btn btn-transfer"
                  data-allocid="<%= al._id %>"
                  data-studentname="<%= al.student && al.student.user ? al.student.user.fullname : '' %>"
                  data-studentid="<%= al.student ? al.student._id : '' %>"
                  onclick="openTransferModal(this.dataset.allocid, this.dataset.studentname, this.dataset.studentid)">
                  Transfer
                </button>
                <% } %>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     GUEST ROOMS PAGE
     Private, whole-room bookings for visitors — max `capacity` people
     per booking, priced per night. No Allocation model involvement,
     no student allocate/vacate/transfer actions here.
══════════════════════════════════════ -->
<div class="page" id="page-guest-rooms">

  <div class="stats-row">
    <div class="stat-card">
      <div class="s-icon" style="background:#F3E5F5;color:#8E24AA"><i class="ti ti-home-2"></i></div>
      <div class="s-info"><h4>Total Guest Rooms</h4><h3><%= guestStats.totalGuestRooms %></h3></div>
    </div>
    <div class="stat-card">
      <div class="s-icon avail"><i class="ti ti-circle-check"></i></div>
      <div class="s-info"><h4>Available</h4><h3><%= guestStats.availableGuestRooms %></h3></div>
    </div>
    <div class="stat-card">
      <div class="s-icon occ"><i class="ti ti-users"></i></div>
      <div class="s-info"><h4>Occupied</h4><h3><%= guestStats.occupiedGuestRooms %></h3></div>
    </div>
    <div class="stat-card">
      <div class="s-icon maint"><i class="ti ti-tool"></i></div>
      <div class="s-info"><h4>Maintenance</h4><h3><%= guestStats.maintenanceGuestRooms %></h3></div>
    </div>
    <div class="stat-card">
      <div class="s-icon indigo"><i class="ti ti-calendar-event"></i></div>
      <div class="s-info"><h4>Upcoming Bookings</h4><h3><%= guestStats.roomsWithUpcomingBookings %></h3></div>
    </div>
  </div>

  <div class="card">
    <div class="card-head">
      <h3><i class="ti ti-home-2"></i> Guest Rooms</h3>
      <div class="card-actions">
        <button class="act-btn btn-approve" onclick="showPage('add-room', document.getElementById('nav-add-room')); presetGuestCategory();">
          <i class="ti ti-plus"></i> Add Guest Room
        </button>
      </div>
    </div>

    <% if (guestRooms.length === 0) { %>
    <div class="empty-state" style="padding:2.5rem">
      <i class="ti ti-home-2"></i>
      <h4>No guest rooms yet</h4>
      <p>Add a room and set its category to "Guest Room" to get started.</p>
    </div>
    <% } else { %>
    <div class="tbl-wrap">
      <table>
        <thead><tr><th>#</th><th>Room No</th><th>Block</th><th>Floor</th><th>Max Occupancy</th><th>Fee / Night</th><th>Status</th><th>Upcoming Bookings</th><th class="actions-th">Actions</th></tr></thead>
        <tbody>
          <% guestRooms.forEach(function(room, i) {
               var safeDescG = (room.description || '').replace(/\\/g, '\\\\').replace(/'/g, '&#39;');
          %>
          <tr data-search-hidden="0">
            <td><%= i+1 %></td>
            <td><strong><%= room.roomNo %></strong></td>
            <td><span class="block-badge block-<%= room.block.toLowerCase() %>">Block <%= room.block %></span></td>
            <td>Floor <%= room.floor %></td>
            <td><%= room.capacity %> <%= room.capacity === 1 ? 'person' : 'people' %> (private)</td>
            <td>Rs <%= (room.feePerNight || 0).toLocaleString() %> / night</td>
            <td><span class="room-status-badge status-<%= room.status.toLowerCase() %>"><%= room.status %></span></td>
            <td>
  <% var roomBookings = guestBookingsByRoom[String(room._id)]; %>
  <% if (roomBookings && roomBookings.length > 0) { %>
    <div style="font-size:.72rem;color:#6A1B9A;font-weight:600;white-space:nowrap">
      <%= roomBookings[0].fromDate %> – <%= roomBookings[0].toDate %>
    </div>
    <div style="font-size:.65rem;color:var(--text-muted);margin-top:.1rem">
      <%= roomBookings[0].studentName %>
    </div>
    <% if (roomBookings.length > 1) { %>
      <span class="badge badge-purple" style="margin-top:.25rem;display:inline-block">+<%= roomBookings.length - 1 %> more</span>
    <% } %>
  <% } else { %>
    <span style="font-size:.72rem;color:var(--text-muted)">No upcoming bookings</span>
  <% } %>
</td>
            <td class="actions-cell">
              <div class="action-cell">
                <button class="act-btn btn-view"
                  data-id="<%= room._id %>" data-roomno="<%= room.roomNo %>" data-block="<%= room.block %>"
                  data-floor="<%= room.floor %>" data-capacity="<%= room.capacity %>" data-occupied="<%= room.occupiedBeds %>"
                  data-type="<%= room.roomType %>" data-category="Guest" data-fee="<%= room.monthlyFee %>"
                  data-nightlyfee="<%= room.feePerNight || 0 %>" data-status="<%= room.status %>"
                  data-desc="<%= safeDescG %>" onclick="openRoomModalFromTile(this)">View</button>
                <button class="act-btn btn-del"
                  data-roomid="<%= room._id %>" data-roomno="<%= room.roomNo %>"
                  onclick="openDeleteRoomModal(this.dataset.roomid, this.dataset.roomno)">Delete</button>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>

