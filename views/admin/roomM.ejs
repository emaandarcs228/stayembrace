<!-- Rooms data for JS -->
<script id="rooms-data" type="application/json"><%- JSON.stringify(rooms.filter(function(r){ return r.status === 'Available' && r.occupiedBeds < r.capacity; }).map(function(r){ return { id: String(r._id), roomNo: r.roomNo, block: r.block, floor: r.floor, capacity: r.capacity, occupiedBeds: r.occupiedBeds }; })) %></script>

<script>
window.PAGE_TITLES = {
  'overview'     : 'Room Management — Overview',
  'all-rooms'    : 'Room Management — Student Rooms',
  'unassigned'   : 'Room Management — Unassigned Students',
  'allocations'  : 'Room Management — Allocations',
  'guest-rooms'  : 'Room Management — Guest Rooms',
  'add-room'     : 'Room Management — Add Room'
};

function showPage(id, el) {
  document.querySelectorAll('.page').forEach(function(p){ p.classList.remove('active'); });
  document.querySelectorAll('.page-tabs .act-btn').forEach(function(n){ n.classList.remove('active'); });
  var pg = document.getElementById('page-' + id);
  if (pg) pg.classList.add('active');
  if (el) el.classList.add('active');
  if (id === 'all-rooms') { applyRoomFilters(); renderRoomsPagination(); }
  if (window.PAGE_TITLES && window.PAGE_TITLES[id]) {
    var titleEl = document.querySelector('.topbar-left h2');
    if (titleEl) titleEl.textContent = window.PAGE_TITLES[id];
  }
}

// Used by the Overview stat cards (Available/Occupied/Maintenance) —
// jumps to Student Rooms tab and pre-applies the status filter, since
// those standalone tabs were removed in favor of this dropdown.
function goToStudentRoomsFiltered(status) {
  document.getElementById('filter-status').value = status;
  showPage('all-rooms', document.getElementById('nav-student-rooms'));
}

/* ═══ DOM READY ═══ */
document.addEventListener('DOMContentLoaded', function() {
  var params = new URLSearchParams(window.location.search);
  var page   = params.get('page');
  var valid  = Object.keys(window.PAGE_TITLES);
  if (page && valid.indexOf(page) !== -1) {
    var navMap = {
      'all-rooms'   : document.getElementById('nav-student-rooms'),
      'unassigned'  : document.getElementById('nav-unassigned'),
      'allocations' : document.getElementById('nav-allocations'),
      'guest-rooms' : document.getElementById('nav-guest-rooms'),
      'add-room'    : document.getElementById('nav-add-room')
    };
    showPage(page, navMap[page] || null);
  } else {
    renderRoomsPagination();
  }

  /* Transfer room → load beds */
  document.getElementById('transfer-room').addEventListener('change', async function() {
    var roomId = this.value;
    var bedSel = document.getElementById('transfer-bed');
    bedSel.innerHTML = '<option value="">— Select bed —</option>';
    if (!roomId) return;
    try {
      var res  = await fetch('/admin/rooms/' + roomId + '/free-beds');
      var data = await res.json();
      data.freeBeds.forEach(function(bed) {
        var o = document.createElement('option');
        o.value = bed; o.textContent = 'Bed ' + bed;
        bedSel.appendChild(o);
      });
    } catch(err) {
      bedSel.innerHTML = '<option value="">Unable to load beds</option>';
    }
  });

  // Ensure Add Room form starts in the correct fee-field state
  toggleAddRoomFeeFields(document.getElementById('ar-category').value);
});

/* ═══ MODAL OVERLAY CLICK-TO-CLOSE ═══ */
document.querySelectorAll('.modal-overlay').forEach(function(overlay) {
  overlay.addEventListener('click', function(e) {
    if (e.target === overlay) overlay.classList.remove('open');
  });
});

/* ═══ ROOM FILTERS ═══ */
function applyRoomFilters() {
  var block  = document.getElementById('filter-block').value;
  var status = document.getElementById('filter-status').value;
  var type   = document.getElementById('filter-type').value;
  document.querySelectorAll('#rooms-body tr').forEach(function(row) {
    var m = (block  === 'all' || row.dataset.block  === block)  &&
            (status === 'all' || row.dataset.status === status) &&
            (type   === 'all' || row.dataset.type   === type);
    row.dataset.filterHidden = m ? '0' : '1';
  });
  ROOMS_PAGE = 1;
  renderRoomsPagination();
}

function applyAllocFilters() {
  var status = document.getElementById('filter-alloc-status').value;
  document.querySelectorAll('#alloc-body tr').forEach(function(row) {
    row.style.display = (status === 'all' || row.dataset.allocStatus === status) ? '' : 'none';
  });
}

/* ═══ PAGINATION ═══ */
var ROWS_PER_PAGE = 13;
var ROOMS_PAGE = 1;

function getVisibleRoomRows() {
  return Array.from(document.querySelectorAll('#rooms-body tr')).filter(function(r) {
    return r.dataset.filterHidden !== '1' && r.dataset.searchHidden !== '1';
  });
}

function renderRoomsPagination() {
  var all     = Array.from(document.querySelectorAll('#rooms-body tr'));
  var visible = getVisibleRoomRows();
  var total   = visible.length;
  var pages   = Math.max(1, Math.ceil(total / ROWS_PER_PAGE));
  if (ROOMS_PAGE > pages) ROOMS_PAGE = pages;
  if (ROOMS_PAGE < 1) ROOMS_PAGE = 1;
  all.forEach(function(r){ r.style.display = 'none'; });
  var start = (ROOMS_PAGE - 1) * ROWS_PER_PAGE;
  var end   = start + ROWS_PER_PAGE;
  visible.slice(start, end).forEach(function(r){ r.style.display = ''; });
  document.getElementById('rooms-page-info').textContent =
    total === 0 ? 'Showing 0 of 0 rooms' :
    'Showing ' + (start+1) + '–' + Math.min(end,total) + ' of ' + total + ' rooms';
  var wrap = document.getElementById('rooms-page-btns');
  wrap.innerHTML = '';
  var prev = document.createElement('button');
  prev.className = 'pg-btn'; prev.textContent = '‹'; prev.disabled = ROOMS_PAGE === 1;
  prev.onclick = function(){ ROOMS_PAGE--; renderRoomsPagination(); };
  wrap.appendChild(prev);
  for (var i = 1; i <= pages; i++) {
    (function(num) {
      var b = document.createElement('button');
      b.className = 'pg-btn' + (num === ROOMS_PAGE ? ' active' : '');
      b.textContent = num;
      b.onclick = function(){ ROOMS_PAGE = num; renderRoomsPagination(); };
      wrap.appendChild(b);
    })(i);
  }
  var next = document.createElement('button');
  next.className = 'pg-btn'; next.textContent = '›'; next.disabled = ROOMS_PAGE === pages;
  next.onclick = function(){ ROOMS_PAGE++; renderRoomsPagination(); };
  wrap.appendChild(next);
}

/* ═══ GLOBAL SEARCH ═══ */
function globalSearchHandler() {
  var q = document.getElementById('globalSearch').value.trim().toLowerCase();
  var hasStudentMatch = false, hasGuestMatch = false;

  // Search Student Rooms
  document.querySelectorAll('#rooms-body tr').forEach(function(row) {
    var m = q === '' || row.textContent.toLowerCase().indexOf(q) !== -1;
    row.dataset.searchHidden = m ? '0' : '1';
    if (m && q !== '') hasStudentMatch = true;
  });

  // Search Guest Rooms
  document.querySelectorAll('#page-guest-rooms tbody tr').forEach(function(row) {
    var m = q === '' || row.textContent.toLowerCase().indexOf(q) !== -1;
    row.dataset.searchHidden = m ? '0' : '1';
    if (m && q !== '') hasGuestMatch = true;
    row.style.display = m ? '' : 'none';
  });

  ROOMS_PAGE = 1;
  renderRoomsPagination();

  // Navigate to the tab that has matching results
  if (q !== '') {
    if (hasStudentMatch) {
      showPage('all-rooms', document.getElementById('nav-student-rooms'));
    } else if (hasGuestMatch) {
      showPage('guest-rooms', document.getElementById('nav-guest-rooms'));
    }
  }
}

/* ═══ ADD ROOM HELPERS ═══ */
function syncCapacity(sel) {
  var cap = document.getElementById('ar-capacity');
  if (sel.value === 'Single') cap.value = 1;
  if (sel.value === 'Double') cap.value = 2;
  if (sel.value === 'Triple') cap.value = 3;
}

// Toggle fields based on selected category:
// - Monthly Fee vs Fee-per-Night
// - Room Type (hidden for Guest, replaced by a "Private Room" note)
// - Capacity (hidden for Guest — always 3, set silently on the hidden input)
// `required` is kept in sync so the browser only enforces whichever
// fields are actually visible.
function toggleAddRoomFeeFields(category) {
  var monthlyGroup   = document.getElementById('ar-monthlyfee-group');
  var nightlyGroup   = document.getElementById('ar-nightlyfee-group');
  var monthlyInput   = document.getElementById('ar-monthlyfee');
  var nightlyInput   = document.getElementById('ar-nightlyfee');
  var capacityInput  = document.getElementById('ar-capacity');
  var capacityGroup  = document.getElementById('ar-capacity-group');
  var roomTypeSelect = document.getElementById('ar-roomtype');
  var roomTypeNote   = document.getElementById('ar-roomtype-note');
  var roomTypeLabel  = document.getElementById('ar-roomtype-label');

  if (category === 'Guest') {
    monthlyGroup.style.display = 'none';
    nightlyGroup.style.display = '';
    monthlyInput.required = false;
    nightlyInput.required = true;

    // Guest rooms are always private, whole-room bookings for up to 3
    // guests — hide the field and let the (still-present, hidden) input
    // carry the fixed value through on submit.
    capacityGroup.style.display = 'none';
    capacityInput.required = false;
    capacityInput.value = 3;

    // Room Type (Single/Double/Triple) is a bed-count concept and
    // doesn't apply to a private guest room — swap it for a note, but
    // keep a valid hidden value so the schema enum still validates.
    roomTypeSelect.style.display = 'none';
    roomTypeSelect.required = false;
    roomTypeSelect.value = 'Triple';
    roomTypeLabel.textContent = 'Room Type';
    roomTypeNote.style.display = 'block';
  } else {
    monthlyGroup.style.display = '';
    nightlyGroup.style.display = 'none';
    monthlyInput.required = true;
    nightlyInput.required = false;

    capacityGroup.style.display = '';
    capacityInput.required = true;

    roomTypeSelect.style.display = '';
    roomTypeSelect.required = true;
    roomTypeLabel.innerHTML = 'Room Type <span class="req">*</span>';
    roomTypeNote.style.display = 'none';
  }
}

// Used by the "Add Guest Room" shortcut button on the Guest Rooms tab
function presetGuestCategory() {
  var sel = document.getElementById('ar-category');
  sel.value = 'Guest';
  toggleAddRoomFeeFields('Guest');
}

/* ═══ ROOM VIEW / EDIT MODAL ═══ */
var _currentRoomId = null;

function openRoomModalFromTile(el) {
  openRoomModal({
    id          : el.dataset.id,
    roomNo      : el.dataset.roomno,
    block       : el.dataset.block,
    floor       : el.dataset.floor,
    capacity    : el.dataset.capacity,
    occupiedBeds: el.dataset.occupied,
    roomType    : el.dataset.type,
    category    : el.dataset.category || 'Student',
    monthlyFee  : el.dataset.fee,
    feePerNight : el.dataset.nightlyfee || 0,
    status      : el.dataset.status,
    description : el.dataset.desc
  });
}

function openRoomModal(d) {
  _currentRoomId = d.id;
  var isGuest = d.category === 'Guest';

  document.getElementById('rv-roomNo').textContent      = d.roomNo;
  document.getElementById('rv-block').textContent       = 'Block ' + d.block;
  document.getElementById('rv-floor').textContent       = 'Floor ' + d.floor;
  document.getElementById('rv-category').textContent    = isGuest ? 'Guest Room' : 'Student Room';
  document.getElementById('rv-type').textContent         = d.roomType;
  document.getElementById('rv-capacity').textContent    = d.capacity + (isGuest ? ' (max occupancy)' : '');
  document.getElementById('rv-description').textContent = d.description || '—';

  // Room Type only makes sense for Student rooms — Guest rooms are a
  // private whole unit, so hide the field entirely.
  document.getElementById('rv-type-field').style.display = isGuest ? 'none' : '';

  // Fee field — show whichever applies
  document.getElementById('rv-fee-field').style.display        = isGuest ? 'none' : '';
  document.getElementById('rv-nightlyfee-field').style.display = isGuest ? '' : 'none';
  document.getElementById('rv-fee').textContent         = 'Rs ' + Number(d.monthlyFee || 0).toLocaleString();
  document.getElementById('rv-nightlyfee').textContent  = 'Rs ' + Number(d.feePerNight || 0).toLocaleString() + ' / night';

  // Occupied-beds field only makes sense for Student rooms (bed-level
  // tracking); Guest rooms are booked as a whole, so hide it.
  document.getElementById('rv-occupied-field').style.display = isGuest ? 'none' : '';
  document.getElementById('rv-occupied').textContent = d.occupiedBeds;

  var sb = document.getElementById('rv-status-badge');
  sb.textContent = d.status;
  sb.className   = 'room-status-badge status-' + d.status.toLowerCase();

  // Upcoming Bookings — Guest rooms only. Fetches this room's active
  // (Approved, not-yet-ended) bookings so admin can see at a glance
  // when it's actually spoken for, since Room.status itself is manual.
  var bookingsSection = document.getElementById('rv-bookings-section');
  bookingsSection.style.display = isGuest ? 'block' : 'none';
  if (isGuest) {
    loadRoomBookings(d.id);
  }

  // Bed visualiser only for Student rooms — a Guest room is booked as
  // one private unit, not per-bed.
  var viz = document.getElementById('rv-bed-viz');
  viz.innerHTML = '';
  if (!isGuest) {
    for (var i = 1; i <= Number(d.capacity); i++) {
      var b = document.createElement('div');
      b.className = 'bed-slot ' + (i <= Number(d.occupiedBeds) ? 'bed-slot-occ' : 'bed-slot-free');
      b.innerHTML = '<i class="fas fa-bed"></i><span>Bed ' + i + '</span>';
      viz.appendChild(b);
    }
  }

  document.getElementById('re-roomNo').value       = d.roomNo;
  document.getElementById('re-block').value        = d.block;
  document.getElementById('re-floor').value        = d.floor;
  document.getElementById('re-roomCategory').value = isGuest ? 'Guest' : 'Student';
  document.getElementById('re-roomType').value     = d.roomType;
  document.getElementById('re-capacity').value     = d.capacity;
  document.getElementById('re-monthlyFee').value   = d.monthlyFee || 0;
  document.getElementById('re-feePerNight').value  = d.feePerNight || 0;
  document.getElementById('re-status').value       = d.status;
  document.getElementById('re-description').value  = d.description || '';

  toggleEditRoomFeeFields(isGuest ? 'Guest' : 'Student');
  switchRoomToView();
  document.getElementById('roomModal').classList.add('open');
}

function closeRoomModal() {
  document.getElementById('roomModal').classList.remove('open');
}

function switchRoomToEdit() {
  document.getElementById('rm-modal-title').innerHTML      = '<i class="ti ti-pencil"></i> Edit Room';
  document.getElementById('rm-view-section').style.display = 'none';
  document.getElementById('rm-edit-section').style.display = 'block';
  document.getElementById('rm-btn-edit').style.display     = 'none';
  document.getElementById('rm-btn-save').style.display     = 'flex';
  document.getElementById('rm-btn-cancel').style.display   = 'flex';
}

function switchRoomToView() {
  document.getElementById('rm-modal-title').innerHTML      = '<i class="ti ti-door"></i> Room Details';
  document.getElementById('rm-view-section').style.display = 'block';
  document.getElementById('rm-edit-section').style.display = 'none';
  document.getElementById('rm-btn-edit').style.display     = 'flex';
  document.getElementById('rm-btn-save').style.display     = 'none';
  document.getElementById('rm-btn-cancel').style.display   = 'none';
}

// Toggle Monthly Fee vs Fee-per-Night, Room Type vs note, and Capacity
// visibility in the Edit modal based on category.
function toggleEditRoomFeeFields(category) {
  var monthlyGroup   = document.getElementById('re-monthlyfee-group');
  var nightlyGroup   = document.getElementById('re-nightlyfee-group');
  var capacityGroup  = document.getElementById('re-capacity-group');
  var capacityInput  = document.getElementById('re-capacity');
  var roomTypeSelect = document.getElementById('re-roomType');
  var roomTypeNote   = document.getElementById('re-roomtype-note');

  if (category === 'Guest') {
    monthlyGroup.style.display  = 'none';
    nightlyGroup.style.display  = '';

    capacityGroup.style.display = 'none';
    capacityInput.value = 3;

    roomTypeSelect.style.display = 'none';
    roomTypeSelect.value = 'Triple';
    roomTypeNote.style.display = 'block';
  } else {
    monthlyGroup.style.display  = '';
    nightlyGroup.style.display  = 'none';

    capacityGroup.style.display = '';

    roomTypeSelect.style.display = '';
    roomTypeNote.style.display = 'none';
  }
}

function submitRoomEdit() {
  if (!_currentRoomId) return;
  var form = document.getElementById('rm-edit-section');
  form.action = '/admin/rooms/edit/' + _currentRoomId;
  form.submit();
}

function triggerRoomDelete() {
  var no = document.getElementById('rv-roomNo').textContent;
  closeRoomModal();
  openDeleteRoomModal(_currentRoomId, no);
}

/* ═══ UPCOMING BOOKINGS (Guest rooms only) ═══ */
async function loadRoomBookings(roomId) {
  var loading = document.getElementById('rv-bookings-loading');
  var list    = document.getElementById('rv-bookings-list');
  var empty   = document.getElementById('rv-bookings-empty');

  loading.style.display = 'block';
  list.style.display    = 'none';
  empty.style.display   = 'none';
  list.innerHTML = '';

  try {
    var res  = await fetch('/admin/rooms/' + roomId + '/guest-bookings');
    var data = await res.json();
    loading.style.display = 'none';

    if (!data.bookings || data.bookings.length === 0) {
      empty.style.display = 'block';
      return;
    }

    data.bookings.forEach(function(b) {
      var row = document.createElement('div');
      row.style.cssText = 'display:flex;justify-content:space-between;align-items:center;gap:.6rem;padding:.5rem .7rem;background:#F3E5F5;border-radius:var(--radius-sm);font-size:.75rem';
      row.innerHTML =
        '<span><strong>' + (b.studentName || 'Unknown') + '</strong> — ' + b.fromDate + ' to ' + b.toDate + '</span>' +
        '<span class="badge badge-success" style="flex-shrink:0">Approved</span>';
      list.appendChild(row);
    });
    list.style.display = 'flex';
  } catch (err) {
    loading.style.display = 'none';
    empty.textContent = 'Unable to load bookings.';
    empty.style.display = 'block';
  }
}

/* ═══ ALLOCATE MODAL — from room button (Student rooms only) ═══ */
function openAllocModalFromBtn(el) {
  openAllocModal(el.dataset.roomid, el.dataset.roomno, el.dataset.capacity, el.dataset.occupied);
}

async function openAllocModal(roomId, roomNo, capacity, occupied) {
  document.getElementById('alloc-room-no').textContent   = roomNo;
  document.getElementById('alloc-room-meta').textContent = (Number(capacity) - Number(occupied)) + ' of ' + capacity + ' beds free';
  document.getElementById('alloc-form').action           = '/admin/rooms/allocate/' + roomId;
  document.getElementById('alloc-student').selectedIndex = 0;

  var bedSel = document.getElementById('alloc-bed');
  bedSel.innerHTML = '<option>Loading beds...</option>';

  try {
    var res  = await fetch('/admin/rooms/' + roomId + '/free-beds');
    var data = await res.json();
    bedSel.innerHTML = '<option value="">— Select bed —</option>';
    data.freeBeds.forEach(function(bed) {
      var o = document.createElement('option');
      o.value = bed; o.textContent = 'Bed ' + bed;
      bedSel.appendChild(o);
    });
  } catch(err) {
    bedSel.innerHTML = '<option value="">Unable to load beds</option>';
  }

  document.getElementById('allocModal').classList.add('open');
}

function closeAllocModal() {
  document.getElementById('allocModal').classList.remove('open');
  var injected = document.getElementById('alloc-room-group');
  if (injected) injected.remove();
  document.getElementById('alloc-form').onsubmit = null;
}

/* ═══ ALLOCATE MODAL — from unassigned student button ═══ */
function openStudentAllocationModal(studentId, studentName) {
  document.getElementById('alloc-room-no').textContent   = 'Select a room below';
  document.getElementById('alloc-room-meta').textContent = 'Allocating for: ' + studentName;
  document.getElementById('alloc-form').action = '#';
  document.getElementById('alloc-form').onsubmit = function(e) {
    var roomSel = document.getElementById('alloc-student-room-sel');
    if (roomSel && roomSel.value) {
      this.action = '/admin/rooms/allocate/' + roomSel.value;
      return true;
    }
    e.preventDefault();
    alert('Please select a room first.');
    return false;
  };

  var studentSel = document.getElementById('alloc-student');
  studentSel.value = studentId;

  var bedSel = document.getElementById('alloc-bed');
  bedSel.innerHTML = '<option value="">— Select room first —</option>';

  var existing = document.getElementById('alloc-student-room-sel');
  if (!existing) {
    var group = document.createElement('div');
    group.className = 'form-group';
    group.id = 'alloc-room-group';
    group.style.marginTop = '.8rem';
    group.innerHTML =
      '<label>Select Room <span class="req">*</span></label>' +
      '<select id="alloc-student-room-sel" required style="border:1px solid var(--border-mid);border-radius:var(--radius-sm);padding:.45rem .7rem;font-size:.78rem;font-family:inherit;outline:none;width:100%">' +
        '<option value="">— Choose an available room —</option>' +
      '</select>';
    bedSel.parentElement.parentElement.insertBefore(group, bedSel.parentElement);

    // NOTE: rooms-data JSON is already scoped to Student rooms only
    // (see the JSON script tag above), so Guest rooms never appear here.
    var roomSel = document.getElementById('alloc-student-room-sel');
    var availableRooms = JSON.parse(document.getElementById('rooms-data').textContent || '[]');
    availableRooms.forEach(function(room) {
      var o = document.createElement('option');
      o.value = room.id;
      o.textContent = room.roomNo + ' — Block ' + room.block + ', Floor ' + room.floor + ' (' + (room.capacity - room.occupiedBeds) + ' free)';
      roomSel.appendChild(o);
    });

    roomSel.addEventListener('change', async function() {
      var rId = this.value;
      var bSel = document.getElementById('alloc-bed');
      bSel.innerHTML = '<option>Loading...</option>';
      if (!rId) { bSel.innerHTML = '<option value="">— Select room first —</option>'; return; }
      document.getElementById('alloc-form').action = '/admin/rooms/allocate/' + rId;
      try {
        var res  = await fetch('/admin/rooms/' + rId + '/free-beds');
        var data = await res.json();
        bSel.innerHTML = '<option value="">— Select bed —</option>';
        data.freeBeds.forEach(function(bed) {
          var o = document.createElement('option');
          o.value = bed; o.textContent = 'Bed ' + bed;
          bSel.appendChild(o);
        });
      } catch(err) {
        bSel.innerHTML = '<option value="">Unable to load beds</option>';
      }
    });
  } else {
    existing.selectedIndex = 0;
    bedSel.innerHTML = '<option value="">— Select room first —</option>';
    document.getElementById('alloc-form').action = '#';
  }

  document.getElementById('allocModal').classList.add('open');
}

/* ═══ OCCUPANTS MODAL ═══ */
async function showOccupantsModal(roomId, roomNo) {
  document.getElementById('occ-room-no').textContent    = roomNo;
  document.getElementById('occ-loading').style.display  = 'flex';
  document.getElementById('occ-content').style.display  = 'none';
  document.getElementById('occupantsModal').classList.add('open');
  try {
    var res  = await fetch('/admin/rooms/' + roomId + '/occupants');
    var data = await res.json();
    var tbody = document.getElementById('occ-tbody');
    tbody.innerHTML = '';
    var empty = document.getElementById('occ-empty');
    if (!data.occupants || data.occupants.length === 0) {
      empty.style.display = 'block';
    } else {
      empty.style.display = 'none';
      data.occupants.forEach(function(al) {
        var tr = document.createElement('tr');
        tr.style.borderBottom = '1px solid #f0f0f0';
        tr.innerHTML =
          '<td style="padding:.45rem .5rem">' +
            '<div style="font-weight:500;font-size:.78rem">' + (al.studentName || '—') + '</div>' +
            '<div style="font-size:.68rem;color:var(--text-muted)">' + (al.studentUserId || '—') + '</div>' +
          '</td>' +
          '<td style="padding:.45rem .5rem;font-size:.78rem">Bed ' + (al.bedNo || '—') + '</td>' +
          '<td style="padding:.45rem .5rem;font-size:.72rem;color:var(--text-muted)">' + (al.since || '—') + '</td>' +
          '<td style="padding:.45rem .5rem">' +
            '<button class="act-btn btn-vacate" style="font-size:.68rem" ' +
              'data-allocid="' + al.allocationId + '" ' +
              'data-name="' + (al.studentName || '') + '" ' +
              'data-roomno="' + roomNo + '" ' +
              'onclick="closeOccupantsModal();openVacateModal(this.dataset.allocid,this.dataset.name,this.dataset.roomno)">' +
              'Vacate' +
            '</button>' +
          '</td>';
        tbody.appendChild(tr);
      });
    }
    document.getElementById('occ-loading').style.display = 'none';
    document.getElementById('occ-content').style.display = 'block';
  } catch(err) {
    document.getElementById('occ-loading').innerHTML =
      '<i class="fas fa-exclamation-circle" style="color:#C62828"></i> Failed to load.';
  }
}

function closeOccupantsModal() {
  document.getElementById('occupantsModal').classList.remove('open');
}

/* ═══ VACATE MODAL ═══ */
function openVacateModal(allocId, studentName, roomNo) {
  document.getElementById('vacate-msg').textContent =
    'Vacate "' + studentName + '" from room ' + roomNo + '? This cannot be undone.';
  document.getElementById('vacate-form').action = '/admin/rooms/vacate/' + allocId;
  document.getElementById('vacateModal').classList.add('open');
}
function closeVacateModal() {
  document.getElementById('vacateModal').classList.remove('open');
}

/* ═══ TRANSFER MODAL ═══ */
function openTransferModal(allocId, studentName, studentId) {
  document.getElementById('transfer-student-name').textContent = 'Transferring: ' + studentName;
  document.getElementById('transfer-form').action = '/admin/rooms/transfer/' + allocId;
  document.getElementById('transfer-room').selectedIndex = 0;
  document.getElementById('transfer-bed').innerHTML = '<option value="">— Select room first —</option>';
  document.getElementById('transferModal').classList.add('open');
}
function closeTransferModal() {
  document.getElementById('transferModal').classList.remove('open');
}

/* ═══ DELETE ROOM MODAL ═══ */
function openDeleteRoomModal(id, no) {
  document.getElementById('del-room-msg').textContent = 'Delete room "' + no + '"? All allocation history will be preserved.';
  document.getElementById('delete-room-form').action  = '/admin/rooms/delete/' + id;
  document.getElementById('deleteRoomModal').classList.add('open');
}
function closeDeleteRoomModal() {
  document.getElementById('deleteRoomModal').classList.remove('open');
}
</script>

