<%
  const activePage    = 'profile';
  const pageTitle     = 'My Profile';
  const pageSubtitle  = student.user.userId;
%>
<%- include('student-header') %>

<div class="page active" id="page-profile">

  <!-- ── Profile Header Banner ── -->
  <div class="welcome-banner" style="margin-bottom:1.2rem">
    <div style="display:flex;align-items:center;gap:1rem;z-index:1">
      <div style="width:60px;height:60px;border-radius:50%;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:1.6rem;font-weight:700;color:white;border:3px solid rgba(255,255,255,.35);flex-shrink:0">
        <%= student.user.fullname.charAt(0).toUpperCase() %>
      </div>
      <div class="wb-text">
        <h2><%= student.user.fullname %></h2>
        <p>
          <span style="background:rgba(255,255,255,.18);padding:.1rem .55rem;border-radius:20px;font-size:.7rem;font-weight:600;margin-right:.4rem">Student</span>
          <%= student.user.userId %>
          &nbsp;·&nbsp;
          <span style="color:<%= student.user.status === 'approved' ? '#a8f0c0' : '#ffcdd2' %>">
            ● <%= student.user.status.charAt(0).toUpperCase() + student.user.status.slice(1) %>
          </span>
        </p>
      </div>
    </div>
    <i class="fas fa-id-badge wb-icon"></i>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.2rem">

    <!-- ── Personal Info ── -->
    <div class="card">
      <div class="card-head">
        <h3><i class="fas fa-user"></i> Personal Information</h3>
      </div>
      <div class="detail-grid">
        <div class="detail-field">
          <label>Full Name</label>
          <span><%= student.user.fullname %></span>
        </div>
        <div class="detail-field">
          <label>Email Address</label>
          <span><%= student.user.email %></span>
        </div>
        <div class="detail-field">
          <label>Phone Number</label>
          <span><%= student.user.phoneNumber || '—' %></span>
        </div>
        <div class="detail-field">
          <label>Gender</label>
          <span><%= student.user.gender ? (student.user.gender.charAt(0).toUpperCase() + student.user.gender.slice(1)) : '—' %></span>
        </div>
        <div class="detail-field">
          <label>Date of Birth</label>
          <span><%= student.user.dateOfBirth ? new Date(student.user.dateOfBirth).toLocaleDateString('en-US', { day:'numeric', month:'long', year:'numeric' }) : '—' %></span>
        </div>
        <div class="detail-field">
          <label>Blood Group</label>
          <span><%= student.bloodGroup || '—' %></span>
        </div>
        <div class="detail-field full">
          <label>Home Address</label>
          <span><%= student.homeAddress || '—' %></span>
        </div>
        <div class="detail-field">
          <label>Emergency Contact</label>
          <span><%= student.emergencyContact || '—' %></span>
        </div>
        <div class="detail-field">
          <label>CNIC</label>
          <span><%= student.cnic || '—' %></span>
        </div>
      </div>
    </div>

    <!-- ── Academic & Guardian ── -->
    <div style="display:flex;flex-direction:column;gap:1.2rem">

      <div class="card">
        <div class="card-head">
          <h3><i class="fas fa-graduation-cap"></i> Academic Details</h3>
        </div>
        <div class="detail-grid">
          <div class="detail-field">
            <label>Department</label>
            <span><%= student.department || '—' %></span>
          </div>
          <div class="detail-field">
            <label>Institution</label>
            <span><%= student.institution || '—' %></span>
          </div>
          <div class="detail-field full">
            <label>Admission Date</label>
            <span><%= student.admissionDate ? new Date(student.admissionDate).toLocaleDateString('en-US', { day:'numeric', month:'long', year:'numeric' }) : '—' %></span>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-head">
          <h3><i class="fas fa-users"></i> Guardian / Emergency</h3>
        </div>
        <div class="detail-grid">
          <div class="detail-field">
            <label>Guardian Name</label>
            <span><%= student.guardianName || '—' %></span>
          </div>
          <div class="detail-field">
            <label>Relation</label>
            <span><%= student.guardianRelation || '—' %></span>
          </div>
          <div class="detail-field">
            <label>Guardian Contact</label>
            <span><%= student.guardianContact || '—' %></span>
          </div>
          <div class="detail-field full">
            <label>Guardian Email</label>
            <span><%= student.guardianEmail || '—' %></span>
          </div>
        </div>
      </div>

    </div>

  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.2rem">

    <!-- ── Hostel Info ── -->
    <div class="card">
      <div class="card-head">
        <h3><i class="ti ti-door"></i> Hostel Details</h3>
        <a href="/student/room" class="add-btn" style="text-decoration:none"><i class="ti ti-arrow-right"></i> Room</a>
      </div>
      <div class="detail-grid">
        <div class="detail-field">
          <label>Room Number</label>
          <span style="font-size:1rem;font-weight:700;color:var(--green-dark)">
            <%= student.room ? student.room.roomNo : '—' %>
          </span>
        </div>
        <div class="detail-field">
          <label>Block / Floor</label>
          <span><%= student.room ? 'Block ' + student.room.block + ', Floor ' + student.room.floor : '—' %></span>
        </div>
        <div class="detail-field">
          <label>Bed Number</label>
          <span><%= student.currentAllocation ? student.currentAllocation.bedNo : '—' %></span>
        </div>
        <div class="detail-field">
          <label>Room Type</label>
          <span><%= student.room ? student.room.roomType : '—' %></span>
        </div>
        <div class="detail-field">
          <label>Hostel Status</label>
          <span>
            <% const hStatus = student.hostelStatus || 'active'; %>
            <span class="badge <%= hStatus === 'active' ? 'badge-success' : hStatus === 'suspended' ? 'badge-danger' : 'badge-neutral' %>">
              <%= hStatus.charAt(0).toUpperCase() + hStatus.slice(1) %>
            </span>
          </span>
        </div>
        <div class="detail-field">
          <label>Allocation Date</label>
          <span><%= student.currentAllocation ? new Date(student.currentAllocation.allocationDate).toLocaleDateString() : '—' %></span>
        </div>
      </div>
    </div>

    <!-- ── ID Document ── -->
    <div class="card">
      <div class="card-head">
        <h3><i class="fas fa-id-card"></i> ID Document</h3>
      </div>
      <div style="padding:1rem 1.2rem">
        <% if (student.user.idImage) {
             const idSrc = '/' + student.user.idImage;
             const isPdf = idSrc.toLowerCase().endsWith('.pdf');
        %>
          <% if (isPdf) { %>
            <div style="display:flex;align-items:center;gap:.8rem;background:#FFF8E1;border:1px solid #FFE082;border-radius:var(--radius-md);padding:.9rem 1rem">
              <i class="fas fa-file-pdf" style="font-size:2rem;color:#E53935;flex-shrink:0"></i>
              <div>
                <div style="font-size:.8rem;font-weight:600;color:#5D4037;margin-bottom:.3rem">PDF Document</div>
                <button class="act-btn btn-view" onclick="openImageLightbox('<%= idSrc %>', '<%= student.user.fullname.replace(/'/g,"\\'") %>')">
                  <i class="fas fa-external-link-alt"></i> View PDF
                </button>
              </div>
            </div>
          <% } else { %>
            <img src="<%= idSrc %>"
                 alt="ID Document"
                 style="max-width:100%;max-height:220px;object-fit:contain;border-radius:var(--radius-md);border:1px solid var(--border);cursor:pointer;display:block"
                 onclick="openImageLightbox('<%= idSrc %>', '<%= student.user.fullname.replace(/'/g,"\\'") %>')"
                 title="Click to enlarge">
            <p style="font-size:.65rem;color:var(--text-muted);margin-top:.4rem"><i class="fas fa-search-plus"></i> Click to enlarge</p>
          <% } %>
        <% } else { %>
          <div class="empty-state" style="padding:1.5rem">
            <i class="fas fa-id-card" style="font-size:2rem;opacity:.3"></i>
            <h4 style="font-size:.8rem">No ID uploaded</h4>
            <p>Contact admin if your ID was not submitted.</p>
          </div>
        <% } %>
      </div>
    </div>

  </div>

  <!-- ══════════════════════════════════════════════════════════════
       TRANSPORT BOOKINGS — full-width card below the 2-column grid
  ══════════════════════════════════════════════════════════════ -->
  <div class="card" style="margin-top:1.2rem">
    <div class="card-head">
      <h3><i class="ti ti-taxi" style="color:#F57C00"></i> Transport Bookings</h3>
      <a href="/student/transport" class="add-btn" style="text-decoration:none;font-size:.7rem">
        <i class="ti ti-car"></i> Browse Providers
      </a>
    </div>

    <% if (typeof cabBookings !== 'undefined' && cabBookings.length > 0) { %>

      <!-- Active bookings summary -->
      <% if (activeCabBookings.length > 0) { %>
      <div style="padding:0 1.2rem .5rem;display:flex;align-items:center;gap:.5rem;flex-wrap:wrap">
        <span style="font-size:.65rem;font-weight:600;color:#E65100;display:flex;align-items:center;gap:.3rem">
          <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#4CAF50;animation:pulseGlow 2s infinite"></span>
          <%= activeCabBookings.length %> Active Booking<%= activeCabBookings.length > 1 ? 's' : '' %>
        </span>
        <span style="font-size:.6rem;color:#bbb">·</span>
        <span style="font-size:.65rem;color:var(--text-muted)"><%= pastCabBookings.length %> Past Booking<%= pastCabBookings.length !== 1 ? 's' : '' %></span>
      </div>
      <% } %>

      <div class="tbl-wrap">
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Provider</th>
              <th>Pickup → Dropoff</th>
              <th>Date / Time</th>
              <th>Pass.</th>
              <th>Vehicle</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% cabBookings.forEach(function(b, i) {
                 const statusMap = typeof rideStatusBadgeClass !== 'undefined' ? rideStatusBadgeClass : {};
                 const pickupDate = new Date(b.pickupDate);
            %>
            <tr>
              <td style="color:var(--text-muted);font-size:.7rem"><%= i + 1 %></td>
              <td>
                <div style="font-weight:600;font-size:.78rem"><%= b.driverName %></div>
                <div style="font-size:.62rem;color:var(--text-muted)"><%= b.driverPhone || '—' %></div>
              </td>
              <td style="font-size:.72rem;max-width:140px;word-break:break-word">
                <span style="color:#4CAF50"><i class="fas fa-circle" style="font-size:.4rem"></i></span> <%= b.pickupLocation %>
                <span style="color:#bbb;margin:0 .15rem">→</span>
                <span style="color:#E65100"><i class="fas fa-map-pin" style="font-size:.4rem"></i></span> <%= b.dropoffLocation %>
              </td>
              <td style="font-size:.72rem">
                <%= pickupDate.toLocaleDateString('en-PK', { day:'2-digit', month:'short', year:'numeric' }) %>
                <% if (b.pickupTime) { %><div style="font-size:.6rem;color:var(--text-muted)"><%= b.pickupTime %></div><% } %>
              </td>
              <td style="text-align:center"><span class="count-pill" style="font-size:.65rem"><%= b.passengerCount %></span></td>
              <td style="font-size:.68rem">
                <%= b.vehicleType || '—' %>
                <% if (b.vehicleRegistration) { %><div style="font-size:.58rem;color:var(--text-muted)"><%= b.vehicleRegistration.toUpperCase() %></div><% } %>
              </td>
              <td><span class="badge <%= statusMap[b.status] || 'badge-neutral' %>"><%= b.status %></span></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

    <% } else { %>

      <div class="empty-state" style="padding:2rem">
        <i class="ti ti-car-off" style="font-size:2.2rem;opacity:.3;display:block;margin-bottom:.5rem"></i>
        <h4 style="font-size:.85rem">No transport bookings yet</h4>
        <p style="font-size:.75rem">Browse available providers and book a cab from the Transport page.</p>
        <a href="/student/transport" class="act-btn btn-view" style="margin-top:.6rem;display:inline-flex;align-items:center;gap:.35rem">
          <i class="ti ti-taxi"></i> Book a Cab
        </a>
      </div>

    <% } %>
  </div>

</div>

<%- include('../partials/id-lightbox') %>

<style>
  @keyframes pulseGlow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(76,175,80,.4); }
    50%      { box-shadow: 0 0 0 6px rgba(76,175,80,0); }
  }
</style>

<%- include('student-footer') %>
