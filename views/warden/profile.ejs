<%
  const activePage    = 'profile';
  const pageTitle     = 'My Profile';
  const pageSubtitle  = warden.userId;
%>
<%- include('warden-header') %>

<!-- ══════════════════════════════════════
     WARDEN PROFILE
══════════════════════════════════════ -->

<div class="page active" id="page-profile">

  <!-- ── Welcome / Profile Banner ── -->
  <div class="welcome-banner" style="margin-bottom:1.2rem">
    <div style="display:flex;align-items:center;gap:1.2rem;z-index:1">

      <!-- Profile Picture (image or initial) with upload trigger -->
      <div class="profile-pic-wrap" style="position:relative;flex-shrink:0">
        <div id="profileAvatarDisplay" style="width:64px;height:64px;border-radius:50%;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:1.6rem;font-weight:700;color:white;border:3px solid rgba(255,255,255,.35);overflow:hidden">
          <% if (warden.profileImage) { %>
            <img src="/<%= warden.profileImage %>"
                 alt="Profile"
                 style="width:100%;height:100%;object-fit:cover"
                 id="profileImageTag">
          <% } else { %>
            <span id="profileInitialText"><%= warden.fullname.charAt(0).toUpperCase() %></span>
          <% } %>
        </div>
        <button type="button" class="profile-pic-btn" onclick="document.getElementById('profilePicInput').click()"
          style="position:absolute;bottom:-2px;right:-2px;width:26px;height:26px;border-radius:50%;border:2px solid #fff;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:.65rem;box-shadow:0 2px 6px rgba(0,0,0,.2);transition:transform .2s"
          onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'"
          title="Change profile photo">
          <i class="fas fa-camera"></i>
        </button>
        <form id="profilePicForm" method="POST" action="/warden/profile/picture" enctype="multipart/form-data" style="display:none">
          <input type="file" name="profileImage" id="profilePicInput" accept="image/jpeg,image/png,image/webp" onchange="document.getElementById('profilePicForm').submit()">
        </form>
      </div>

      <div class="wb-text">
        <h2><%= warden.fullname %></h2>
        <p>
          <span style="background:rgba(255,255,255,.18);padding:.1rem .55rem;border-radius:20px;font-size:.7rem;font-weight:600;margin-right:.4rem">Warden</span>
          <%= warden.userId %>
          &nbsp;·&nbsp;
          <span style="color:#a8f0c0">● Active</span>
          <% if (warden.profileImage) { %>
            &nbsp;·&nbsp;
            <button type="button" class="act-btn" style="background:rgba(255,255,255,.12);border:none;color:rgba(255,255,255,.8);font-size:.65rem;padding:.15rem .5rem;border-radius:12px;cursor:pointer"
              onclick="if(confirm('Remove profile photo?')){document.getElementById('removePhotoForm').submit()}">
              <i class="fas fa-trash-alt"></i> Remove
            </button>
            <form id="removePhotoForm" method="POST" action="/warden/profile/picture" style="display:none">
              <input type="hidden" name="_action" value="remove">
            </form>
          <% } %>
        </p>
      </div>
    </div>
    <i class="fas fa-shield-alt wb-icon"></i>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.2rem">

    <!-- ── Personal Information ── -->
    <div class="card">
      <div class="card-head">
        <h3><i class="fas fa-user"></i> Personal Information</h3>
        <button class="act-btn btn-edit" onclick="toggleEditMode()">
          <i class="fas fa-pen"></i> Edit
        </button>
      </div>

      <!-- View Mode -->
      <div id="profileViewMode">
        <div class="detail-grid">
          <div class="detail-field">
            <label>Full Name</label>
            <span><%= warden.fullname %></span>
          </div>
          <div class="detail-field">
            <label>Email Address</label>
            <span><%= warden.email %></span>
          </div>
          <div class="detail-field">
            <label>Phone Number</label>
            <span><%= warden.phoneNumber || '—' %></span>
          </div>
          <div class="detail-field">
            <label>Gender</label>
            <span><%= warden.gender ? warden.gender.charAt(0).toUpperCase() + warden.gender.slice(1) : '—' %></span>
          </div>
          <div class="detail-field">
            <label>Date of Birth</label>
            <span><%= warden.dateOfBirth ? new Date(warden.dateOfBirth).toLocaleDateString('en-US', { day:'numeric', month:'long', year:'numeric' }) : '—' %></span>
          </div>
        </div>
      </div>

      <!-- Edit Mode (hidden by default) -->
      <div id="profileEditMode" style="display:none">
        <form id="profileForm" method="POST" action="/warden/profile/update">
          <div class="form-section">
            <div class="form-grid">
              <div class="form-group">
                <label>Full Name</label>
                <input type="text" name="fullname" value="<%= warden.fullname %>" required>
              </div>
              <div class="form-group">
                <label>Email <span class="req">*</span></label>
                <input type="email" name="email" value="<%= warden.email %>" required>
              </div>
              <div class="form-group">
                <label>Phone Number</label>
                <input type="text" name="phoneNumber" value="<%= warden.phoneNumber || '' %>" placeholder="03XX-XXXXXXX">
              </div>
              <div class="form-group">
                <label>Gender</label>
                <select name="gender">
                  <option value="">— Select —</option>
                  <option value="male" <%= warden.gender === 'male' ? 'selected' : '' %>>Male</option>
                  <option value="female" <%= warden.gender === 'female' ? 'selected' : '' %>>Female</option>
                </select>
              </div>
              <div class="form-group">
                <label>Date of Birth</label>
                <input type="date" name="dateOfBirth" value="<%= warden.dateOfBirth ? new Date(warden.dateOfBirth).toISOString().split('T')[0] : '' %>">
              </div>
            </div>
            <div class="form-footer" style="border-top:none;padding:.8rem 0 0">
              <button type="submit" class="btn-primary"><i class="fas fa-save"></i> Save Changes</button>
              <button type="button" class="btn-sec" onclick="toggleEditMode()">Cancel</button>
            </div>
          </div>
        </form>
      </div>
    </div>

    <!-- ── Account Details ── -->
    <div class="card">
      <div class="card-head">
        <h3><i class="ti ti-shield-lock"></i> Account Details</h3>
      </div>
      <div class="detail-grid">
        <div class="detail-field">
          <label>User ID</label>
          <span class="uid-code" style="font-size:.85rem"><%= warden.userId %></span>
        </div>
        <div class="detail-field">
          <label>Role</label>
          <span class="role-badge warden">Warden</span>
        </div>
        <div class="detail-field">
          <label>Status</label>
          <span class="status-badge approved">Active</span>
        </div>
        <div class="detail-field">
          <label>Account Created</label>
          <span><%= new Date(warden.createdAt).toLocaleDateString('en-US', { day:'numeric', month:'long', year:'numeric' }) %></span>
        </div>
        <div class="detail-field">
          <label>Last Updated</label>
          <span><%= warden.updatedAt ? new Date(warden.updatedAt).toLocaleDateString('en-US', { day:'numeric', month:'long', year:'numeric' }) : '—' %></span>
        </div>
        <div class="detail-field">
          <label>Created By</label>
          <span><%= warden.createdBy || 'System' %></span>
        </div>
      </div>
    </div>

  </div>

  <!-- ── Change Password ── -->
  <div class="card" style="max-width:600px">
    <div class="card-head">
      <h3><i class="fas fa-lock"></i> Change Password</h3>
    </div>
    <div class="card-body">
      <form id="passwordForm" method="POST" action="/warden/profile/password">
        <div class="form-grid cols-1">
          <div class="form-group">
            <label>Current Password <span class="req">*</span></label>
            <div class="pw-wrap">
              <input type="password" name="currentPassword" id="currentPassword" placeholder="Enter current password" required>
              <button type="button" class="pw-toggle" onclick="togglePassword('currentPassword', this)">
                <i class="fas fa-eye"></i>
              </button>
            </div>
          </div>
          <div class="form-group">
            <label>New Password <span class="req">*</span></label>
            <div class="pw-wrap">
              <input type="password" name="newPassword" id="newPassword" placeholder="Min 8 characters, uppercase, lowercase, number, special char" required oninput="window.updatePasswordHint('newPassword', 'np-hint')">
              <button type="button" class="pw-toggle" onclick="togglePassword('newPassword', this)">
                <i class="fas fa-eye"></i>
              </button>
            </div>
            <p class="field-hint" id="np-hint">Min 8 chars with at least 3 of: uppercase, lowercase, number, special character.</p>
          </div>
          <div class="form-group">
            <label>Confirm New Password <span class="req">*</span></label>
            <div class="pw-wrap">
              <input type="password" name="confirmPassword" id="confirmPassword" placeholder="Re-enter new password" required>
              <button type="button" class="pw-toggle" onclick="togglePassword('confirmPassword', this)">
                <i class="fas fa-eye"></i>
              </button>
            </div>
          </div>
        </div>
        <div class="form-footer" style="border-top:none;padding:.8rem 0 0">
          <button type="submit" class="btn-primary"><i class="fas fa-key"></i> Update Password</button>
        </div>
      </form>
    </div>
  </div>

</div>

<!-- ── Scripts ── -->
<script>
(function() {
  'use strict';

  window.toggleEditMode = function() {
    var viewEl = document.getElementById('profileViewMode');
    var editEl = document.getElementById('profileEditMode');
    if (!viewEl || !editEl) return;
    var isEditing = editEl.style.display !== 'none';
    viewEl.style.display = isEditing ? '' : 'none';
    editEl.style.display = isEditing ? 'none' : '';
  };

  window.togglePassword = function(inputId, btn) {
    var input = document.getElementById(inputId);
    if (!input) return;
    var icon = btn.querySelector('i');
    if (input.type === 'password') {
      input.type = 'text';
      if (icon) icon.className = 'fas fa-eye-slash';
    } else {
      input.type = 'password';
      if (icon) icon.className = 'fas fa-eye';
    }
  };

  // ── Shared password helpers (match backend isStrongPassword exactly) ──
  window.isStrongPassword = window.isStrongPassword || function(pw) {
    var c = 0;
    if (/[a-z]/.test(pw)) c++;
    if (/[A-Z]/.test(pw)) c++;
    if (/\d/.test(pw)) c++;
    if (/[^A-Za-z0-9]/.test(pw)) c++;
    return pw.length >= 8 && c >= 3;
  };
  window.getPasswordConditions = window.getPasswordConditions || function(pw) {
    return { length: pw.length >= 8, lower: /[a-z]/.test(pw), upper: /[A-Z]/.test(pw), digit: /\d/.test(pw), special: /[^A-Za-z0-9]/.test(pw) };
  };
  window.getPasswordConditionCount = window.getPasswordConditionCount || function(c) {
    return (c.lower ? 1 : 0) + (c.upper ? 1 : 0) + (c.digit ? 1 : 0) + (c.special ? 1 : 0);
  };
  window.isPasswordFullyValid = window.isPasswordFullyValid || function(pw) {
    var c = window.getPasswordConditions(pw);
    return c.length && window.getPasswordConditionCount(c) >= 3;
  };
  window.passwordConditionsHTML = window.passwordConditionsHTML || function(pw) {
    var c = window.getPasswordConditions(pw);
    var cnt = window.getPasswordConditionCount(c);
    var ok = c.length && cnt >= 3;
    var items = [
      { k: 'length', l: '8+ characters', m: c.length },
      { k: 'upper',  l: 'Uppercase letter', m: c.upper },
      { k: 'lower',  l: 'Lowercase letter', m: c.lower },
      { k: 'digit',  l: 'Digit', m: c.digit },
      { k: 'special', l: 'Special character', m: c.special },
      { k: 'count',   l: 'At least 3 of 4 types (upper, lower, digit, special)', m: cnt >= 3 }
    ];
    var html = '<div style="font-size:.7rem;line-height:1.6;margin-top:.1rem">';
    items.forEach(function(it) {
      html += '<span style="color:' + (ok || it.m ? '#2E7D32' : '#C62828') + '">' + (it.m ? '✓' : '✗') + ' ' + it.l + '</span><br>';
    });
    return html + '</div>';
  };
  window.updatePasswordHint = window.updatePasswordHint || function(inputId, hintId) {
    var inp = document.getElementById(inputId);
    var h = document.getElementById(hintId);
    if (!inp || !h) return false;
    var v = inp.value;
    if (v.length === 0) { h.innerHTML = 'Min 8 chars with at least 3 of: uppercase, lowercase, number, special character.'; h.style.color = '#888'; return false; }
    if (window.isPasswordFullyValid(v)) { h.innerHTML = '✓ Password meets requirements.'; h.style.color = '#2E7D32'; }
    else { h.innerHTML = window.passwordConditionsHTML(v); h.style.color = ''; }
    return window.isPasswordFullyValid(v);
  };

  var pwdForm = document.getElementById('passwordForm');
  if (pwdForm) {
    pwdForm.addEventListener('submit', function(e) {
      var current = document.getElementById('currentPassword').value.trim();
      var newPwd  = document.getElementById('newPassword').value.trim();
      var confirm = document.getElementById('confirmPassword').value.trim();
      if (!current || !newPwd || !confirm) {
        e.preventDefault();
        alert('Please fill in all password fields.');
        return;
      }
      if (newPwd !== confirm) {
        e.preventDefault();
        alert('New passwords do not match.');
        return;
      }
      if (!window.isPasswordFullyValid(newPwd)) {
        e.preventDefault();
        document.getElementById('np-hint').innerHTML = '<span style="color:#C62828">✗ Password does not meet requirements. See conditions above.</span>';
        return;
      }
    });
  }

  var profileForm = document.getElementById('profileForm');
  if (profileForm) {
    profileForm.addEventListener('submit', function(e) {
      var email = profileForm.querySelector('input[name="email"]').value.trim();
      if (!email) {
        e.preventDefault();
        alert('Email address is required.');
        return;
      }
      if (!email.includes('@') || !email.includes('.')) {
        e.preventDefault();
        alert('Please enter a valid email address.');
        return;
      }
    });
  }

})();
</script>

<%- include('warden-footer') %>