<script src="/js/preloader.js"></script>
<script>
    // Navbar scroll effect
    const navbar = document.getElementById("navbar");
    window.addEventListener("scroll", () => {
        if (window.scrollY > 50) {
            navbar.classList.add("scrolled");
        } else {
            navbar.classList.remove("scrolled");
        }
    });

    // Reveal animations on scroll
    function reveal() {
        const reveals = document.querySelectorAll('.reveal, .reveal-card, .reveal-text, .stat, .section-header');
        reveals.forEach(element => {
            const windowHeight = window.innerHeight;
            const elementTop = element.getBoundingClientRect().top;
            const elementVisible = 120;
            if (elementTop < windowHeight - elementVisible) {
                element.classList.add('active');
            }
            if (elementTop > windowHeight) {
                element.classList.remove('active');
            }
        });
    }

    window.addEventListener('scroll', reveal);
    reveal();
</script>
<script>
  const headingText = "Safe place\nFor Students";
  const subText = "Discipline. Community. Growth. Your home during the academic journey.";
  const headingEl = document.getElementById('typing-heading');
  const subEl = document.getElementById('typing-sub');

  let headingIndex = 0;
  let subIndex = 0;
  let typingTimer;

  function typeHeading() {
    if (headingIndex < headingText.length) {
      if (headingText.charAt(headingIndex) === '\n') {
        headingEl.innerHTML += '<br>';
      } else {
        headingEl.innerHTML += headingText.charAt(headingIndex);
      }
      headingIndex++;
      typingTimer = setTimeout(typeHeading, 60);
    } else {
      setTimeout(typeSub, 400);
    }
  }

  function typeSub() {
    if (subIndex < subText.length) {
      subEl.innerHTML += subText.charAt(subIndex);
      subIndex++;
      typingTimer = setTimeout(typeSub, 40);
    } else {
      // Wait 5 seconds, then clear and restart
      typingTimer = setTimeout(resetTyping, 5000);
    }
  }

  function resetTyping() {
    // Clear text
    headingEl.innerHTML = '';
    subEl.innerHTML = '';
    headingIndex = 0;
    subIndex = 0;
    // Small pause then start again
    typingTimer = setTimeout(typeHeading, 500);
  }

  // Start after page loads
  window.addEventListener('load', () => {
    setTimeout(typeHeading, 500);
  });
</script>

